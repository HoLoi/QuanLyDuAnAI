@model QuanLyDuAn.ViewModels.ChucDanh.ChucDanhPageViewModel
@using QuanLyDuAn.Constants

@{
    ViewData["Title"] = "Chức danh";
    var permissions = Model.Permissions;
    bool canShowForm = permissions.Contains(Permissions.ChucDanh.Them) || permissions.Contains(Permissions.ChucDanh.Sua);
    ViewBag.Permissions = permissions;
}

@section Styles {
    <link rel="stylesheet" href="~/css/ChucDanh/index.css" asp-append-version="true" />
}

<section class="chuc-danh-page">
    <header class="chuc-danh-header-card">
        <h1 class="chuc-danh-title">Chức danh</h1>
        <p class="chuc-danh-subtitle">Quản lý danh mục chức danh và mô tả nghiệp vụ.</p>
    </header>

    <section class="chuc-danh-section-card">
        <div asp-validation-summary="All" class="text-danger mb-2"></div>

        @if (canShowForm)
        {
            <partial name="_Form" for="Form" />
            <hr />
        }

        <partial name="_Table" model="Model.DanhSach" />
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
