@model List<QuanLyDuAn.ViewModels.ChucDanh.ChucDanhViewModel>
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    
}

<table class="table table-bordered mt-3 app-data-table">
    <thead>
        <tr>
            <th>Tên</th>
            <th>Mô tả</th>
            <th class="col-actions"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cd in Model)
        {
            <tr>
                <td>@cd.TenChucDanh</td>
                <td>@cd.MoTaChucDanh</td>
                <td class="col-actions table-actions">
                    @if (permissions.Contains(Permissions.ChucDanh.Sua))
                    {
                        <a asp-action="Sua" asp-route-id="@cd.MaChucDanh" class="btn btn-action btn-subtle">Sửa</a>
                    }

                    @if (permissions.Contains(Permissions.ChucDanh.Xoa))
                    {
                        <form asp-action="XoaChucDanh" method="post">
                            <input type="hidden" name="maChucDanh" value="@cd.MaChucDanh" />
                            <button type="submit" class="btn btn-action btn-danger-soft">Xóa</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
