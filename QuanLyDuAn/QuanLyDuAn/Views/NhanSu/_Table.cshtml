@model List<QuanLyDuAn.ViewModels.NhanSu.NhanSuViewModel>
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    var maNguoiDungHienTai = ViewBag.MaNguoiDungHienTai as int?;
}

<table class="table workflow-table mt-3 app-data-table">
    <thead>
        <tr>
            <th>Họ tên</th>
            <th>Chức danh</th>
            <th>SĐT</th>
            <th>Email</th>
            <th class="col-status">Tài khoản</th>
            <th class="col-actions"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ns in Model)
        {
            <tr>
                <td>@ns.HoTenNguoiDung</td>
                <td>@ns.TenChucDanh</td>
                <td>@ns.SdtNguoiDung</td>
                <td>@ns.Email</td>
                <td class="col-status">
                    @if (!ns.CoTaiKhoan)
                    {
                        <span class="workflow-badge workflow-idle">Chưa có</span>
                    }
                    else if (ns.TaiKhoanBiKhoa)
                    {
                        <span class="workflow-badge workflow-blocked">@TrangThai.TaiKhoanKhoaHienThi</span>
                    }
                    else if (ns.ChoKichHoat)
                    {
                        <span class="workflow-badge workflow-idle">@TrangThai.TaiKhoanChoKichHoatHienThi</span>
                    }
                    else
                    {
                        <span class="workflow-badge workflow-success">@TrangThai.TaiKhoanHoatDongHienThi</span>
                    }
                </td>
                <td class="col-actions table-actions">
                    @if (permissions.Contains(Permissions.NhanSu.Sua))
                    {
                        <a asp-action="Sua" asp-route-id="@ns.MaNguoiDung" class="btn-action btn-subtle">Sửa</a>
                    }

                    @if (permissions.Contains(Permissions.NhanSu.Xoa) && ns.MaNguoiDung != maNguoiDungHienTai)
                    {
                        <form asp-action="XoaNhanSu"
                              method="post"
                              data-confirm-first="Bạn có chắc chắn muốn xóa nhân sự này? Hồ sơ sẽ được xóa khỏi danh sách hoạt động và tài khoản sẽ không thể đăng nhập.">
                            <input type="hidden" name="maNguoiDung" value="@ns.MaNguoiDung" />
                            <button type="submit" class="btn-action btn-danger-soft">Xóa</button>
                        </form>
                    }

                    @if (ns.CoTheGuiLaiKichHoat && permissions.Contains(Permissions.NhanSu.Sua))
                    {
                        <form asp-action="GuiLaiEmailKichHoat" method="post">
                            <input type="hidden" name="maNguoiDung" value="@ns.MaNguoiDung" />
                            <button type="submit" class="btn-action btn-subtle">Gửi kích hoạt</button>
                        </form>
                    }

                    @if (ns.MaNguoiDung == maNguoiDungHienTai)
                    {
                        <span class="workflow-badge workflow-idle">Tài khoản hiện tại</span>
                    }
                    else if (ns.CoTaiKhoan && permissions.Contains(Permissions.NhanSu.Khoa) && !ns.TaiKhoanBiKhoa)
                    {
                        <form asp-action="KhoaTaiKhoan"
                              method="post"
                              data-confirm-first="Bạn có chắc chắn muốn khóa tài khoản này? Người dùng sẽ tạm thời không thể đăng nhập.">
                            <input type="hidden" name="maNguoiDung" value="@ns.MaNguoiDung" />
                            <button type="submit" class="btn-action btn-danger-soft">Khóa</button>
                        </form>
                    }

                    @if (ns.CoTaiKhoan && permissions.Contains(Permissions.NhanSu.MoKhoa) && ns.TaiKhoanBiKhoa)
                    {
                        <form asp-action="MoKhoaTaiKhoan" method="post">
                            <input type="hidden" name="maNguoiDung" value="@ns.MaNguoiDung" />
                            <button type="submit" class="btn-action btn-confirm">Mở khóa</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
