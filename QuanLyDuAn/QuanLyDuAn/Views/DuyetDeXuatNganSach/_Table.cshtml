@model QuanLyDuAn.ViewModels.DuyetDeXuatNganSach.DuyetDeXuatNganSachPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    
    var canApprove = permissions.Contains(Permissions.DuyetNganSach.Duyet);
}

<table class="table table-bordered table-sm">
    <thead>
        <tr>
            <th>Mã</th>
            <th>Dự án</th>
            <th>Người đề xuất</th>
            <th>Ngân sách cũ</th>
            <th>Ngân sách đề xuất</th>
            <th>Lý do</th>
            <th>Ngày đề xuất</th>
            <th>Trạng thái</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.DanhSach.Count == 0)
        {
            <tr>
                <td colspan="9" class="text-center text-muted">Không có đề xuất ngân sách.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.DanhSach)
            {
                <tr>
                    <td>@item.MaDeXuatNS</td>
                    <td>@item.TenDuAn</td>
                    <td>@item.NguoiDungDeXuat</td>
                    <td>@item.NganSachCu?.ToString("N0")</td>
                    <td>@item.NganSachDeXuat?.ToString("N0")</td>
                    <td>@item.LyDoDeXuat</td>
                    <td>@item.NgayDeXuat?.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@TrangThai.ToDisplay(item.TrangThaiDeXuat)</td>
                    <td>
                        @if (canApprove && TrangThai.EqualsValue(item.TrangThaiDeXuat, TrangThai.ChoDuyet))
                        {
                            <div class="d-flex gap-1">
                                <form asp-action="Duyet" method="post">
                                    <input type="hidden" name="maDeXuatNs" value="@item.MaDeXuatNS" />
                                    <input type="hidden" name="locMaDuAn" value="@Model.LocMaDuAn" />
                                    <input type="hidden" name="locTrangThai" value="@Model.LocTrangThai" />
                                    <button type="submit" class="btn btn-sm btn-success">Duyệt</button>
                                </form>
                                <form asp-action="TuChoi" method="post" class="d-flex gap-1">
                                    <input type="hidden" name="maDeXuatNs" value="@item.MaDeXuatNS" />
                                    <input type="hidden" name="locMaDuAn" value="@Model.LocMaDuAn" />
                                    <input type="hidden" name="locTrangThai" value="@Model.LocTrangThai" />
                                    <input type="text" name="lyDo" class="form-control form-control-sm" placeholder="Lý do" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Từ chối</button>
                                </form>
                            </div>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
