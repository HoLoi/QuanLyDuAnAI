@model QuanLyDuAn.ViewModels.DuyetDeXuatNganSach.DuyetDeXuatNganSachPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    var canApprove = permissions.Contains(Permissions.DuyetNganSach.Duyet);

    string GetStatusBadgeClass(string? status)
    {
        if (TrangThai.EqualsValue(status, TrangThai.ChoDuyet))
            return "is-pending";
        if (TrangThai.EqualsValue(status, TrangThai.DaDuyet))
            return "is-approved";
        if (TrangThai.EqualsValue(status, TrangThai.TuChoi))
            return "is-rejected";
        if (TrangThai.EqualsValue(status, TrangThai.DaHuy))
            return "is-cancelled";

        return "is-neutral";
    }
}

<div class="duyet-de-xuat-ngan-sach-section-head">
    <h2 class="duyet-de-xuat-ngan-sach-section-title">Danh sách đề xuất</h2>
    <p class="duyet-de-xuat-ngan-sach-section-note">Bảng rút gọn theo thông tin chính, bấm xem chi tiết để mở thông tin đầy đủ.</p>
</div>

@if (Model.DanhSach.Count == 0)
{
    <div class="duyet-de-xuat-ngan-sach-empty-state">
        <p class="duyet-de-xuat-ngan-sach-empty-title">Chưa có đề xuất cần xử lý.</p>
    </div>
}
else
{
    <div class="duyet-de-xuat-ngan-sach-table-scroll">
        <table class="table duyet-de-xuat-ngan-sach-table">
            <thead>
                <tr>
                    <th>Mã</th>
                    <th>Dự án</th>
                    <th>Ngân sách cũ</th>
                    <th>Ngân sách đề xuất</th>
                    <th>Ngày đề xuất</th>
                    <th>Trạng thái</th>
                    <th class="col-actions">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DanhSach)
                {
                    var isPending = TrangThai.EqualsValue(item.TrangThaiDeXuat, TrangThai.ChoDuyet);
                    var detailRowId = $"dxns-detail-{item.MaDeXuatNS}";
                    var chenhLech = (item.NganSachDeXuat ?? 0) - (item.NganSachCu ?? 0);
                    <tr class="duyet-de-xuat-ngan-sach-main-row">
                        <td class="text-nowrap">#@item.MaDeXuatNS</td>
                        <td>
                            <div class="duyet-de-xuat-ngan-sach-cell-title">@item.TenDuAn</div>
                            <div class="duyet-de-xuat-ngan-sach-cell-sub">Mã dự án: @item.MaDuAn</div>
                        </td>
                        <td class="text-nowrap">
                            @if (item.NganSachCu.HasValue)
                            {
                                @($"{item.NganSachCu.Value:N0} VNĐ")
                            }
                            else
                            {
                                <span class="duyet-de-xuat-ngan-sach-cell-sub">Chưa có</span>
                            }
                        </td>
                        <td class="text-nowrap">
                            @if (item.NganSachDeXuat.HasValue)
                            {
                                @($"{item.NganSachDeXuat.Value:N0} VNĐ")
                            }
                            else
                            {
                                <span class="duyet-de-xuat-ngan-sach-cell-sub">0 VNĐ</span>
                            }
                        </td>
                        <td class="text-nowrap">@item.NgayDeXuat?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="duyet-de-xuat-ngan-sach-status-badge @GetStatusBadgeClass(item.TrangThaiDeXuat)">
                                @TrangThai.ToDisplay(item.TrangThaiDeXuat)
                            </span>
                        </td>
                        <td class="col-actions">
                            <div class="duyet-de-xuat-ngan-sach-table-actions">
                                @if (canApprove && isPending)
                                {
                                    <form asp-action="Duyet" method="post" class="js-confirm-submit" data-confirm="Xác nhận duyệt đề xuất này?">
                                        <input type="hidden" name="maDeXuatNs" value="@item.MaDeXuatNS" />
                                        <input type="hidden" name="locMaDuAn" value="@Model.LocMaDuAn" />
                                        <input type="hidden" name="locTrangThai" value="@Model.LocTrangThai" />
                                        <button type="submit" class="duyet-de-xuat-ngan-sach-action-btn duyet-de-xuat-ngan-sach-action-approve">Duyệt</button>
                                    </form>
                                    <form asp-action="TuChoi" method="post" class="js-confirm-submit" data-confirm="Xác nhận từ chối đề xuất này?">
                                        <input type="hidden" name="maDeXuatNs" value="@item.MaDeXuatNS" />
                                        <input type="hidden" name="locMaDuAn" value="@Model.LocMaDuAn" />
                                        <input type="hidden" name="locTrangThai" value="@Model.LocTrangThai" />
                                        <input type="hidden" name="lyDo" value="" />
                                        <button type="submit" class="duyet-de-xuat-ngan-sach-action-btn duyet-de-xuat-ngan-sach-action-reject">Từ chối</button>
                                    </form>
                                }
                                <button type="button"
                                        class="duyet-de-xuat-ngan-sach-action-btn duyet-de-xuat-ngan-sach-action-detail js-toggle-detail"
                                        data-target="@detailRowId"
                                        aria-expanded="false">
                                    Xem chi tiết
                                </button>
                            </div>
                        </td>
                    </tr>
                    <tr id="@detailRowId" class="duyet-de-xuat-ngan-sach-detail-row d-none">
                        <td colspan="7">
                            <div class="duyet-de-xuat-ngan-sach-detail-card">
                                <div class="duyet-de-xuat-ngan-sach-detail-grid">
                                    <div class="duyet-de-xuat-ngan-sach-detail-item">
                                        <span class="duyet-de-xuat-ngan-sach-detail-label">Người đề xuất</span>
                                        <span class="duyet-de-xuat-ngan-sach-detail-value">@item.NguoiDungDeXuat</span>
                                    </div>
                                    <div class="duyet-de-xuat-ngan-sach-detail-item duyet-de-xuat-ngan-sach-detail-item-wide">
                                        <span class="duyet-de-xuat-ngan-sach-detail-label">Lý do đề xuất</span>
                                        <span class="duyet-de-xuat-ngan-sach-detail-value">
                                            @if (!string.IsNullOrWhiteSpace(item.LyDoDeXuat))
                                            {
                                                @item.LyDoDeXuat
                                            }
                                            else
                                            {
                                                @:Chưa có mô tả
                                            }
                                        </span>
                                    </div>
                                    <div class="duyet-de-xuat-ngan-sach-detail-item">
                                        <span class="duyet-de-xuat-ngan-sach-detail-label">Chênh lệch ngân sách</span>
                                        <span class="duyet-de-xuat-ngan-sach-detail-value">
                                            @($"{chenhLech:N0} VNĐ")
                                        </span>
                                    </div>
                                    <div class="duyet-de-xuat-ngan-sach-detail-item">
                                        <span class="duyet-de-xuat-ngan-sach-detail-label">Người duyệt</span>
                                        <span class="duyet-de-xuat-ngan-sach-detail-value">
                                            @if (!string.IsNullOrWhiteSpace(item.NguoiDungDuyet))
                                            {
                                                @item.NguoiDungDuyet
                                            }
                                            else
                                            {
                                                @:Chưa duyệt
                                            }
                                        </span>
                                    </div>
                                    <div class="duyet-de-xuat-ngan-sach-detail-item">
                                        <span class="duyet-de-xuat-ngan-sach-detail-label">Ngày duyệt</span>
                                        <span class="duyet-de-xuat-ngan-sach-detail-value">
                                            @(item.NgayDuyet?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa duyệt")
                                        </span>
                                    </div>
                                    <div class="duyet-de-xuat-ngan-sach-detail-item duyet-de-xuat-ngan-sach-detail-item-wide">
                                        <span class="duyet-de-xuat-ngan-sach-detail-label">Lý do từ chối / ghi chú</span>
                                        <span class="duyet-de-xuat-ngan-sach-detail-value">Không có</span>
                                    </div>
                                </div>
                                @if (canApprove && isPending)
                                {
                                    <form asp-action="TuChoi" method="post" class="duyet-de-xuat-ngan-sach-reject-form js-confirm-submit" data-confirm="Xác nhận từ chối đề xuất này?">
                                        <input type="hidden" name="maDeXuatNs" value="@item.MaDeXuatNS" />
                                        <input type="hidden" name="locMaDuAn" value="@Model.LocMaDuAn" />
                                        <input type="hidden" name="locTrangThai" value="@Model.LocTrangThai" />
                                        <input type="text" name="lyDo" class="form-control form-control-sm" placeholder="Nhập lý do từ chối (nếu có)" />
                                        <button type="submit" class="duyet-de-xuat-ngan-sach-action-btn duyet-de-xuat-ngan-sach-action-reject">Gửi từ chối kèm lý do</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
