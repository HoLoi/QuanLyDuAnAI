@model QuanLyDuAn.ViewModels.DuyetDeXuatNganSach.DuyetDeXuatNganSachPageViewModel
@using QuanLyDuAn.Constants

@{
    ViewData["Title"] = "Duyệt đề xuất ngân sách";
    var permissions = Model.Permissions;
    ViewBag.Permissions = permissions;
}

@section Styles {
    <link rel="stylesheet" href="~/css/shared/approval.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/DuyetDeXuatNganSach/index.css" asp-append-version="true" />
}

<section class="duyet-de-xuat-ngan-sach-page app-page approval-page">
    <header class="duyet-de-xuat-ngan-sach-header-card app-page-header approval-header-card">
        <div class="duyet-de-xuat-ngan-sach-header-content">
            <h1 class="duyet-de-xuat-ngan-sach-title app-page-title">Duyệt đề xuất ngân sách</h1>
            <p class="duyet-de-xuat-ngan-sach-subtitle app-page-subtitle">Xem xét, duyệt hoặc từ chối các đề xuất thay đổi ngân sách của dự án</p>
        </div>
    </header>

    <section class="duyet-de-xuat-ngan-sach-section-card app-section-card approval-section-card">
        <partial name="_Filter" model="Model" />
    </section>

    <section class="duyet-de-xuat-ngan-sach-section-card app-section-card approval-section-card">
        <partial name="_Table" model="Model" />
    </section>
</section>

@section Scripts {
    <script src="~/js/approval/index.js" asp-append-version="true"></script>
}
