@model QuanLyDuAn.ViewModels.DuyetDeXuatNganSach.DuyetDeXuatNganSachPageViewModel
@using QuanLyDuAn.Constants

<div class="duyet-de-xuat-ngan-sach-section-head">
    <h2 class="duyet-de-xuat-ngan-sach-section-title">Bộ lọc danh sách</h2>
    <p class="duyet-de-xuat-ngan-sach-section-note">Lọc theo dự án và trạng thái để kiểm soát các đề xuất ngân sách cần xử lý.</p>
</div>

<form asp-action="Index" method="get" class="duyet-de-xuat-ngan-sach-filter-form">
    <div>
        <label for="locMaDuAn" class="form-label">Mã dự án</label>
        <input id="locMaDuAn" type="number" name="locMaDuAn" value="@Model.LocMaDuAn" class="form-control" placeholder="Nhập mã dự án" />
    </div>
    <div>
        <label for="locTrangThai" class="form-label">Trạng thái đề xuất</label>
        <select id="locTrangThai" name="locTrangThai" class="form-select">
            <option value="">Tất cả trạng thái</option>
            <option value="@TrangThai.ChoDuyet" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.ChoDuyet))">@TrangThai.ChoDuyetHienThi</option>
            <option value="@TrangThai.DaDuyet" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.DaDuyet))">@TrangThai.DaDuyetHienThi</option>
            <option value="@TrangThai.TuChoi" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.TuChoi))">@TrangThai.TuChoiHienThi</option>
            <option value="@TrangThai.DaHuy" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.DaHuy))">@TrangThai.DaHuyHienThi</option>
        </select>
    </div>
    <div class="duyet-de-xuat-ngan-sach-filter-actions">
        <button class="duyet-de-xuat-ngan-sach-filter-btn-primary" type="submit">Lọc dữ liệu</button>
        <a asp-action="Index" class="duyet-de-xuat-ngan-sach-filter-btn-secondary">Làm mới</a>
    </div>
</form>
