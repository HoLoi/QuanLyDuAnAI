@model QuanLyDuAn.ViewModels.DanhGiaDuAn.DanhGiaDuAnPageViewModel
@using QuanLyDuAn.Constants

@{
    ViewData["Title"] = "Đánh giá dự án";
    var canTacNghiep = Model.Permissions.Contains(Permissions.DanhGiaDuAn.DanhGia)
                       || Model.Permissions.Contains(Permissions.DanhGiaDuAn.Sua);
}

@section Styles
{
    <link rel="stylesheet" href="~/css/DanhGiaDuAn/index.css" asp-append-version="true" />
}

<div class="danh-gia-du-an-page">
    <div class="danh-gia-card">
        <div class="page-head">
            <h5 class="mb-1">Đánh giá dự án</h5>
            <p class="text-muted mb-0">Tổng hợp chất lượng dự án theo tiêu chí, số liệu hỗ trợ và luồng duyệt hiện tại.</p>
        </div>

        @await Html.PartialAsync("_Filter", Model)

        @if (canTacNghiep && Model.MaDuAn.HasValue)
        {
            <div class="mb-3">
                <a asp-action="Form"
                   asp-route-maDuAn="@Model.MaDuAn"
                   asp-route-tuKhoa="@Model.TuKhoa"
                   asp-route-trangThai="@Model.TrangThai"
                   class="btn btn-primary btn-sm">
                    Đánh giá dự án đang lọc
                </a>
            </div>
        }

        @await Html.PartialAsync("_SummaryCards", Model)

        @if (Model.Form != null)
        {
            @await Html.PartialAsync("_Form", Model.Form)
        }

        @if (Model.DanhSach.Any())
        {
            @await Html.PartialAsync("_Table", Model)
        }
        else
        {
            @await Html.PartialAsync("_EmptyState")
        }
    </div>
</div>
