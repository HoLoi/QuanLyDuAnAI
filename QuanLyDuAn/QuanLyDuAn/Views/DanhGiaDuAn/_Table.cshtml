@model QuanLyDuAn.ViewModels.DanhGiaDuAn.DanhGiaDuAnPageViewModel
@{
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="table-responsive dgda-table-wrap app-table-scroll evaluation-table-wrap">
    <table class="table workflow-table align-middle dgda-table app-data-table evaluation-table">
        <thead>
            <tr>
                <th class="dgda-col-project">Dự án</th>
                <th>Quản lý</th>
                <th>Trạng thái dự án</th>
                <th>% hoàn thành</th>
                <th>Số công việc</th>
                <th>Số công việc trễ</th>
                <th>Trạng thái đánh giá</th>
                <th class="text-end">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.DanhSach)
            {
                <tr class="@(item.DuAnTreTienDo ? "dgda-row-late" : null)">
                    <td class="dgda-col-project">
                        <div class="fw-semibold">@item.TenDuAn</div>
                    </td>
                    <td>@item.TenNguoiQuanLy</td>
                    <td>
                        <div>@item.TrangThaiDuAn</div>
                        @if (item.DuAnTreTienDo)
                        {
                            <div class="mt-1">
                                <span class="dgda-late-badge evaluation-late-badge">Trễ tiến độ</span>
                                @if (item.SoNgayQuaHan.HasValue && item.SoNgayQuaHan.Value > 0)
                                {
                                    <span class="text-muted small ms-1">Quá hạn @item.SoNgayQuaHan ngày</span>
                                }
                            </div>
                        }
                        @if (!item.DuDieuKienDanhGia)
                        {
                            <div class="text-muted small">Chưa đủ điều kiện.</div>
                        }
                    </td>
                    <td>@item.PhanTramHoanThanh%</td>
                    <td>@item.TongCongViec</td>
                    <td>@item.CongViecTreHan</td>
                    <td>@await Html.PartialAsync("_TrangThaiDanhGiaBadge", item.TrangThaiDanhGia)</td>
                    <td class="text-end dgda-col-actions">
                        <div class="table-actions dgda-table-actions evaluation-table-actions">
                            <a asp-controller="DanhGiaNhanVien"
                               asp-action="Index"
                               asp-route-maDuAn="@item.MaDuAn"
                               asp-route-nguon="du-an"
                               asp-route-returnUrl="@currentUrl"
                               class="btn-action btn-subtle">
                                Đánh giá nhân viên
                            </a>

                            @if (!item.CoDanhGia && item.CoTheDanhGia)
                            {
                                <a asp-action="Form"
                                   asp-route-maDuAn="@item.MaDuAn"
                                   asp-route-tuKhoa="@Model.TuKhoa"
                                   asp-route-trangThai="@Model.TrangThai"
                                   asp-route-returnUrl="@currentUrl"
                                   asp-route-tuNgayDanhGia="@Model.TuNgayDanhGia?.ToString("yyyy-MM-dd")"
                                   asp-route-denNgayDanhGia="@Model.DenNgayDanhGia?.ToString("yyyy-MM-dd")"
                                   class="btn-action btn-confirm">
                                    Đánh giá
                                </a>
                            }
                            else if (item.CoDanhGia && item.CoTheSua)
                            {
                                <a asp-action="Form"
                                   asp-route-maDuAn="@item.MaDuAn"
                                   asp-route-tuKhoa="@Model.TuKhoa"
                                   asp-route-trangThai="@Model.TrangThai"
                                   asp-route-returnUrl="@currentUrl"
                                   asp-route-tuNgayDanhGia="@Model.TuNgayDanhGia?.ToString("yyyy-MM-dd")"
                                   asp-route-denNgayDanhGia="@Model.DenNgayDanhGia?.ToString("yyyy-MM-dd")"
                                   class="btn-action btn-confirm">
                                    Sửa đánh giá
                                </a>
                            }
                            else if (item.CoDanhGia)
                            {
                                <a asp-action="ChiTiet" asp-route-maDanhGiaDuAn="@item.MaDanhGiaDuAn" asp-route-returnUrl="@currentUrl" class="btn-action btn-subtle">Xem đánh giá</a>
                            }
                            else if (!item.DuDieuKienDanhGia)
                            {
                                <span class="text-muted small">Chờ dự án hoàn thành/lưu trữ.</span>
                            }

                            @if (item.CoDanhGia && item.CoTheXacNhan)
                            {
                                <form asp-action="XacNhan" method="post">
                                    <input type="hidden" name="maDanhGiaDuAn" value="@item.MaDanhGiaDuAn" />
                                    <input type="hidden" name="maDuAn" value="@item.MaDuAn" />
                                    <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
                                    <input type="hidden" name="trangThai" value="@Model.TrangThai" />
                                    <input type="hidden" name="returnUrl" value="@currentUrl" />
                                    <input type="hidden" name="tuNgayDanhGia" value="@Model.TuNgayDanhGia?.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="denNgayDanhGia" value="@Model.DenNgayDanhGia?.ToString("yyyy-MM-dd")" />
                                    <button type="submit" class="btn-action btn-confirm">Xác nhận đánh giá</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

