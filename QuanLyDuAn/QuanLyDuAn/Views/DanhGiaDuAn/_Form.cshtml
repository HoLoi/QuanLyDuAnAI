@model QuanLyDuAn.ViewModels.DanhGiaDuAn.DanhGiaDuAnFormViewModel
@{
    var tuKhoa = Context.Request.Query["tuKhoa"].ToString();
    var trangThai = Context.Request.Query["trangThai"].ToString();
    var tuNgayDanhGia = Context.Request.Query["tuNgayDanhGia"].ToString();
    var denNgayDanhGia = Context.Request.Query["denNgayDanhGia"].ToString();
    var returnUrl = Context.Request.Query["returnUrl"].ToString();
    var formBackUrl = Url.IsLocalUrl(returnUrl)
        ? returnUrl
        : Url.Action("Index", "DanhGiaDuAn", new
        {
            maDuAn = Model.MaDuAn,
            tuKhoa,
            trangThai,
            tuNgayDanhGia,
            denNgayDanhGia
        });
    var duAnDangTre = Model.ThongKe?.DuAnBiTreTheoAi == true;
    var daCoDanhGia = Model.MaDanhGiaDuAn.HasValue && Model.TieuChi.Any(x => x.MaChiTietDGDA.HasValue);
}

<div class="dgda-form card mb-3">
    <div class="card-body">
        <div class="evaluation-form-toolbar mb-2">
            <a href="@formBackUrl" class="btn-action dgda-back-btn">← Trở lại</a>
        </div>
        <h6 class="mb-3">Form đánh giá dự án: @Model.TenDuAn</h6>

        <details class="support-collapse mb-3" open>
            <summary>Dữ liệu hỗ trợ</summary>
            <div class="mt-2">
                @await Html.PartialAsync("_ProjectStats", Model.ThongKe)
                @if (duAnDangTre)
                {
                    @await Html.PartialAsync("_AiInsightCard", Model.ThongKe)
                }
            </div>
        </details>

        @if (duAnDangTre)
        {
            <form asp-action="PhanTichAiDuAn" method="post" id="phanTichAiDuAnForm" class="d-none">
                @Html.AntiForgeryToken()
                <input type="hidden" name="maDuAn" value="@Model.MaDuAn" />
            </form>

            <div class="ai-confirm-card card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="mb-2">Xác nhận nguyên nhân thực tế</h6>
                    <p class="text-muted mb-2">AI chỉ tham khảo, xác nhận của Manager là dữ liệu thực tế.</p>

                    <div class="row g-2 mb-2">
                        <div class="col-md-6">
                            <div class="mini-stat">
                                <span>Nguyên nhân AI</span>
                                <strong>@(string.IsNullOrWhiteSpace(Model.TenNguyenNhanAiDuDoan) ? "Chưa có gợi ý AI" : Model.TenNguyenNhanAiDuDoan)</strong>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mini-stat">
                                <span>Nguyên nhân Manager xác nhận</span>
                                <strong>@(string.IsNullOrWhiteSpace(Model.TenNguyenNhanManagerXacNhan) ? "Chưa xác nhận" : Model.TenNguyenNhanManagerXacNhan)</strong>
                            </div>
                        </div>
                    </div>

                    @if (Model.HienThiKhuXacNhanNguyenNhan)
                    {
                        var maNguyenNhanMacDinh = Model.MaDmNguyenNhanManagerXacNhan ?? Model.MaDmNguyenNhanAiDuDoan;
                        <form asp-action="XacNhanNguyenNhan" method="post" class="row g-2 align-items-end">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="maDuAn" value="@Model.MaDuAn" />
                            <input type="hidden" name="tuKhoa" value="@tuKhoa" />
                            <input type="hidden" name="trangThai" value="@trangThai" />
                            <input type="hidden" name="tuNgayDanhGia" value="@tuNgayDanhGia" />
                            <input type="hidden" name="denNgayDanhGia" value="@denNgayDanhGia" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />

                            <div class="col-md-6">
                                <label class="form-label">Nguyên nhân Manager xác nhận</label>
                                <select class="form-select" name="maDmNguyenNhan" required>
                                    <option value="">Chọn nguyên nhân</option>
                                    @foreach (var item in Model.DanhSachNguyenNhan)
                                    {
                                        <option value="@item.MaDMNguyenNhan" selected="@(maNguyenNhanMacDinh == item.MaDMNguyenNhan ? "selected" : null)">@item.TenNguyenNhan</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Độ tin cậy (tùy chọn)</label>
                                <input type="number" class="form-control" step="0.01" min="0" max="1" name="doTinCay" value="@Model.DoTinCayAi?.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn-action btn-confirm w-100">Xác nhận nguyên nhân</button>
                            </div>
                        </form>
                    }
                    else if (!string.IsNullOrWhiteSpace(Model.ThongBaoXacNhanNguyenNhan))
                    {
                        <div class="empty-note">@Model.ThongBaoXacNhanNguyenNhan</div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="empty-note mb-3">Dự án không trễ nên không cần xác nhận nguyên nhân trễ.</div>
        }

        <div class="row g-2 mb-3">
            <div class="col-md-4"><div class="mini-stat"><span>Trạng thái dự án</span><strong>@Model.TrangThaiDuAn</strong></div></div>
            <div class="col-md-4">
                <div class="mini-stat">
                    <span>Điểm tổng kết</span>
                    @if (daCoDanhGia)
                    {
                        <div class="score-badge"><strong>@Model.DiemTongKet.ToString("0.0")</strong><small>@Model.XepLoai</small></div>
                    }
                    else
                    {
                        <strong>Chưa đánh giá</strong>
                    }
                </div>
            </div>
            <div class="col-md-4">
                <div class="mini-stat">
                    <span>Xếp loại</span>
                    <strong>@(daCoDanhGia ? Model.XepLoai : "Chưa đánh giá")</strong>
                </div>
            </div>
        </div>

        <form asp-action="Luu" method="post" class="vstack gap-2">
            <input type="hidden" asp-for="MaDanhGiaDuAn" />
            <input type="hidden" asp-for="MaDuAn" />
            <input type="hidden" name="tuKhoa" value="@tuKhoa" />
            <input type="hidden" name="trangThai" value="@trangThai" />
            <input type="hidden" name="tuNgayDanhGia" value="@tuNgayDanhGia" />
            <input type="hidden" name="denNgayDanhGia" value="@denNgayDanhGia" />
            <input type="hidden" name="returnUrl" value="@returnUrl" />

            @for (var i = 0; i < Model.TieuChi.Count; i++)
            {
                <div class="criteria-row">
                    <input type="hidden" asp-for="TieuChi[i].MaChiTietDGDA" />
                    <input type="hidden" asp-for="TieuChi[i].MaTieuChi" />
                    <input type="hidden" asp-for="TieuChi[i].TenTieuChi" />
                    <div class="criteria-title">@Model.TieuChi[i].TenTieuChi</div>
                    <div class="row g-2">
                        <div class="col-md-2">
                            <label class="form-label">Điểm (1-10)</label>
                            <input asp-for="TieuChi[i].DiemDanhGiaDA" class="form-control" min="1" max="10" />
                        </div>
                        <div class="col-md-10">
                            <label class="form-label">Nhận xét</label>
                            <input asp-for="TieuChi[i].NhanXetDuAn" class="form-control" maxlength="500" />
                        </div>
                    </div>
                </div>
            }

            <div>
                <label class="form-label">Nhận xét tổng dự án</label>
                <textarea asp-for="NhanXetTongDuAn" class="form-control" rows="3" maxlength="500"></textarea>
            </div>

            <div class="d-flex flex-wrap gap-2">
                @if (Model.CoTheLuu)
                {
                    <button type="submit" class="btn-action btn-confirm">Lưu đánh giá</button>
                }
                @if (Model.CoTheGuiDuyet && Model.MaDanhGiaDuAn.HasValue)
                {
                    <button type="submit"
                            class="btn-action btn-subtle"
                            formaction="@Url.Action("GuiDuyet", "DanhGiaDuAn")"
                            formmethod="post"
                            name="maDanhGiaDuAn"
                            value="@Model.MaDanhGiaDuAn">
                        Gửi duyệt
                    </button>
                }
            </div>
        </form>
    </div>
</div>

<script>
(() => {
    const card = document.getElementById('aiInsightCard');
    const submitForm = document.getElementById('phanTichAiDuAnForm');
    const actionButton = document.getElementById('btnPhanTichAiDuAn');
    if (!card || !submitForm || !actionButton) {
        return;
    }

    if (card.dataset.bound === 'true') {
        return;
    }
    card.dataset.bound = 'true';

    const loading = document.getElementById('aiInsightLoading');
    const errorBox = document.getElementById('aiInsightError');
    const emptyBox = document.getElementById('aiInsightEmpty');
    const warningBox = document.getElementById('aiInsightWarning');
    const khongTreNote = document.getElementById('aiKhongTreNote');
    const relatedWrap = document.getElementById('aiRelatedReasonsWrap');
    const relatedList = document.getElementById('aiRelatedReasons');

    const fieldMap = {
        aiTinhTrangTienDo: 'tinhTrangTienDo',
        aiNguyenNhan: 'nguyenNhanAiDuDoan',
        aiDoTinCay: 'doTinCayAi',
        aiThoiGianDuDoan: 'thoiGianDuDoanAi',
        aiNguyenNhanManager: 'nguyenNhanManagerXacNhan'
    };

    const setLoadingState = (isLoading) => {
        if (loading) {
            loading.classList.toggle('d-none', !isLoading);
        }
        actionButton.disabled = isLoading;
    };

    const showError = (message) => {
        if (!errorBox) {
            return;
        }

        errorBox.textContent = message && message.trim().length > 0
            ? message
            : 'Không kết nối được dịch vụ AI. Vui lòng thử lại.';
        errorBox.classList.remove('d-none');
    };

    const hideError = () => {
        if (errorBox) {
            errorBox.classList.add('d-none');
        }
    };

    const applyInsight = (insight) => {
        if (!insight) {
            return;
        }

        Object.entries(fieldMap).forEach(([elementId, key]) => {
            const target = document.getElementById(elementId);
            if (!target) {
                return;
            }

            const value = insight[key];
            target.textContent = value === null || value === undefined || value === '' ? '-' : value;
        });

        if (warningBox) {
            const canhBao = insight.canhBaoDuLieuAi;
            if (insight.ketQuaAiCoTheDaCu && canhBao) {
                warningBox.textContent = canhBao;
                warningBox.classList.remove('d-none');
            } else {
                warningBox.classList.add('d-none');
            }
        }

        if (emptyBox) {
            if (insight.coDuLieuAi) {
                emptyBox.classList.add('d-none');
            } else {
                emptyBox.textContent = insight.trangThaiDuLieuAi || 'Chưa có kết quả phân tích nguyên nhân trễ cho dự án này.';
                emptyBox.classList.remove('d-none');
            }
        }

        if (khongTreNote) {
            if (insight.thongBaoKhongTre && insight.thongBaoKhongTre.trim().length > 0) {
                khongTreNote.textContent = insight.thongBaoKhongTre;
            }
            khongTreNote.classList.toggle('d-none', !insight.hienThiThongBaoKhongTre);
        }

        if (actionButton && insight.nutPhanTichText) {
            actionButton.textContent = insight.nutPhanTichText;
        }

        if (relatedWrap && relatedList) {
            const relatedReasons = Array.isArray(insight.danhSachNguyenNhanLienQuan)
                ? insight.danhSachNguyenNhanLienQuan
                    .filter((item) => item && item.tenNguyenNhan)
                    .slice(0, 3)
                : [];

            relatedList.innerHTML = '';
            relatedReasons.forEach((item) => {
                const row = document.createElement('li');
                row.className = 'ai-related-item';

                const name = document.createElement('span');
                name.className = 'ai-related-name';
                name.textContent = item.tenNguyenNhan;

                const meta = document.createElement('span');
                meta.className = 'ai-related-meta';
                const mucPhuHop = item.mucPhuHop && item.mucPhuHop.trim().length > 0 ? item.mucPhuHop : 'Chưa có';
                meta.textContent = mucPhuHop;

                row.appendChild(name);
                row.appendChild(meta);
                relatedList.appendChild(row);
            });

            relatedWrap.classList.toggle('d-none', relatedReasons.length === 0);
        }

        card.dataset.coDuLieuAi = insight.coDuLieuAi ? 'true' : 'false';
        card.dataset.laDuAnTre = insight.duAnBiTreTheoAi === true ? 'true' : 'false';
        card.dataset.canPhanTichAi = insight.canPhanTichAi ? 'true' : 'false';
        card.dataset.tuDongPhanTichAi = insight.tuDongPhanTichAi ? 'true' : 'false';
    };

    const submitAnalyze = async () => {
        setLoadingState(true);
        hideError();

        try {
            const payload = new URLSearchParams(new FormData(submitForm));
            const response = await fetch(submitForm.action, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: payload
            });

            const data = await response.json();
            if (!response.ok || !data || data.thanhCong !== true) {
                showError(data?.thongBao || 'Không kết nối được dịch vụ AI. Vui lòng thử lại.');
                return;
            }

            applyInsight(data.duLieu);
        } catch (error) {
            showError('Không kết nối được dịch vụ AI. Vui lòng thử lại.');
        } finally {
            setLoadingState(false);
        }
    };

    actionButton.addEventListener('click', submitAnalyze);

    const canAutoAnalyze = card.dataset.tuDongPhanTichAi === 'true' && card.dataset.canPhanTichAi === 'true';
    if (canAutoAnalyze) {
        submitAnalyze();
    }
})();
</script>
