@model QuanLyDuAn.ViewModels.DanhGiaDuAn.DanhGiaDuAnFormViewModel
@{
    var tuKhoa = Context.Request.Query["tuKhoa"].ToString();
    var trangThai = Context.Request.Query["trangThai"].ToString();
    var tuNgayDanhGia = Context.Request.Query["tuNgayDanhGia"].ToString();
    var denNgayDanhGia = Context.Request.Query["denNgayDanhGia"].ToString();
    var returnUrl = Context.Request.Query["returnUrl"].ToString();
    var formBackUrl = Url.IsLocalUrl(returnUrl)
        ? returnUrl
        : Url.Action("Index", "DanhGiaDuAn", new
        {
            maDuAn = Model.MaDuAn,
            tuKhoa,
            trangThai,
            tuNgayDanhGia,
            denNgayDanhGia
        });
    var duAnDangTre = Model.ThongKe?.DuAnBiTreTheoAi == true;
    var daCoDanhGia = Model.MaDanhGiaDuAn.HasValue && Model.TieuChi.Any(x => x.MaChiTietDGDA.HasValue);
}

<div class="dgda-form card mb-3">
    <div class="card-body">
        <div class="evaluation-form-toolbar mb-2">
            <a href="@formBackUrl" class="btn-action dgda-back-btn">← Trở lại</a>
        </div>
        <h6 class="mb-3">Form đánh giá dự án: @Model.TenDuAn</h6>

        <details class="support-collapse mb-3" open>
            <summary>Dữ liệu hỗ trợ</summary>
            <div class="mt-2">
                @await Html.PartialAsync("_ProjectStats", Model.ThongKe)
                @if (duAnDangTre)
                {
                    @await Html.PartialAsync("_AiInsightCard", Model.ThongKe)
                }
            </div>
        </details>

        <div class="row g-2 mb-3">
            <div class="col-md-4"><div class="mini-stat"><span>Trạng thái dự án</span><strong>@Model.TrangThaiDuAn</strong></div></div>
            <div class="col-md-4">
                <div class="mini-stat">
                    <span>Điểm tổng kết</span>
                    @if (daCoDanhGia)
                    {
                        <div class="score-badge"><strong>@Model.DiemTongKet.ToString("0.0")</strong><small>@Model.XepLoai</small></div>
                    }
                    else
                    {
                        <strong>Chưa đánh giá</strong>
                    }
                </div>
            </div>
            <div class="col-md-4">
                <div class="mini-stat">
                    <span>Xếp loại</span>
                    <strong>@(daCoDanhGia ? Model.XepLoai : "Chưa đánh giá")</strong>
                </div>
            </div>
        </div>

        <form asp-action="Luu" method="post" class="vstack gap-2">
            <input type="hidden" asp-for="MaDanhGiaDuAn" />
            <input type="hidden" asp-for="MaDuAn" />
            <input type="hidden" name="tuKhoa" value="@tuKhoa" />
            <input type="hidden" name="trangThai" value="@trangThai" />
            <input type="hidden" name="tuNgayDanhGia" value="@tuNgayDanhGia" />
            <input type="hidden" name="denNgayDanhGia" value="@denNgayDanhGia" />
            <input type="hidden" name="returnUrl" value="@returnUrl" />

            @for (var i = 0; i < Model.TieuChi.Count; i++)
            {
                <div class="criteria-row">
                    <input type="hidden" asp-for="TieuChi[i].MaChiTietDGDA" />
                    <input type="hidden" asp-for="TieuChi[i].MaTieuChi" />
                    <input type="hidden" asp-for="TieuChi[i].TenTieuChi" />
                    <div class="criteria-title">@Model.TieuChi[i].TenTieuChi</div>
                    <div class="row g-2">
                        <div class="col-md-2">
                            <label class="form-label">Điểm (1-10)</label>
                            <input asp-for="TieuChi[i].DiemDanhGiaDA" class="form-control" min="1" max="10" />
                        </div>
                        <div class="col-md-10">
                            <label class="form-label">Nhận xét</label>
                            <input asp-for="TieuChi[i].NhanXetDuAn" class="form-control" maxlength="500" />
                        </div>
                    </div>
                </div>
            }

            <div>
                <label class="form-label">Nhận xét tổng dự án</label>
                <textarea asp-for="NhanXetTongDuAn" class="form-control" rows="3" maxlength="500"></textarea>
            </div>

            <div class="d-flex flex-wrap gap-2">
                @if (Model.CoTheLuu)
                {
                    <button type="submit" class="btn-action btn-confirm">Lưu đánh giá</button>
                }
                @if (Model.CoTheGuiDuyet && Model.MaDanhGiaDuAn.HasValue)
                {
                    <button type="submit"
                            class="btn-action btn-subtle"
                            formaction="@Url.Action("GuiDuyet", "DanhGiaDuAn")"
                            formmethod="post"
                            name="maDanhGiaDuAn"
                            value="@Model.MaDanhGiaDuAn">
                        Gửi duyệt
                    </button>
                }
            </div>
        </form>
    </div>
</div>
