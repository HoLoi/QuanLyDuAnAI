@model QuanLyDuAn.ViewModels.DanhGiaDuAn.DanhGiaDuAnChiTietViewModel

@{
    ViewData["Title"] = "Chi tiết đánh giá dự án";
    var returnUrl = Context.Request.Query["returnUrl"].ToString();
    var backUrl = Url.IsLocalUrl(returnUrl) ? returnUrl : Url.Action("Index", "DanhGiaDuAn");
    var duAnDangTre = Model.ThongKe?.DuAnBiTreTheoAi == true;
}

@section Styles
{
    <link rel="stylesheet" href="~/css/DanhGiaDuAn/index.css" asp-append-version="true" />
}

<div class="danh-gia-du-an-page">
    <div class="danh-gia-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Chi tiết đánh giá dự án</h5>
            <a href="@backUrl" class="btn-action btn-subtle">Trở lại</a>
        </div>

        <div class="row g-2 mb-3">
            <div class="col-md-4"><div class="mini-stat"><span>Dự án</span><strong>@Model.TenDuAn</strong></div></div>
            <div class="col-md-4"><div class="mini-stat"><span>Trạng thái</span><strong>@await Html.PartialAsync("_TrangThaiDanhGiaBadge", Model.TrangThaiDanhGia)</strong></div></div>
            <div class="col-md-4"><div class="mini-stat"><span>Điểm tổng</span><strong>@Model.DiemTongKet.ToString("0.0") - @Model.XepLoai</strong></div></div>
        </div>

        @await Html.PartialAsync("_ProjectStats", Model.ThongKe)
        @if (duAnDangTre)
        {
            @await Html.PartialAsync("_AiInsightCard", Model.ThongKe)
        }
        else
        {
            <div class="empty-note mb-3">Dự án không trễ nên không cần xác nhận nguyên nhân trễ.</div>
        }

        <div class="table-responsive dgda-table-wrap">
            <table class="table workflow-table dgda-table">
                <thead><tr><th>Tiêu chí</th><th>Điểm</th><th>Nhận xét</th></tr></thead>
                <tbody>
                @foreach (var tc in Model.TieuChi)
                {
                    <tr><td>@tc.TenTieuChi</td><td>@tc.DiemDanhGiaDA</td><td>@tc.NhanXetDuAn</td></tr>
                }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <label class="form-label">Nhận xét tổng</label>
            <div class="p-2 border rounded">@(string.IsNullOrWhiteSpace(Model.NhanXetTongDuAn) ? "-" : Model.NhanXetTongDuAn)</div>
        </div>
    </div>
</div>
