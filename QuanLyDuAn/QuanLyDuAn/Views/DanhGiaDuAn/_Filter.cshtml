@model QuanLyDuAn.ViewModels.DanhGiaDuAn.DanhGiaDuAnPageViewModel

<form asp-action="Index" method="get" class="dgda-filter" id="dgda-filter">
    <div class="dgda-filter-grid dgda-filter-grid-main">
        <div class="dgda-filter-field dgda-filter-field-wide">
            <label class="form-label">Từ khóa</label>
            <input type="text" name="tuKhoa" value="@Model.TuKhoa" class="form-control" placeholder="Tên dự án, nhận xét..." />
        </div>
        <div class="dgda-filter-field">
            <label class="form-label">Dự án</label>
            <select name="maDuAn" class="form-select">
                <option value="">Tất cả</option>
                @foreach (var duAn in Model.DanhSachDuAn)
                {
                    <option value="@duAn.MaDuAn" selected="@(Model.MaDuAn == duAn.MaDuAn)">@duAn.TenDuAn</option>
                }
            </select>
        </div>
        <div class="dgda-filter-field">
            <label class="form-label">Trạng thái đánh giá</label>
            <select name="trangThai" class="form-select">
                <option value="">Tất cả</option>
                <option value="ChuaDanhGia" selected="@(string.Equals(Model.TrangThai, "ChuaDanhGia", StringComparison.OrdinalIgnoreCase))">Chưa đánh giá</option>
                <option value="Nhap" selected="@(string.Equals(Model.TrangThai, "Nhap", StringComparison.OrdinalIgnoreCase))">Nháp</option>
                <option value="ChoDuyet" selected="@(string.Equals(Model.TrangThai, "ChoDuyet", StringComparison.OrdinalIgnoreCase))">Chờ duyệt</option>
                <option value="DaDuyet" selected="@(string.Equals(Model.TrangThai, "DaDuyet", StringComparison.OrdinalIgnoreCase))">Đã duyệt</option>
                <option value="TuChoi" selected="@(string.Equals(Model.TrangThai, "TuChoi", StringComparison.OrdinalIgnoreCase))">Từ chối</option>
            </select>
        </div>
    </div>

    <div class="dgda-filter-grid dgda-filter-grid-time">
        <div class="dgda-filter-field dgda-filter-field-date">
            <label class="form-label">Từ ngày đánh giá</label>
            <input type="date" name="tuNgayDanhGia" value="@Model.TuNgayDanhGia?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="dgda-filter-field dgda-filter-field-date">
            <label class="form-label">Đến ngày đánh giá</label>
            <input type="date" name="denNgayDanhGia" value="@Model.DenNgayDanhGia?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="dgda-filter-actions">
            <button type="submit" class="btn-filter-apply">Lọc dữ liệu</button>
            <a asp-action="Index" class="btn-filter-reset">Làm mới</a>
        </div>
    </div>
</form>
