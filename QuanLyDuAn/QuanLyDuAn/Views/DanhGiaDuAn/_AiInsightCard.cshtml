@model QuanLyDuAn.ViewModels.DanhGiaDuAn.DanhGiaDuAnThongKeViewModel

@{
    var coDuLieuAi = Model.CoDuLieuAi == true;
    var goiYAi = coDuLieuAi && !string.IsNullOrWhiteSpace(Model.TenNguyenNhanAiDuDoan)
        ? Model.TenNguyenNhanAiDuDoan
        : "Chưa có kết quả";
    var mucPhuHop = !string.IsNullOrWhiteSpace(Model.MucPhuHopAi)
        ? Model.MucPhuHopAi
        : (Model.DoTinCayAi.HasValue ? Model.DoTinCayAi.Value.ToString("P0") : "Chưa có");
    var nguon = Model.NguonNguyenNhanAi == "NguyenNhanModel" ? "Mô hình" : "Quy tắc";
    var daXacNhan = !string.IsNullOrWhiteSpace(Model.TenNguyenNhanManagerXacNhan);
}

<div class="ai-insight-card card border-0 shadow-sm mb-3" id="aiInsightCard">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between gap-2 mb-2 align-items-center">
            <h6 class="mb-0">Gợi ý AI</h6>
            <span class="badge badge-reference">Tham khảo</span>
        </div>

        @if (Model.KetQuaAiCoTheDaCu && !string.IsNullOrWhiteSpace(Model.CanhBaoDuLieuAi))
        {
            <div class="alert alert-warning py-2 mb-2">@Model.CanhBaoDuLieuAi</div>
        }

        <div class="row g-2">
            <div class="col-lg-4 col-md-6"><div class="stat-box"><span>Gợi ý AI</span><strong>@goiYAi</strong></div></div>
            <div class="col-lg-4 col-md-6"><div class="stat-box"><span>Mức phù hợp</span><strong>@mucPhuHop</strong></div></div>
            <div class="col-lg-4 col-md-6"><div class="stat-box"><span>Nguồn</span><strong>@(coDuLieuAi ? nguon : "Chưa có")</strong></div></div>
            <div class="col-lg-4 col-md-6"><div class="stat-box"><span>Thời gian phân tích</span><strong>@(Model.ThoiGianDuDoanAi?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa có")</strong></div></div>
            <div class="col-lg-4 col-md-6"><div class="stat-box"><span>Nguyên nhân xác nhận</span><strong>@(daXacNhan ? Model.TenNguyenNhanManagerXacNhan : "Chưa xác nhận")</strong></div></div>
            <div class="col-lg-4 col-md-6"><div class="stat-box"><span>Thời gian xác nhận</span><strong>@(Model.ThoiGianManagerXacNhan?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa xác nhận")</strong></div></div>
        </div>
    </div>
</div>
