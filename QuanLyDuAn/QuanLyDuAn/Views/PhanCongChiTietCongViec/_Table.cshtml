@model QuanLyDuAn.ViewModels.PhanCongChiTietCongViec.PhanCongChiTietCongViecPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    bool canDelete = permissions.Contains(Permissions.PhanCongChiTietCongViec.ThucHien) && Model.CoTheQuanLyCongViec;
    var maChiTietCv = Model.ChiTietCongViec.MaChiTietCV;
}

@if (!Model.DanhSachPhanCong.Any())
{
    <div class="pct-empty-state">
        <i class="bi bi-people"></i>
        <h3>Chưa có nhân sự được phân công.</h3>
        <p>Danh sách phân công sẽ hiển thị tại đây khi bạn giao người thực hiện cho chi tiết công việc này.</p>
    </div>
}
else
{
    <div class="pct-table-scroll">
        <table class="table pct-table">
            <thead>
                <tr>
                    <th class="col-id">Mã NV</th>
                    <th>Nhân viên</th>
                    <th class="col-date">Ngày giao việc</th>
                    <th class="col-actions">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DanhSachPhanCong)
                {
                    <tr>
                        <td class="col-id">@item.MaNguoiDung</td>
                        <td>@item.TenNhanVien</td>
                        <td class="col-date">@item.NgayGiaoChiTietCongViec?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="col-actions">
                            @if (canDelete)
                            {
                                <form asp-action="XoaPhanCong" method="post">
                                    <input type="hidden" name="maChiTietCv" value="@maChiTietCv" />
                                    <input type="hidden" name="maNguoiDung" value="@item.MaNguoiDung" />
                                    <button type="submit" class="pct-btn pct-btn-danger-soft">Xóa phân công</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="pct-subsection">
    <h3 class="pct-subsection-title">Nhân sự có thể phân công</h3>
    <p class="pct-subsection-note">Chỉ gồm người thuộc dự án và đã được phân công ở công việc cha.</p>
</div>

@if (!Model.ThanhVienCoThePhanCong.Any())
{
    <div class="pct-inline-note">
        Không còn nhân viên phù hợp để phân công.
    </div>
}
else
{
    <div class="pct-table-scroll">
        <table class="table pct-table pct-table-subtle">
            <thead>
                <tr>
                    <th class="col-id">Mã NV</th>
                    <th>Nhân viên</th>
                    <th>Vai trò trong dự án</th>
                    <th class="col-actions">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var nv in Model.ThanhVienCoThePhanCong)
                {
                    <tr>
                        <td class="col-id">@nv.MaNguoiDung</td>
                        <td>@nv.HoTenNguoiDung</td>
                        <td>@nv.VaiTroTrongDuAn</td>
                        <td class="col-actions">
                            <button type="button" class="pct-btn pct-btn-neutral-soft" disabled>Chọn ở form</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
