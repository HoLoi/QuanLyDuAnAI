@model QuanLyDuAn.ViewModels.PhanCongChiTietCongViec.PhanCongChiTietCongViecPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    bool coQuyenThucHien = permissions.Contains(Permissions.PhanCongChiTietCongViec.ThucHien);
    bool coTheQuanLy = Model.CoTheQuanLyCongViec;
    bool coNhanSuHopLe = Model.ThanhVienCoThePhanCong.Any();
    bool canShowForm = coQuyenThucHien && coTheQuanLy && coNhanSuHopLe;
}

@if (canShowForm)
{
    <form asp-action="ThemPhanCong" method="post" class="pct-assignment-form">
        <input type="hidden" asp-for="Form.MaChiTietCV" />

        <div class="assignment-form-grid">
            <div class="assignment-form-input">
                <div class="pct-form-field">
                    <label asp-for="Form.MaNguoiDung" class="form-label">Nhân viên</label>
                    <select class="form-select" asp-for="Form.MaNguoiDung" required>
                        <option value="">-- Chọn nhân viên thuộc dự án --</option>
                        @foreach (var nv in Model.ThanhVienCoThePhanCong)
                        {
                            <option value="@nv.MaNguoiDung">@nv.HoTenNguoiDung - @nv.VaiTroTrongDuAn</option>
                        }
                    </select>
                    <span asp-validation-for="Form.MaNguoiDung" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="assignment-form-actions">
            <button type="submit" class="pct-btn pct-btn-primary">
                <i class="bi bi-person-plus"></i>
                Phân công
            </button>
            <a asp-action="Index" asp-route-maChiTietCv="@Model.ChiTietCongViec.MaChiTietCV" class="pct-btn pct-btn-secondary">
                <i class="bi bi-arrow-clockwise"></i>
                Làm mới
            </a>
        </div>
    </form>
}
else if (!coQuyenThucHien || !coTheQuanLy)
{
    <div class="pct-inline-note">
        Bạn không có quyền phân công mục này.
    </div>
}
else if (!coNhanSuHopLe)
{
    <div class="pct-inline-note">
        Không còn nhân viên phù hợp để phân công.
    </div>
}
