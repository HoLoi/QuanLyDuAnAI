@model QuanLyDuAn.ViewModels.PhanCongCongViec.PhanCongCongViecPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    bool canDelete = permissions.Contains(Permissions.PhanCongCongViec.ThucHien) && Model.CoTheQuanLyCongViec;
    var maCongViec = Model.CongViec.MaCongViec;
}

@if (!Model.DanhSachPhanCong.Any())
{
    <div class="pc-empty-state">
        <i class="bi bi-people"></i>
        <h3>Chưa có nhân sự được phân công.</h3>
        <p>Danh sách phân công sẽ hiển thị tại đây ngay sau khi bạn giao việc cho nhân sự phù hợp.</p>
    </div>
}
else
{
    <div class="pc-table-scroll">
        <table class="table pc-table">
            <thead>
                <tr>
                    <th class="col-id">Mã NV</th>
                    <th>Nhân viên</th>
                    <th class="col-date">Ngày giao việc</th>
                    <th class="col-actions">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DanhSachPhanCong)
                {
                    <tr>
                        <td class="col-id">@item.MaNguoiDung</td>
                        <td>@item.TenNhanVien</td>
                        <td class="col-date">@item.NgayGiaoViec?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="col-actions">
                            @if (canDelete)
                            {
                                <form asp-action="XoaPhanCong" method="post">
                                    <input type="hidden" name="maCongViec" value="@maCongViec" />
                                    <input type="hidden" name="maNguoiDung" value="@item.MaNguoiDung" />
                                    <button type="submit" class="pc-btn pc-btn-danger-soft">Xóa phân công</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="pc-subsection">
    <h3 class="pc-subsection-title">Nhân sự có thể phân công</h3>
    <p class="pc-subsection-note">Chỉ hiển thị nhân sự thuộc dự án, chưa bị phân công vào công việc hiện tại và còn hiệu lực tài khoản.</p>
</div>

@if (!Model.ThanhVienCoThePhanCong.Any())
{
    <div class="pc-inline-note">
        Không còn nhân viên phù hợp để phân công.
    </div>
}
else
{
    <div class="pc-table-scroll">
        <table class="table pc-table pc-table-subtle">
            <thead>
                <tr>
                    <th class="col-id">Mã NV</th>
                    <th>Nhân viên</th>
                    <th>Vai trò trong dự án</th>
                    <th class="col-actions">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var nv in Model.ThanhVienCoThePhanCong)
                {
                    <tr>
                        <td class="col-id">@nv.MaNguoiDung</td>
                        <td>@nv.HoTenNguoiDung</td>
                        <td>@nv.VaiTroTrongDuAn</td>
                        <td class="col-actions">
                            <button type="button" class="pc-btn pc-btn-neutral-soft" disabled>Chọn ở form</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
