@model QuanLyDuAn.ViewModels.PhanCongCongViec.PhanCongCongViecPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = Model.Permissions;
    var soDaPhanCong = Model.DanhSachPhanCong.Count;
    var soConCoThePhanCong = Model.ThanhVienCoThePhanCong.Count;
    var tongNhanSuScope = soDaPhanCong + soConCoThePhanCong;

    ViewBag.Permissions = permissions;
    ViewData["Title"] = "Phân công công việc";
}

@section Styles {
    <link rel="stylesheet" href="~/css/PhanCongCongViec/index.css" asp-append-version="true" />
}

<div class="phan-cong-cong-viec-page">
    <section class="pc-header-card">
        <div class="pc-header-content">
            <h1 class="pc-title">Phân công công việc</h1>
            <p class="pc-subtitle">Quản lý nhân sự thực hiện công việc trong phạm vi dự án</p>
        </div>
        <a asp-controller="CongViec" asp-action="Index" class="pc-back-btn">
            <i class="bi bi-arrow-left"></i>
            Quay lại công việc
        </a>
    </section>

    <section class="pc-summary-grid">
        <article class="pc-summary-card">
            <span class="pc-summary-icon"><i class="bi bi-briefcase"></i></span>
            <div class="pc-summary-content">
                <span class="pc-summary-label">Công việc</span>
                <strong class="pc-summary-value">@Model.CongViec.TenCongViec</strong>
                <p class="pc-summary-note">Mã công việc: #@Model.CongViec.MaCongViec</p>
            </div>
        </article>

        <article class="pc-summary-card">
            <span class="pc-summary-icon status"><i class="bi bi-check2-circle"></i></span>
            <div class="pc-summary-content">
                <span class="pc-summary-label">Trạng thái</span>
                <strong class="pc-summary-value">@Model.CongViec.TenTrangThai</strong>
                <p class="pc-summary-note">Theo dõi trạng thái hiện tại của công việc</p>
            </div>
        </article>

        <article class="pc-summary-card">
            <span class="pc-summary-icon progress"><i class="bi bi-activity"></i></span>
            <div class="pc-summary-content">
                <span class="pc-summary-label">Tiến độ</span>
                <strong class="pc-summary-value">@Model.CongViec.PhanTramTienDo%</strong>
                <p class="pc-summary-note">Tiến độ tổng hợp từ các chi tiết công việc</p>
            </div>
        </article>

        <article class="pc-summary-card">
            <span class="pc-summary-icon assigned"><i class="bi bi-people-fill"></i></span>
            <div class="pc-summary-content">
                <span class="pc-summary-label">Đã phân công</span>
                <strong class="pc-summary-value">@soDaPhanCong</strong>
                <p class="pc-summary-note">Nhân sự đang thực hiện công việc</p>
            </div>
        </article>

        <article class="pc-summary-card">
            <span class="pc-summary-icon available"><i class="bi bi-person-plus"></i></span>
            <div class="pc-summary-content">
                <span class="pc-summary-label">Còn có thể phân công</span>
                <strong class="pc-summary-value">@soConCoThePhanCong</strong>
                <p class="pc-summary-note">Trong tổng @tongNhanSuScope nhân sự thuộc phạm vi dự án</p>
            </div>
        </article>
    </section>

    <section class="pc-section-card">
        <div class="pc-section-head">
            <h2 class="pc-section-title">Phân công nhân sự</h2>
            <p class="pc-section-note">Chỉ nhân sự đủ điều kiện trong dự án mới có thể được chọn để phân công.</p>
        </div>
        <partial name="_Form" model="Model" />
    </section>

    <section class="pc-section-card">
        <div class="pc-section-head">
            <h2 class="pc-section-title">Danh sách phân công</h2>
            <p class="pc-section-note">Theo dõi nhân sự đã giao việc và thao tác điều chỉnh khi cần.</p>
        </div>
        <partial name="_Table" model="Model" />
    </section>
</div>
