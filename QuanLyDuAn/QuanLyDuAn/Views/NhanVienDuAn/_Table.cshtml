@model QuanLyDuAn.ViewModels.NhanVienDuAn.NhanVienDuAnPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    bool canEdit = permissions.Contains(Permissions.ThanhVienDuAn.Them);
    bool canDelete = permissions.Contains(Permissions.ThanhVienDuAn.Xoa);
}

<h6>Danh sách nhân viên đang phụ trách</h6>
<table class="table table-bordered mt-2">
    <thead>
        <tr>
            <th>Mã NV</th>
            <th>Họ tên</th>
            <th>Vai trò trong dự án</th>
            <th>Ngày tham gia</th>
            <th>Thuộc team phụ trách</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.DanhSachNhanVienPhuTrach.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center text-muted">Chưa có nhân viên phụ trách.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.DanhSachNhanVienPhuTrach)
            {
                <tr>
                    <td>@item.MaNguoiDung</td>
                    <td>@item.HoTenNguoiDung</td>
                    <td>
                        @if (canEdit)
                        {
                            <form asp-action="CapNhatVaiTro" method="post" class="d-flex gap-1">
                                <input type="hidden" name="maDuAn" value="@Model.MaDuAn" />
                                <input type="hidden" name="maNguoiDung" value="@item.MaNguoiDung" />
                                <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
                                <input type="hidden" name="locMaLoaiDuAn" value="@Model.LocMaLoaiDuAn" />
                                <input type="hidden" name="locTrangThaiDuAn" value="@Model.LocTrangThaiDuAn" />
                                <select name="vaiTroTrongDuAn" class="form-select form-select-sm">
                                    <option value="@TrangThai.VaiTroLeader"
                                            selected="@(TrangThai.EqualsValue(item.VaiTroTrongDuAn, TrangThai.VaiTroLeader) ? "selected" : null)">
                                        @TrangThai.VaiTroLeaderHienThi
                                    </option>
                                    <option value="@TrangThai.VaiTroMember"
                                            selected="@(TrangThai.EqualsValue(item.VaiTroTrongDuAn, TrangThai.VaiTroMember) ? "selected" : null)">
                                        @TrangThai.VaiTroMemberHienThi
                                    </option>
                                </select>
                                <button type="submit" class="btn btn-warning btn-sm" disabled="@(!Model.CoTheChinhSua)">Lưu</button>
                            </form>
                        }
                        else
                        {
                            @TrangThai.ToDisplayVaiTroTrongDuAn(item.VaiTroTrongDuAn)
                        }
                    </td>
                    <td>@item.NgayThamGiaDuAn?.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        @if (item.ThuocTeamPhuTrach)
                        {
                            <span class="text-success">Có (@item.TenTeamPhuTrach)</span>
                        }
                        else
                        {
                            <span class="text-muted">Không</span>
                        }
                    </td>
                    <td>
                        @if (canDelete)
                        {
                            <form asp-action="XoaNhanVien" method="post">
                                <input type="hidden" name="maDuAn" value="@Model.MaDuAn" />
                                <input type="hidden" name="maNguoiDung" value="@item.MaNguoiDung" />
                                <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
                                <input type="hidden" name="locMaLoaiDuAn" value="@Model.LocMaLoaiDuAn" />
                                <input type="hidden" name="locTrangThaiDuAn" value="@Model.LocTrangThaiDuAn" />
                                <button type="submit" class="btn btn-danger btn-sm" disabled="@(!Model.CoTheChinhSua)">Xóa</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
