@model QuanLyDuAn.ViewModels.NhanVienDuAn.NhanVienDuAnPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = Model.Permissions;
    bool canShowForm = permissions.Contains(Permissions.ThanhVienDuAn.Them) && Model.CoTheChinhSua;
    ViewBag.Permissions = permissions;
}

@section Styles {
    <link rel="stylesheet" href="~/css/ThanhVienDuAn/index.css" asp-append-version="true" />
}

<div class="thanh-vien-du-an-page">
    <section class="thanh-vien-header-card">
        <div>
            <h2 class="thanh-vien-title">Quản lý thành viên dự án</h2>
            <p class="thanh-vien-subtitle">Theo dõi danh sách nhân sự phụ trách và vai trò trong dự án.</p>
        </div>
        <a asp-controller="DuAn"
           asp-action="Index"
           asp-route-tuKhoa="@Model.TuKhoa"
           asp-route-locMaLoaiDuAn="@Model.LocMaLoaiDuAn"
           asp-route-locTrangThaiDuAn="@Model.LocTrangThaiDuAn"
           class="btn thanh-vien-back-btn">Quay lại dự án</a>
    </section>

    <section class="thanh-vien-section-card thanh-vien-project-card">
        <div class="thanh-vien-project-info">
            <span><strong>Dự án:</strong> @Model.TenDuAn (Mã: @Model.MaDuAn)</span>
            <span class="thanh-vien-status-badge">Trạng thái: @TrangThai.ToDisplay(Model.TrangThaiDuAn)</span>
        </div>
    </section>

    @if (!Model.CoTheChinhSua)
    {
        <section class="thanh-vien-warning-card">
            @Model.LyDoKhongTheChinhSua
        </section>
    }

    @if (canShowForm)
    {
        <section class="thanh-vien-section-card thanh-vien-form-card">
            <div class="thanh-vien-section-head">
                <h3 class="thanh-vien-section-title">Thêm thành viên phụ trách</h3>
                <p class="thanh-vien-section-note">Chọn nhân viên phù hợp để tham gia dự án.</p>
            </div>
            <partial name="_Form" model="Model" />
        </section>
    }

    <section class="thanh-vien-section-card thanh-vien-table-card">
        <div class="thanh-vien-section-head">
            <h3 class="thanh-vien-section-title">Danh sách thành viên phụ trách</h3>
            <p class="thanh-vien-section-note">Cập nhật vai trò và quản lý thành viên theo phân quyền hiện tại.</p>
        </div>
        <partial name="_Table" model="Model" />
        <partial name="_Pagination" model="Model.Pagination" />
    </section>
</div>
