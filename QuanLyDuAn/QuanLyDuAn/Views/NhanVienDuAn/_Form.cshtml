@model QuanLyDuAn.ViewModels.NhanVienDuAn.NhanVienDuAnPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    bool canShowForm = permissions.Contains(Permissions.ThanhVienDuAn.Them) && Model.CoTheChinhSua;
}

@if (canShowForm)
{
    <form asp-action="ThemNhanVien" method="post" class="thanh-vien-entry-form">
        <input type="hidden" asp-for="MaDuAn" />
        <input type="hidden" asp-for="TuKhoa" />
        <input type="hidden" asp-for="LocMaLoaiDuAn" />
        <input type="hidden" asp-for="LocTrangThaiDuAn" />

        <div class="thanh-vien-select-box">
            @if (Model.DanhSachNhanVienCoTheThem.Count == 0)
            {
                <div class="thanh-vien-muted-text">Không còn nhân viên hợp lệ để thêm.</div>
            }
            else
            {
                <div class="row g-2">
                    @foreach (var item in Model.DanhSachNhanVienCoTheThem)
                    {
                        <div class="col-lg-6 col-md-12">
                            <label class="form-check-label d-flex align-items-center gap-2 thanh-vien-check-item">
                                <input class="form-check-input" type="checkbox" name="SelectedMaNguoiDung" value="@item.MaNguoiDung" />
                                <span>
                                    @item.HoTenNguoiDung
                                    <span class="text-muted">(Nhóm: @item.TatCaTenTeamDangThamGia)</span>
                                </span>
                            </label>
                        </div>
                    }
                </div>
            }
        </div>

        <button type="submit" class="btn thanh-vien-btn-primary"
                disabled="@(!Model.CoTheChinhSua || Model.DanhSachNhanVienCoTheThem.Count == 0)">
            Thêm thành viên
        </button>
    </form>
}
