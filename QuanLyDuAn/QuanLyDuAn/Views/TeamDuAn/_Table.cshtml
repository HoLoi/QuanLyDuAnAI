@model QuanLyDuAn.ViewModels.TeamDuAn.TeamDuAnPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    bool canEdit = permissions.Contains(Permissions.TeamDuAn.Them);
    bool canDelete = permissions.Contains(Permissions.TeamDuAn.Xoa);
}

@if (Model.DanhSachTeamPhuTrach.Count == 0)
{
    <div class="team-empty-state">
        <div class="team-empty-icon"><i class="bi bi-diagram-3"></i></div>
        <div class="team-empty-title">Chưa có nhóm phụ trách</div>
        <p class="team-empty-text">Hãy chọn nhóm và lưu để bắt đầu phân công phụ trách dự án.</p>
    </div>
}
else
{
    <div class="team-table-scroll">
        <table class="table table-bordered app-data-table team-table">
            <thead>
                <tr>
                    <th>Tên nhóm</th>
                    <th>Ngày tham gia</th>
                    <th>Số thành viên phụ trách</th>
                    <th class="col-actions">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DanhSachTeamPhuTrach)
                {
                    <tr>
                        <td class="fw-semibold">@item.TenTeam</td>
                        <td>@item.NgayTeamThamGiaDuAn?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td><span class="team-count-badge">@item.SoThanhVienPhuTrach thành viên</span></td>
                        <td class="col-actions table-actions team-table-actions">
                            @if (canEdit)
                            {
                                <a asp-action="Index"
                                   asp-route-maDuAn="@Model.MaDuAn"
                                   asp-route-maTeamDangChon="@item.MaTeam"
                                   asp-route-tuKhoa="@Model.TuKhoa"
                                   asp-route-locMaLoaiDuAn="@Model.LocMaLoaiDuAn"
                                   asp-route-locTrangThaiDuAn="@Model.LocTrangThaiDuAn"
                                   class="btn btn-action btn-subtle team-action-btn team-action-warning">
                                    <i class="bi bi-people"></i>
                                    <span>Sửa thành viên</span>
                                </a>
                            }

                            @if (canDelete)
                            {
                                <button type="button"
                                        class="btn btn-action btn-danger-soft team-action-btn team-action-danger btn-mo-modal-xoa-team"
                                        data-ma-team="@item.MaTeam"
                                        data-ten-team="@item.TenTeam"
                                        data-so-nhan-vien="@item.SoThanhVienPhuTrach"
                                        disabled="@(Model.CoTheChinhSua ? null : "disabled")">
                                    <i class="bi bi-trash"></i>
                                    <span>Gỡ nhóm</span>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (canDelete)
{
    <div class="modal fade" id="xoaTeamModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Gỡ nhóm phụ trách khỏi dự án</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="XoaTeamKhoiDuAn" method="post">
                    <div class="modal-body">
                        <input type="hidden" name="maDuAn" value="@Model.MaDuAn" />
                        <input type="hidden" name="maTeam" id="xoaTeam_maTeam" value="" />
                        <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
                        <input type="hidden" name="locMaLoaiDuAn" value="@Model.LocMaLoaiDuAn" />
                        <input type="hidden" name="locTrangThaiDuAn" value="@Model.LocTrangThaiDuAn" />

                        <p class="mb-2">
                            Nhóm <strong id="xoaTeam_tenTeam"></strong> hiện có
                            <strong id="xoaTeam_soNhanVien"></strong> thành viên trong dự án.
                        </p>
                        <p class="mb-2">Bạn muốn:</p>

                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="luaChonXuLyNhanVien" id="giuNguyenNhanVien" value="1" checked>
                            <label class="form-check-label" for="giuNguyenNhanVien">
                                [1] Giữ nguyên thành viên phụ trách dự án thuộc nhóm này
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="luaChonXuLyNhanVien" id="goNhanVienThuocTeam" value="2">
                            <label class="form-check-label" for="goNhanVienThuocTeam">
                                [2] Gỡ luôn thành viên đang phụ trách dự án thuộc nhóm này (có kiểm tra phân công công việc)
                            </label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-danger">Xác nhận gỡ nhóm</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
