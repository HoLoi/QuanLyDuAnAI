@model QuanLyDuAn.ViewModels.TeamDuAn.TeamDuAnPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = Model.Permissions;
    bool canShowForm = permissions.Contains(Permissions.TeamDuAn.Them) && Model.CoTheChinhSua;
    ViewBag.Permissions = permissions;
}

@section Styles {
    <link rel="stylesheet" href="~/css/TeamDuAn/index.css" asp-append-version="true" />
}

<div class="team-du-an-page">
    <section class="team-header-card">
        <div>
            <h2 class="team-title">Quản lý nhóm phụ trách dự án</h2>
            <p class="team-subtitle">Theo dõi nhóm phụ trách và thành viên được giao trong dự án.</p>
        </div>
        <a asp-controller="DuAn"
           asp-action="Index"
           asp-route-tuKhoa="@Model.TuKhoa"
           asp-route-locMaLoaiDuAn="@Model.LocMaLoaiDuAn"
           asp-route-locTrangThaiDuAn="@Model.LocTrangThaiDuAn"
           class="btn team-back-btn">Quay lại dự án</a>
    </section>

    <section class="team-section-card team-project-card">
        <div class="team-project-info">
            <span><strong>Dự án:</strong> @Model.TenDuAn (Mã: @Model.MaDuAn)</span>
            <span class="team-status-badge">Trạng thái: @TrangThai.ToDisplay(Model.TrangThaiDuAn)</span>
        </div>
    </section>

    @if (!Model.CoTheChinhSua)
    {
        <section class="team-warning-card">
            @Model.LyDoKhongTheChinhSua
        </section>
    }

    @if (canShowForm)
    {
        <section class="team-section-card team-filter-card">
            <div class="team-section-head">
                <h3 class="team-section-title">Chọn nhóm phụ trách</h3>
                <p class="team-section-note">Tải danh sách thành viên của nhóm trước khi lưu.</p>
            </div>
            <partial name="_Filter" model="Model" />
            <partial name="_Form" model="Model" />
        </section>
    }

    <section class="team-section-card team-table-card">
        <div class="team-section-head">
            <h3 class="team-section-title">Danh sách nhóm đang phụ trách</h3>
            <p class="team-section-note">Quản lý các nhóm tham gia dự án và điều chỉnh thành viên.</p>
        </div>
        <partial name="_Table" model="Model" />
        <partial name="_Pagination" model="Model.Pagination" />
    </section>
</div>

@section Scripts {
    <script>
        (function () {
            const modalElement = document.getElementById('xoaTeamModal');
            if (!modalElement || typeof bootstrap === 'undefined') return;

            const modal = new bootstrap.Modal(modalElement);
            const inputMaTeam = document.getElementById('xoaTeam_maTeam');
            const textTenTeam = document.getElementById('xoaTeam_tenTeam');
            const textSoNhanVien = document.getElementById('xoaTeam_soNhanVien');
            const luaChonGiu = document.getElementById('giuNguyenNhanVien');
            const buttons = document.querySelectorAll('.btn-mo-modal-xoa-team');

            buttons.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    if (inputMaTeam) inputMaTeam.value = btn.getAttribute('data-ma-team') || '';
                    if (textTenTeam) textTenTeam.textContent = btn.getAttribute('data-ten-team') || '';
                    if (textSoNhanVien) textSoNhanVien.textContent = btn.getAttribute('data-so-nhan-vien') || '0';
                    if (luaChonGiu) luaChonGiu.checked = true;
                    modal.show();
                });
            });
        })();
    </script>
}
