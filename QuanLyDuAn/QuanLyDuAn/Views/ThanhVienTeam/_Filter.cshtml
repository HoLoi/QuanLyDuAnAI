@model QuanLyDuAn.ViewModels.ThanhVienTeam.ThanhVienTeamPageViewModel

@{
    var locVaiTroLanhDao = (Model.LocVaiTroLanhDao ?? string.Empty).ToLowerInvariant();
}

<form asp-action="Index" method="get" class="workflow-filter mb-3">
    <div class="workflow-filter-row workflow-filter-row-main">
        <div class="filter-field">
        <input type="text" name="tuKhoa" value="@Model.TuKhoa" class="form-control"
               placeholder="Tìm theo team, nhân sự, vai trò..." />
        </div>
        <div class="filter-field">
        <select name="locMaTeam" class="form-select">
            <option value="">-- Tất cả team --</option>
            @foreach (var team in Model.DanhSachTeam)
            {
                if (Model.LocMaTeam == team.MaTeam)
                {
                    <option value="@team.MaTeam" selected>@team.TenTeam</option>
                }
                else
                {
                    <option value="@team.MaTeam">@team.TenTeam</option>
                }
            }
        </select>
        </div>
        <div class="filter-field">
        <select name="locVaiTroLanhDao" class="form-select">
            <option value="">-- Tất cả vai trò --</option>
            <option value="truongnhom" selected="@(locVaiTroLanhDao == "truongnhom" ? "selected" : null)">Trưởng nhóm</option>
            <option value="thanhvien" selected="@(locVaiTroLanhDao == "thanhvien" ? "selected" : null)">Thành viên</option>
        </select>
    </div>
    </div>
    <div class="workflow-filter-row workflow-filter-row-time">
        <div class="filter-actions">
            <button type="submit" class="btn-filter-apply">Lọc</button>
            <a asp-action="Index" class="btn-filter-reset">Làm mới</a>
        </div>
    </div>
</form>
