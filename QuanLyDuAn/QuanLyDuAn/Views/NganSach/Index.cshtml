@model QuanLyDuAn.ViewModels.NganSach.NganSachPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = Model.Permissions;
    var canApprove = permissions.Contains(Permissions.DuyetNganSach.Xem);

    ViewBag.Permissions = permissions;
}

<div class="card p-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0">Ngân sách</h5>
        <div class="d-flex gap-2">
            @if (canApprove)
            {
                <a asp-controller="DuyetDeXuatNganSach"
                   asp-action="Index"
                   class="btn btn-outline-primary btn-sm">Duyệt đề xuất ngân sách</a>
            }
        </div>
    </div>

    <partial name="_Filter" model="Model" />
    <partial name="_Table" model="Model.DanhSach" />
</div>
