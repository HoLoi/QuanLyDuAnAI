@model List<QuanLyDuAn.ViewModels.NganSach.NganSachItemViewModel>
@using QuanLyDuAn.Constants

@{
    string GetStatusBadgeClass(string? status)
    {
        if (TrangThai.EqualsValue(status, TrangThai.DaDuyet))
            return "is-approved";
        if (TrangThai.EqualsValue(status, TrangThai.DaThayThe))
            return "is-replaced";
        if (TrangThai.EqualsValue(status, TrangThai.GiuNguyen))
            return "is-kept";

        return "is-neutral";
    }
}

<div class="ngan-sach-section-head">
    <h2 class="ngan-sach-section-title">Danh sách ngân sách</h2>
    <p class="ngan-sach-section-note">Hiển thị các phiên bản ngân sách theo dự án, trạng thái phê duyệt và hiệu lực sử dụng.</p>
</div>

@if (Model.Count == 0)
{
    <div class="ngan-sach-empty-state">
        <p class="ngan-sach-empty-title">Chưa có ngân sách.</p>
    </div>
}
else
{
    <div class="ngan-sach-table-scroll">
        <table class="table ngan-sach-table">
            <thead>
                <tr>
                    <th>Mã</th>
                    <th>Dự án</th>
                    <th>Ngân sách</th>
                    <th>Phiên bản</th>
                    <th>Trạng thái</th>
                    <th>Hiệu lực</th>
                    <th>Người duyệt</th>
                    <th>Ngày duyệt</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-nowrap">#@item.MaNganSach</td>
                        <td>
                            <div class="ngan-sach-cell-title">@item.TenDuAn</div>
                            <div class="ngan-sach-cell-sub">Mã dự án: @item.MaDuAn</div>
                        </td>
                        <td class="text-nowrap">@($"{item.SoTienNganSach ?? 0:N0} VNĐ")</td>
                        <td class="text-nowrap">v@(item.Version ?? 0)</td>
                        <td>
                            <span class="ngan-sach-status-badge @GetStatusBadgeClass(item.TrangThaiNganSach)">
                                @TrangThai.ToDisplay(item.TrangThaiNganSach)
                            </span>
                        </td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="ngan-sach-status-badge is-active">Đang hiệu lực</span>
                            }
                            else
                            {
                                <span class="ngan-sach-status-badge is-inactive">Không hiệu lực</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.NguoiDungDuyet))
                            {
                                @item.NguoiDungDuyet
                            }
                            else
                            {
                                <span class="ngan-sach-cell-sub">Chưa duyệt</span>
                            }
                        </td>
                        <td class="text-nowrap">
                            @(item.NgayDuyetNganSach?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa duyệt")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
