@model QuanLyDuAn.ViewModels.ChiTietCongViec.ChiTietCongViecPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = Model.Permissions;
    bool canEdit = permissions.Contains(Permissions.ChiTietCongViec.Sua) && Model.CoTheCapNhat;
    bool canDelete = permissions.Contains(Permissions.ChiTietCongViec.Xoa) && Model.CoTheCapNhat;
    var trangThaiOptions = new[]
    {
        TrangThai.ChuaBatDau,
        TrangThai.DangThucHien,
        TrangThai.BiCanCan,
        TrangThai.TamDung,
        TrangThai.HoanThanh
    };
}

<h6>Danh sách chi tiết công việc</h6>
<table class="table table-bordered table-sm app-data-table">
    <thead>
        <tr>
            <th class="col-id">Mã</th>
            <th>Tên CTCV</th>
            <th>Nội dung</th>
            <th class="col-date">Ngày bắt đầu CTCV</th>
            <th class="col-date">Ngày kết thúc CTCV</th>
            <th class="col-date">Ngày tạo</th>
            <th class="col-status">Trạng thái</th>
            <th class="col-action">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.DanhSach.Any())
        {
            <tr>
                <td colspan="8" class="text-center text-muted">Chưa có chi tiết công việc.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.DanhSach)
            {
                var collapseId = $"edit-{item.MaChiTietCV}";
                <tr>
                    <td class="col-id">@item.MaChiTietCV</td>
                    <td>@item.TenCTCV</td>
                    <td>@item.NoiDungChiTietCV</td>
                    <td class="col-date">@item.NgayBatDauCTCV?.ToString("dd/MM/yyyy")</td>
                    <td class="col-date">@item.NgayKetThucCTCV?.ToString("dd/MM/yyyy")</td>
                    <td class="col-date">@item.NgayTaoCTCV?.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="col-status">@TrangThai.ToDisplay(item.TrangThaiCTCV)</td>
                    <td class="col-action table-actions">
                        @if (canEdit)
                        {
                            <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                Sửa
                            </button>
                        }
                        @if (canDelete)
                        {
                            <form asp-action="Xoa" method="post">
                                <input type="hidden" name="maCongViec" value="@Model.CongViec.MaCongViec" />
                                <input type="hidden" name="maChiTietCv" value="@item.MaChiTietCV" />
                                <button type="submit" class="btn btn-outline-danger btn-sm">Xóa</button>
                            </form>
                        }
                    </td>
                </tr>
                @if (canEdit)
                {
                    <tr class="collapse" id="@collapseId">
                        <td colspan="8">
                            <form asp-action="Sua" method="post" class="row g-2">
                                <input type="hidden" name="MaChiTietCV" value="@item.MaChiTietCV" />
                                <input type="hidden" name="MaCongViec" value="@Model.CongViec.MaCongViec" />
                                <div class="col-md-3">
                                    <label class="form-label">Tên CTCV</label>
                                    <input type="text" class="form-control" name="TenCTCV" value="@item.TenCTCV" maxlength="255" />
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label">Nội dung</label>
                                    <input type="text" class="form-control" name="NoiDungChiTietCV" value="@item.NoiDungChiTietCV" maxlength="255" required />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Ngày bắt đầu CTCV</label>
                                    <input type="date" class="form-control" name="NgayBatDauCTCV" value="@item.NgayBatDauCTCV?.ToString("yyyy-MM-dd")" required />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Trạng thái</label>
                                    <select class="form-select" name="TrangThaiCTCV" required>
                                        @foreach (var status in trangThaiOptions)
                                        {
                                            <option value="@status" selected="@(TrangThai.EqualsValue(item.TrangThaiCTCV, status))">@TrangThai.ToDisplay(status)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary btn-sm">Lưu cập nhật</button>
                                </div>
                            </form>
                        </td>
                    </tr>
                }
            }
        }
    </tbody>
</table>
