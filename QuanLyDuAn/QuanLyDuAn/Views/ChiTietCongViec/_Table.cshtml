@model QuanLyDuAn.ViewModels.ChiTietCongViec.ChiTietCongViecPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = Model.Permissions;
    bool canEdit = permissions.Contains(Permissions.ChiTietCongViec.Sua) && Model.CoTheCapNhat;
    bool canDelete = permissions.Contains(Permissions.ChiTietCongViec.Xoa) && Model.CoTheCapNhat;

    string GetStatusIcon(string cssTrangThai)
    {
        return cssTrangThai switch
        {
            "workflow-success" => "bi-check2-circle",
            "workflow-pending" => "bi-hourglass-split",
            "workflow-blocked" => "bi-exclamation-octagon",
            "workflow-paused" => "bi-pause-circle",
            "workflow-cancelled" => "bi-x-octagon",
            "workflow-idle" => "bi-circle",
            _ => "bi-play-circle"
        };
    }

    string GetAssignmentText(int soNguoi)
    {
        return soNguoi <= 0
            ? "Chưa phân công"
            : $"Đã phân công · {soNguoi} người";
    }

    string GetAssignmentBadgeClass(int soNguoi)
    {
        return soNguoi > 0 ? "bg-success" : "bg-secondary";
    }
}

@if (!Model.DanhSach.Any())
{
    <div class="empty-state">
        <i class="bi bi-list-task"></i>
        <p>Chưa có chi tiết công việc.</p>
    </div>
}
else
{
    <div class="chi-tiet-table-wrapper d-none d-lg-block">
        <table class="table app-data-table chi-tiet-table">
            <thead>
                <tr>
                    <th>Tên CTCV</th>
                    <th>Nội dung</th>
                    <th class="col-date">Ngày bắt đầu</th>
                    <th class="col-date">Ngày hoàn thành thực tế</th>
                    <th class="col-date">Ngày tạo</th>
                    <th class="col-status">Trạng thái</th>
                    <th class="col-assignment">Phân công</th>
                    <th class="col-actions">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DanhSach)
                {
                    var collapseId = $"edit-{item.MaChiTietCV}";
                    <tr>
                        <td>@item.TenCTCV</td>
                        <td>@item.NoiDungChiTietCV</td>
                        <td class="col-date">@item.NgayBatDauCTCV?.ToString("dd/MM/yyyy")</td>
                        <td class="col-date">@item.NgayKetThucCTCV?.ToString("dd/MM/yyyy")</td>
                        <td class="col-date">@item.NgayTaoCTCV?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="col-status">
                            <span class="workflow-badge @item.CssTrangThai">
                                <i class="bi @GetStatusIcon(item.CssTrangThai)"></i>
                                @item.TrangThaiHienThi
                            </span>
                        </td>
                        <td class="col-assignment">
                            <span class="badge @GetAssignmentBadgeClass(item.SoNguoiDuocPhanCong)">
                                @GetAssignmentText(item.SoNguoiDuocPhanCong)
                            </span>
                        </td>
                        <td class="col-actions table-actions">
                            @if (permissions.Contains(Permissions.PhanCongChiTietCongViec.Xem) && item.CoThePhanCongChiTietCongViec)
                            {
                                <a asp-controller="PhanCongChiTietCongViec" asp-action="Index" asp-route-maChiTietCv="@item.MaChiTietCV" class="btn btn-action btn-subtle">
                                    <i class="bi bi-person-plus"></i>
                                    Phân công
                                </a>
                            }
                            @if (canEdit)
                            {
                                <button type="button" class="btn btn-action btn-subtle" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false">
                                    <i class="bi bi-pencil-square"></i>
                                    Sửa
                                </button>
                            }
                            @if (canDelete)
                            {
                                <form asp-action="Xoa" method="post">
                                    <input type="hidden" name="maCongViec" value="@Model.CongViec.MaCongViec" />
                                    <input type="hidden" name="maChiTietCv" value="@item.MaChiTietCV" />
                                    <button type="submit" class="btn btn-action btn-danger-soft">
                                        <i class="bi bi-trash3"></i>
                                        Xóa
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                    @if (canEdit)
                    {
                        <tr class="collapse-row">
                            <td colspan="8" class="p-0 border-0">
                                <div class="collapse" id="@collapseId">
                                    <form asp-action="Sua" method="post" class="edit-inline-form">
                                        <input type="hidden" name="MaChiTietCV" value="@item.MaChiTietCV" />
                                        <input type="hidden" name="MaCongViec" value="@Model.CongViec.MaCongViec" />

                                        <div class="form-field">
                                            <label>Tên CTCV</label>
                                            <input type="text" class="form-control" name="TenCTCV" value="@item.TenCTCV" maxlength="255" />
                                        </div>
                                        <div class="form-field form-field--wide">
                                            <label>Nội dung</label>
                                            <input type="text" class="form-control" name="NoiDungChiTietCV" value="@item.NoiDungChiTietCV" maxlength="255" required />
                                        </div>
                                        <div class="form-field">
                                            <label>Ngày bắt đầu</label>
                                            <input type="date" class="form-control" name="NgayBatDauCTCV" value="@item.NgayBatDauCTCV?.ToString("yyyy-MM-dd")" required />
                                        </div>
                                        <div class="form-field">
                                            <label>Trạng thái hiện tại</label>
                                            <div>
                                                <span class="workflow-badge @item.CssTrangThai">
                                                    <i class="bi @GetStatusIcon(item.CssTrangThai)"></i>
                                                    @item.TrangThaiHienThi
                                                </span>
                                            </div>
                                            <small class="text-muted">Trạng thái được cập nhật thông qua báo cáo tiến độ đã được duyệt.</small>
                                        </div>
                                        <div class="form-actions">
                                            <button type="submit" class="btn btn-form-primary btn-sm">
                                                <i class="bi bi-check2"></i>
                                                Lưu cập nhật
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="chi-tiet-mobile-list d-lg-none">
        @foreach (var item in Model.DanhSach)
        {
            var mobileEditId = $"edit-mobile-{item.MaChiTietCV}";
            <article class="chi-tiet-mobile-card">
                <div class="mobile-head">
                    <div>
                        <p class="mobile-id">CTCV #@item.MaChiTietCV</p>
                        <h3>@item.TenCTCV</h3>
                    </div>
                    <span class="workflow-badge @item.CssTrangThai">
                        <i class="bi @GetStatusIcon(item.CssTrangThai)"></i>
                        @item.TrangThaiHienThi
                    </span>
                </div>

                <p class="mobile-content">@item.NoiDungChiTietCV</p>

                <div class="mobile-meta">
                    <div><span>Bắt đầu</span><strong>@item.NgayBatDauCTCV?.ToString("dd/MM/yyyy")</strong></div>
                    <div><span>Hoàn thành thực tế</span><strong>@item.NgayKetThucCTCV?.ToString("dd/MM/yyyy")</strong></div>
                    <div><span>Ngày tạo</span><strong>@item.NgayTaoCTCV?.ToString("dd/MM/yyyy HH:mm")</strong></div>
                    <div><span>Phân công</span><strong>@GetAssignmentText(item.SoNguoiDuocPhanCong)</strong></div>
                </div>

                <div class="mobile-actions">
                    @if (permissions.Contains(Permissions.PhanCongChiTietCongViec.Xem) && item.CoThePhanCongChiTietCongViec)
                    {
                        <a asp-controller="PhanCongChiTietCongViec" asp-action="Index" asp-route-maChiTietCv="@item.MaChiTietCV" class="btn btn-action btn-subtle">
                            <i class="bi bi-person-plus"></i>
                            Phân công
                        </a>
                    }
                    @if (canEdit)
                    {
                        <button type="button" class="btn btn-action btn-subtle" data-bs-toggle="collapse" data-bs-target="#@mobileEditId" aria-expanded="false">
                            <i class="bi bi-pencil-square"></i>
                            Sửa
                        </button>
                    }
                    @if (canDelete)
                    {
                        <form asp-action="Xoa" method="post" class="w-100">
                            <input type="hidden" name="maCongViec" value="@Model.CongViec.MaCongViec" />
                            <input type="hidden" name="maChiTietCv" value="@item.MaChiTietCV" />
                            <button type="submit" class="btn btn-action btn-danger-soft w-100">
                                <i class="bi bi-trash3"></i>
                                Xóa
                            </button>
                        </form>
                    }
                </div>

                @if (canEdit)
                {
                    <div class="collapse" id="@mobileEditId">
                        <form asp-action="Sua" method="post" class="edit-inline-form edit-inline-form--mobile">
                            <input type="hidden" name="MaChiTietCV" value="@item.MaChiTietCV" />
                            <input type="hidden" name="MaCongViec" value="@Model.CongViec.MaCongViec" />

                            <div class="form-field">
                                <label>Tên CTCV</label>
                                <input type="text" class="form-control" name="TenCTCV" value="@item.TenCTCV" maxlength="255" />
                            </div>
                            <div class="form-field">
                                <label>Nội dung</label>
                                <input type="text" class="form-control" name="NoiDungChiTietCV" value="@item.NoiDungChiTietCV" maxlength="255" required />
                            </div>
                            <div class="form-field">
                                <label>Ngày bắt đầu</label>
                                <input type="date" class="form-control" name="NgayBatDauCTCV" value="@item.NgayBatDauCTCV?.ToString("yyyy-MM-dd")" required />
                            </div>
                            <div class="form-field">
                                <label>Trạng thái hiện tại</label>
                                <div>
                                    <span class="workflow-badge @item.CssTrangThai">
                                        <i class="bi @GetStatusIcon(item.CssTrangThai)"></i>
                                        @item.TrangThaiHienThi
                                    </span>
                                </div>
                                <small class="text-muted">Trạng thái được cập nhật thông qua báo cáo tiến độ đã được duyệt.</small>
                            </div>
                            <button type="submit" class="btn btn-form-primary btn-sm w-100">
                                <i class="bi bi-check2"></i>
                                Lưu cập nhật
                            </button>
                        </form>
                    </div>
                }
            </article>
        }
    </div>
}
