@model QuanLyDuAn.ViewModels.DuyetDeXuatCongViec.DuyetDeXuatCongViecPageViewModel
@using QuanLyDuAn.Constants

@{
    ViewData["Title"] = "Duyệt đề xuất công việc";
    var permissions = Model.Permissions;
    ViewBag.Permissions = permissions;
}

@section Styles {
    <link rel="stylesheet" href="~/css/shared/approval.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/DuyetDeXuatCongViec/index.css" asp-append-version="true" />
}

<section class="duyet-de-xuat-cong-viec-page app-page approval-page">
    <header class="duyet-de-xuat-cong-viec-header-card app-page-header approval-header-card">
        <div class="duyet-de-xuat-cong-viec-header-content">
            <h1 class="duyet-de-xuat-cong-viec-title app-page-title">Duyệt đề xuất công việc</h1>
            <p class="duyet-de-xuat-cong-viec-subtitle app-page-subtitle">Xem xét, duyệt hoặc từ chối các đề xuất công việc trong phạm vi dự án</p>
        </div>
    </header>

    <section class="duyet-de-xuat-cong-viec-section-card app-section-card approval-section-card">
        <partial name="_Filter" model="Model" />
    </section>

    <section class="duyet-de-xuat-cong-viec-section-card app-section-card approval-section-card">
        <partial name="_Table" model="Model" />
    </section>
</section>

@section Scripts {
    <script src="~/js/approval/index.js" asp-append-version="true"></script>
}
