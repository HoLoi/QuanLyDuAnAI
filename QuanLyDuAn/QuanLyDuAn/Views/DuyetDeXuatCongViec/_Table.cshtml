@model QuanLyDuAn.ViewModels.DuyetDeXuatCongViec.DuyetDeXuatCongViecPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    var canApprove = permissions.Contains(Permissions.DuyetDeXuatCongViec.Duyet);

    string GetStatusBadgeClass(string? status)
    {
        if (TrangThai.EqualsValue(status, TrangThai.ChoDuyet))
            return "is-pending";
        if (TrangThai.EqualsValue(status, TrangThai.DaDuyet))
            return "is-approved";
        if (TrangThai.EqualsValue(status, TrangThai.TuChoi))
            return "is-rejected";
        if (TrangThai.EqualsValue(status, TrangThai.DaHuy))
            return "is-cancelled";

        return "is-neutral";
    }
}

<div class="duyet-de-xuat-cong-viec-section-head approval-section-head">
    <h2 class="duyet-de-xuat-cong-viec-section-title approval-section-title">Danh sách đề xuất</h2>
    <p class="duyet-de-xuat-cong-viec-section-note approval-section-note">Bảng rút gọn theo thông tin chính, bấm xem chi tiết để mở thông tin đầy đủ.</p>
</div>

@if (Model.DanhSach.Count == 0)
{
    <div class="duyet-de-xuat-cong-viec-empty-state app-empty-state">
        <p class="duyet-de-xuat-cong-viec-empty-title">Chưa có đề xuất cần xử lý.</p>
    </div>
}
else
{
    <div class="duyet-de-xuat-cong-viec-table-scroll app-table-scroll approval-table-scroll">
        <table class="table duyet-de-xuat-cong-viec-table app-data-table approval-table">
            <thead>
                <tr>
                    <th>Dự án</th>
                    <th>Công việc đề xuất</th>
                    <th>Chi phí đề xuất</th>
                    <th>Ngày đề xuất</th>
                    <th>Trạng thái</th>
                    <th class="col-actions">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DanhSach)
                {
                    var isPending = TrangThai.EqualsValue(item.TrangThaiCongViecDeXuat, TrangThai.ChoDuyet);
                    var detailRowId = $"dxcv-detail-{item.MaDeXuatCV}";
                    <tr class="duyet-de-xuat-cong-viec-main-row">
                        <td>
                            <div class="duyet-de-xuat-cong-viec-cell-title">@item.TenDuAn</div>
                        </td>
                        <td>
                            <div class="duyet-de-xuat-cong-viec-cell-title">@item.TenCongViecDeXuat</div>
                        </td>
                        <td class="text-nowrap">
                            @if (item.ChiPhiDeXuat.HasValue)
                            {
                                @($"{item.ChiPhiDeXuat.Value:N0} VNĐ")
                            }
                            else
                            {
                                <span class="duyet-de-xuat-cong-viec-cell-sub">0 VNĐ</span>
                            }
                        </td>
                        <td class="text-nowrap">@item.NgayDeXuatCongViec?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="duyet-de-xuat-cong-viec-status-badge status-badge @GetStatusBadgeClass(item.TrangThaiCongViecDeXuat)">
                                @TrangThai.ToDisplay(item.TrangThaiCongViecDeXuat)
                            </span>
                        </td>
                        <td class="col-actions">
                            <div class="duyet-de-xuat-cong-viec-table-actions approval-table-actions table-actions">
                                @if (canApprove && isPending)
                                {
                                    <form asp-action="Duyet" method="post" class="js-confirm-submit" data-confirm="Xác nhận duyệt đề xuất này?">
                                        <input type="hidden" name="maDeXuatCv" value="@item.MaDeXuatCV" />
                                        <input type="hidden" name="locMaDuAn" value="@Model.LocMaDuAn" />
                                        <input type="hidden" name="locTrangThai" value="@Model.LocTrangThai" />
                                        <input type="hidden" name="locMaNguoiDungDeXuat" value="@Model.LocMaNguoiDungDeXuat" />
                                        <input type="hidden" name="tuNgay" value="@Model.TuNgay?.ToString("yyyy-MM-dd")" />
                                        <input type="hidden" name="denNgay" value="@Model.DenNgay?.ToString("yyyy-MM-dd")" />
                                        <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
                                        <input type="hidden" name="pageNumber" value="@Model.Pagination.PageNumber" />
                                        <input type="hidden" name="pageSize" value="@Model.Pagination.PageSize" />
                                        <button type="submit" class="duyet-de-xuat-cong-viec-action-btn duyet-de-xuat-cong-viec-action-approve btn-action btn-confirm approval-action-btn">Duyệt</button>
                                    </form>
                                    <form asp-action="TuChoi" method="post" class="js-confirm-submit" data-confirm="Bạn có chắc chắn muốn từ chối đề xuất công việc này không?">
                                        <input type="hidden" name="maDeXuatCv" value="@item.MaDeXuatCV" />
                                        <input type="hidden" name="locMaDuAn" value="@Model.LocMaDuAn" />
                                        <input type="hidden" name="locTrangThai" value="@Model.LocTrangThai" />
                                        <input type="hidden" name="locMaNguoiDungDeXuat" value="@Model.LocMaNguoiDungDeXuat" />
                                        <input type="hidden" name="tuNgay" value="@Model.TuNgay?.ToString("yyyy-MM-dd")" />
                                        <input type="hidden" name="denNgay" value="@Model.DenNgay?.ToString("yyyy-MM-dd")" />
                                        <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
                                        <input type="hidden" name="pageNumber" value="@Model.Pagination.PageNumber" />
                                        <input type="hidden" name="pageSize" value="@Model.Pagination.PageSize" />
                                        <button type="submit" class="duyet-de-xuat-cong-viec-action-btn duyet-de-xuat-cong-viec-action-reject btn-action btn-danger-soft approval-action-btn">Từ chối</button>
                                    </form>
                                }
                                <button type="button"
                                        class="duyet-de-xuat-cong-viec-action-btn duyet-de-xuat-cong-viec-action-detail btn-action btn-subtle approval-action-btn js-toggle-detail"
                                        data-target="@detailRowId"
                                        aria-expanded="false">
                                    Xem chi tiết
                                </button>
                            </div>
                        </td>
                    </tr>
                    <tr id="@detailRowId" class="duyet-de-xuat-cong-viec-detail-row d-none">
                        <td colspan="6">
                            <div class="duyet-de-xuat-cong-viec-detail-card approval-detail-card">
                                <div class="duyet-de-xuat-cong-viec-detail-grid approval-detail-grid">
                                    <div class="duyet-de-xuat-cong-viec-detail-item approval-detail-item">
                                        <span class="duyet-de-xuat-cong-viec-detail-label approval-detail-label">Người đề xuất</span>
                                        <span class="duyet-de-xuat-cong-viec-detail-value approval-detail-value">@item.NguoiDungDeXuat</span>
                                    </div>
                                    <div class="duyet-de-xuat-cong-viec-detail-item approval-detail-item">
                                        <span class="duyet-de-xuat-cong-viec-detail-label approval-detail-label">Thời gian dự kiến</span>
                                        <span class="duyet-de-xuat-cong-viec-detail-value approval-detail-value">
                                            @if (item.NgayBatDauCongViecDeXuat.HasValue || item.NgayKetThucCVDeXuatDuKien.HasValue)
                                            {
                                                @($"{item.NgayBatDauCongViecDeXuat:dd/MM/yyyy HH:mm} đến {item.NgayKetThucCVDeXuatDuKien:dd/MM/yyyy HH:mm}")
                                            }
                                            else
                                            {
                                                @:Chưa có dữ liệu
                                            }
                                        </span>
                                    </div>
                                    <div class="duyet-de-xuat-cong-viec-detail-item duyet-de-xuat-cong-viec-detail-item-wide approval-detail-item approval-detail-item-wide">
                                        <span class="duyet-de-xuat-cong-viec-detail-label approval-detail-label">Mô tả công việc</span>
                                        <span class="duyet-de-xuat-cong-viec-detail-value approval-detail-value">
                                            @if (!string.IsNullOrWhiteSpace(item.MoTaCongViecDeXuat))
                                            {
                                                @item.MoTaCongViecDeXuat
                                            }
                                            else
                                            {
                                                @:Chưa có mô tả
                                            }
                                        </span>
                                    </div>
                                    <div class="duyet-de-xuat-cong-viec-detail-item approval-detail-item">
                                        <span class="duyet-de-xuat-cong-viec-detail-label approval-detail-label">Danh mục công việc</span>
                                        <span class="duyet-de-xuat-cong-viec-detail-value approval-detail-value">
                                            @if (!string.IsNullOrWhiteSpace(item.TenDanhMucCongViec))
                                            {
                                                @item.TenDanhMucCongViec
                                            }
                                            else
                                            {
                                                @:Chưa có thông tin
                                            }
                                        </span>
                                    </div>
                                    <div class="duyet-de-xuat-cong-viec-detail-item approval-detail-item">
                                        <span class="duyet-de-xuat-cong-viec-detail-label approval-detail-label">Mức độ ưu tiên</span>
                                        <span class="duyet-de-xuat-cong-viec-detail-value approval-detail-value">
                                            @if (!string.IsNullOrWhiteSpace(item.TenMucDoUuTien))
                                            {
                                                @item.TenMucDoUuTien
                                            }
                                            else
                                            {
                                                @:Chưa có thông tin
                                            }
                                        </span>
                                    </div>
                                    <div class="duyet-de-xuat-cong-viec-detail-item approval-detail-item">
                                        <span class="duyet-de-xuat-cong-viec-detail-label approval-detail-label">Người duyệt</span>
                                        <span class="duyet-de-xuat-cong-viec-detail-value approval-detail-value">
                                            @if (!string.IsNullOrWhiteSpace(item.NguoiDungDuyet))
                                            {
                                                @item.NguoiDungDuyet
                                            }
                                            else
                                            {
                                                @:Chưa duyệt
                                            }
                                        </span>
                                    </div>
                                    <div class="duyet-de-xuat-cong-viec-detail-item approval-detail-item">
                                        <span class="duyet-de-xuat-cong-viec-detail-label approval-detail-label">Ngày duyệt</span>
                                        <span class="duyet-de-xuat-cong-viec-detail-value approval-detail-value">
                                            @(item.NgayDuyetDeXuatCongViec?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa duyệt")
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
