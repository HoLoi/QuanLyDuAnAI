@model QuanLyDuAn.ViewModels.DuyetDeXuatCongViec.DuyetDeXuatCongViecPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    
    var canApprove = permissions.Contains(Permissions.DuyetDeXuatCongViec.Duyet);
}

<table class="table table-bordered table-sm">
    <thead>
        <tr>
            <th>Mã</th>
            <th>Dự án</th>
            <th>Người đề xuất</th>
            <th>Công việc</th>
            <th>Mô tả</th>
            <th>Chi phí</th>
            <th>Ngày đề xuất</th>
            <th>Trạng thái</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.DanhSach.Count == 0)
        {
            <tr>
                <td colspan="9" class="text-center text-muted">Không có đề xuất công việc.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.DanhSach)
            {
                <tr>
                    <td>@item.MaDeXuatCV</td>
                    <td>@item.TenDuAn</td>
                    <td>@item.NguoiDungDeXuat</td>
                    <td>@item.TenCongViecDeXuat</td>
                    <td>@item.MoTaCongViecDeXuat</td>
                    <td>@item.ChiPhiDeXuat?.ToString("N0")</td>
                    <td>@item.NgayDeXuatCongViec?.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@TrangThai.ToDisplay(item.TrangThaiCongViecDeXuat)</td>
                    <td>
                        @if (canApprove && TrangThai.EqualsValue(item.TrangThaiCongViecDeXuat, TrangThai.ChoDuyet))
                        {
                            <div class="d-flex gap-1">
                                <form asp-action="Duyet" method="post">
                                    <input type="hidden" name="maDeXuatCv" value="@item.MaDeXuatCV" />
                                    <input type="hidden" name="locMaDuAn" value="@Model.LocMaDuAn" />
                                    <input type="hidden" name="locTrangThai" value="@Model.LocTrangThai" />
                                    <button type="submit" class="btn btn-sm btn-success">Duyệt</button>
                                </form>
                                <form asp-action="TuChoi" method="post" class="d-flex gap-1">
                                    <input type="hidden" name="maDeXuatCv" value="@item.MaDeXuatCV" />
                                    <input type="hidden" name="locMaDuAn" value="@Model.LocMaDuAn" />
                                    <input type="hidden" name="locTrangThai" value="@Model.LocTrangThai" />
                                    <input type="text" name="lyDo" class="form-control form-control-sm" placeholder="Lý do" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Từ chối</button>
                                </form>
                            </div>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
