@model QuanLyDuAn.ViewModels.DuyetDeXuatCongViec.DuyetDeXuatCongViecPageViewModel
@using QuanLyDuAn.Constants

<div class="duyet-de-xuat-cong-viec-section-head approval-section-head">
    <h2 class="duyet-de-xuat-cong-viec-section-title approval-section-title">Bộ lọc danh sách</h2>
    <p class="duyet-de-xuat-cong-viec-section-note approval-section-note">Lọc theo dự án, người đề xuất, trạng thái, ngày gửi và từ khóa để xử lý nhanh các đề xuất cần duyệt.</p>
</div>

<form asp-action="Index" method="get" class="duyet-de-xuat-cong-viec-filter-form app-filter">
    <div class="app-filter-field">
        <label for="locMaDuAn" class="form-label">Dự án</label>
        <select id="locMaDuAn" name="locMaDuAn" class="form-select">
            <option value="">Tất cả dự án</option>
            @foreach (var duAn in Model.DanhSachDuAn)
            {
                <option value="@duAn.Value" selected="@(Model.LocMaDuAn == duAn.Value)">@duAn.Text</option>
            }
        </select>
    </div>
    <div class="app-filter-field">
        <label for="locMaNguoiDungDeXuat" class="form-label">Người đề xuất</label>
        <select id="locMaNguoiDungDeXuat" name="locMaNguoiDungDeXuat" class="form-select">
            <option value="">Tất cả người đề xuất</option>
            @foreach (var nguoiDeXuat in Model.DanhSachNguoiDeXuat)
            {
                <option value="@nguoiDeXuat.Value" selected="@(Model.LocMaNguoiDungDeXuat == nguoiDeXuat.Value)">@nguoiDeXuat.Text</option>
            }
        </select>
    </div>
    <div class="app-filter-field">
        <label for="locTrangThai" class="form-label">Trạng thái đề xuất</label>
        <select id="locTrangThai" name="locTrangThai" class="form-select">
            <option value="">Tất cả trạng thái</option>
            <option value="@TrangThai.ChoDuyet" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.ChoDuyet))">@TrangThai.ChoDuyetHienThi</option>
            <option value="@TrangThai.DaDuyet" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.DaDuyet))">@TrangThai.DaDuyetHienThi</option>
            <option value="@TrangThai.TuChoi" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.TuChoi))">@TrangThai.TuChoiHienThi</option>
            <option value="@TrangThai.DaHuy" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.DaHuy))">@TrangThai.DaHuyHienThi</option>
        </select>
    </div>
    <div class="app-filter-field">
        <label for="tuNgay" class="form-label">Từ ngày</label>
        <input id="tuNgay" type="date" name="tuNgay" value="@Model.TuNgay?.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="app-filter-field">
        <label for="denNgay" class="form-label">Đến ngày</label>
        <input id="denNgay" type="date" name="denNgay" value="@Model.DenNgay?.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="app-filter-field">
        <label for="tuKhoa" class="form-label">Từ khóa</label>
        <input id="tuKhoa" type="search" name="tuKhoa" value="@Model.TuKhoa" class="form-control" placeholder="Tìm theo công việc, mô tả, dự án, người đề xuất..." />
    </div>
    <div class="duyet-de-xuat-cong-viec-filter-actions">
        <button class="duyet-de-xuat-cong-viec-filter-btn-primary btn-action btn-filter-apply approval-action-btn" type="submit">Lọc</button>
        <a asp-action="Index" class="duyet-de-xuat-cong-viec-filter-btn-secondary btn-action btn-filter-reset approval-action-btn">Làm mới</a>
    </div>
</form>
