@model QuanLyDuAn.ViewModels.DeXuatNganSach.DeXuatNganSachPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = Model.Permissions;
    bool canShowForm = permissions.Contains(Permissions.DeXuatNganSach.Them);

    ViewBag.Permissions = permissions;
    ViewBag.LocMaDuAn = Model.LocMaDuAn;
    ViewBag.LocTrangThai = Model.LocTrangThai;
}

<div class="card p-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
            <h5 class="mb-0">Đề xuất ngân sách</h5>
            <div class="text-muted">@Model.TenDuAn</div>
        </div>
        <a asp-controller="DuAn" asp-action="Index" class="btn btn-outline-secondary btn-sm">Quay lại dự án</a>
    </div>

    <div asp-validation-summary="All" class="text-danger mb-2"></div>

    <div class="border rounded p-3 mb-3">
        <div class="row g-2">
            <div class="col-md-4">
                <div class="small text-muted">Ngân sách dự án</div>
                <div class="fw-semibold">
                    @(Model.NganSachDuAn.HasValue ? $"{Model.NganSachDuAn.Value:N0} VNĐ" : "Chưa có ngân sách được duyệt")
                </div>
            </div>
            <div class="col-md-4">
                <div class="small text-muted">Tổng chi phí đã dùng</div>
                <div class="fw-semibold">@Model.TongChiPhiDaDung.ToString("N0") VNĐ</div>
            </div>
            <div class="col-md-4">
                <div class="small text-muted">Số công việc dự án</div>
                <div class="fw-semibold">@Model.TongCongViecDuAn</div>
            </div>
        </div>

        @if (Model.TongCongViecDuAn <= 0)
        {
            <div class="mt-3">
                <a asp-controller="DeXuatCongViec"
                   asp-action="Index"
                   asp-route-locMaDuAn="@Model.MaDuAn"
                   class="btn btn-warning btn-sm">Đi đến đề xuất công việc</a>
            </div>
        }
    </div>

    @if (canShowForm)
    {
        <partial name="_Form" model="Model" />
        <hr />
    }

    <partial name="_Filter" model="Model" />
    <partial name="_Table" model="Model.DanhSach" />
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
