@model QuanLyDuAn.ViewModels.DeXuatNganSach.DeXuatNganSachPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = Model.Permissions;
    var canCreate = permissions.Contains(Permissions.DeXuatNganSach.Them);

    ViewBag.Permissions = permissions;
    ViewBag.LocMaDuAn = Model.LocMaDuAn;
    ViewBag.LocTrangThai = Model.LocTrangThai;
}

<div class="card p-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
            <h5 class="mb-0">Đề xuất ngân sách</h5>
            <div class="text-muted">@Model.TenDuAn</div>
        </div>
        <a asp-controller="DuAn" asp-action="Index" class="btn btn-outline-secondary btn-sm">Quay lại dự án</a>
    </div>

    <div asp-validation-summary="All" class="text-danger mb-2"></div>

    @if (canCreate)
    {
        <partial name="_Form" model="Model" />
        <hr />
    }

    <partial name="_Filter" model="Model" />
    <partial name="_Table" model="Model.DanhSach" />
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
