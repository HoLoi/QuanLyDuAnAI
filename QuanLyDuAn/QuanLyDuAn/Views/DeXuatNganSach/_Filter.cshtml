@model QuanLyDuAn.ViewModels.DeXuatNganSach.DeXuatNganSachPageViewModel
@using QuanLyDuAn.Constants

<form asp-action="Index" method="get" class="dxns-filter-form app-filter">
    <div class="dxns-filter-grid dxns-filter-grid-main app-filter-main">
        <div class="dxns-filter-field app-filter-field">
            <label class="form-label" for="locMaDuAn">Dự án</label>
            <select id="locMaDuAn" name="locMaDuAn" class="form-select">
                @foreach (var duAn in Model.DanhSachDuAn)
                {
                    if (Model.LocMaDuAn == duAn.MaDuAn)
                    {
                        <option value="@duAn.MaDuAn" selected>@duAn.TenDuAn</option>
                    }
                    else
                    {
                        <option value="@duAn.MaDuAn">@duAn.TenDuAn</option>
                    }
                }
            </select>
        </div>
        <div class="dxns-filter-field app-filter-field">
            <label class="form-label" for="locTrangThai">Trạng thái đề xuất</label>
            <select id="locTrangThai" name="locTrangThai" class="form-select">
                <option value="">-- Tất cả trạng thái --</option>
                <option value="@TrangThai.ChoDuyet" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.ChoDuyet))">@TrangThai.ChoDuyetHienThi</option>
                <option value="@TrangThai.DaDuyet" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.DaDuyet))">@TrangThai.DaDuyetHienThi</option>
                <option value="@TrangThai.TuChoi" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.TuChoi))">@TrangThai.TuChoiHienThi</option>
                <option value="@TrangThai.DaHuy" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.DaHuy))">@TrangThai.DaHuyHienThi</option>
            </select>
        </div>
    </div>

    <div class="dxns-filter-grid dxns-filter-grid-time app-filter-time">
        <div class="dxns-filter-field app-filter-field">
            <label class="form-label" for="locTheoNgay">Lọc theo ngày</label>
            <select id="locTheoNgay" name="locTheoNgay" class="form-select">
                <option value="NgayDeXuat" selected="@((Model.LocTheoNgay ?? "NgayDeXuat") == "NgayDeXuat")">Ngày đề xuất</option>
                <option value="NgayDuyet" selected="@(Model.LocTheoNgay == "NgayDuyet")">Ngày duyệt</option>
            </select>
        </div>

        <div class="dxns-filter-field dxns-filter-field-date app-filter-field">
            <label class="form-label" for="tuNgay">Từ ngày</label>
            <input id="tuNgay" type="date" name="tuNgay" value="@Model.TuNgay?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>

        <div class="dxns-filter-field dxns-filter-field-date app-filter-field">
            <label class="form-label" for="denNgay">Đến ngày</label>
            <input id="denNgay" type="date" name="denNgay" value="@Model.DenNgay?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>

        <div class="dxns-filter-actions">
            <button class="dxns-action-btn dxns-action-primary btn-action btn-filter-apply proposal-action-btn" type="submit">
                <i class="bi bi-funnel"></i>
                Lọc dữ liệu
            </button>
            <a asp-action="Index" asp-route-locMaDuAn="@Model.LocMaDuAn" class="dxns-action-btn dxns-action-neutral btn-action btn-filter-reset proposal-action-btn">
                <i class="bi bi-x-circle"></i>
                Làm mới
            </a>
        </div>
    </div>
</form>
