@model List<QuanLyDuAn.ViewModels.DeXuatNganSach.DeXuatNganSachItemViewModel>
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    bool canCancel = permissions.Contains(Permissions.DeXuatNganSach.Them);
    int? locMaDuAn = ViewBag.LocMaDuAn as int?;
    string? locTrangThai = ViewBag.LocTrangThai as string;
}

<div class="dxns-table-scroll">
    <table class="table dxns-table">
        <thead>
            <tr>
                <th class="col-id">Mã</th>
                <th>Ngân sách cũ</th>
                <th>Ngân sách đề xuất</th>
                <th>Người đề xuất</th>
                <th>Ngày đề xuất</th>
                <th>Trạng thái</th>
                <th class="col-actions">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="7">
                        <div class="dxns-empty-state">Chưa có đề xuất ngân sách.</div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    var statusCode = TrangThai.ToCode(item.TrangThaiDeXuat);
                    var badgeClass = "dxns-status-neutral";
                    if (TrangThai.EqualsValue(statusCode, TrangThai.ChoDuyet)) { badgeClass = "dxns-status-pending"; }
                    else if (TrangThai.EqualsValue(statusCode, TrangThai.DaDuyet)) { badgeClass = "dxns-status-approved"; }
                    else if (TrangThai.EqualsValue(statusCode, TrangThai.TuChoi)) { badgeClass = "dxns-status-rejected"; }
                    else if (TrangThai.EqualsValue(statusCode, TrangThai.DaHuy)) { badgeClass = "dxns-status-canceled"; }

                    <tr>
                        <td class="col-id">#@item.MaDeXuatNS</td>
                        <td class="text-nowrap">@(item.NganSachCu?.ToString("N0") ?? "-") VNĐ</td>
                        <td class="text-nowrap">@item.NganSachDeXuat?.ToString("N0") VNĐ</td>
                        <td>@item.NguoiDungDeXuat</td>
                        <td class="text-nowrap">@item.NgayDeXuat?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="dxns-status-badge @badgeClass">@TrangThai.ToDisplay(item.TrangThaiDeXuat)</span>
                        </td>
                        <td class="col-actions">
                            <div class="dxns-action-group">
                                <button type="button" class="dxns-action-btn dxns-action-neutral" data-bs-toggle="collapse" data-bs-target="#dxns-detail-@item.MaDeXuatNS" aria-expanded="false" aria-controls="dxns-detail-@item.MaDeXuatNS">
                                    <i class="bi bi-eye"></i>
                                    Xem chi tiết
                                </button>
                                @if (canCancel && TrangThai.EqualsValue(item.TrangThaiDeXuat, TrangThai.ChoDuyet))
                                {
                                    <form asp-action="HuyDeXuat" method="post" class="d-inline">
                                        <input type="hidden" name="maDeXuatNs" value="@item.MaDeXuatNS" />
                                        <input type="hidden" name="locMaDuAn" value="@locMaDuAn" />
                                        <input type="hidden" name="locTrangThai" value="@locTrangThai" />
                                        <button type="submit" class="dxns-action-btn dxns-action-danger">
                                            <i class="bi bi-x-circle"></i>
                                            Hủy đề xuất
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                    <tr class="collapse" id="dxns-detail-@item.MaDeXuatNS">
                        <td colspan="7" class="dxns-detail-cell">
                            <div class="dxns-detail-grid">
                                <div>
                                    <span>Lý do đề xuất</span>
                                    <p>@item.LyDoDeXuat</p>
                                </div>
                                <div>
                                    <span>Người duyệt</span>
                                    <p>@(string.IsNullOrWhiteSpace(item.NguoiDungDuyet) ? "Chưa duyệt" : item.NguoiDungDuyet)</p>
                                </div>
                                <div>
                                    <span>Ngày duyệt</span>
                                    <p>@(item.NgayDuyet?.ToString("dd/MM/yyyy HH:mm") ?? "-")</p>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
