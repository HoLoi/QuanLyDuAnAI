@model QuanLyDuAn.ViewModels.Team.TeamPageViewModel
@using QuanLyDuAn.Constants

@{
    var locTrangThai = Model.LocTrangThaiTeam;
}

<form asp-action="Index" method="get" class="workflow-filter mb-3">
    <div class="workflow-filter-row workflow-filter-row-main">
        <div class="filter-field">
        <input type="text" name="tuKhoa" value="@Model.TuKhoa" class="form-control"
               placeholder="Tìm theo tên team, mô tả..." />
        </div>
        <div class="filter-field">
        <select name="locTrangThaiTeam" class="form-select">
            <option value="">-- Tất cả trạng thái --</option>
            <option value="@TrangThai.HoatDong" selected="@(TrangThai.EqualsValue(locTrangThai, TrangThai.HoatDong) ? "selected" : null)">@TrangThai.HoatDongHienThi</option>
            <option value="@TrangThai.NgungHoatDong" selected="@(TrangThai.EqualsValue(locTrangThai, TrangThai.NgungHoatDong) ? "selected" : null)">@TrangThai.NgungHoatDongHienThi</option>
        </select>
        </div>
    </div>
    <div class="workflow-filter-row workflow-filter-row-time">
        <div class="filter-actions">
            <button type="submit" class="btn-filter-apply">Lọc</button>
            <a asp-action="Index" class="btn-filter-reset">Làm mới</a>
        </div>
    </div>
</form>
