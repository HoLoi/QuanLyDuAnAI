@model List<QuanLyDuAn.ViewModels.Team.TeamViewModel>
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    bool CanAccess(params string[] keys) => keys.Any(x => permissions.Contains(x));
    string? tuKhoa = ViewBag.TuKhoa as string;
    string? locTrangThaiTeam = ViewBag.LocTrangThaiTeam as string;
}

<table class="table table-bordered mt-3 app-data-table">
    <thead>
        <tr>
            <th class="col-id">Mã</th>
            <th>Tên team</th>
            <th>Mô tả</th>
            <th class="col-date">Ngày lập</th>
            <th class="col-status">Trạng thái</th>
            <th class="col-count">Số thành viên</th>
            <th class="col-actions"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var team in Model)
        {
            <tr>
                <td class="col-id">@team.MaTeam</td>
                <td>@team.TenTeam</td>
                <td>@team.MoTaTeam</td>
                <td class="col-date">@team.NgayLapTeam?.ToString("dd/MM/yyyy")</td>
                <td class="col-status">@TrangThai.ToDisplay(team.TrangThaiTeam)</td>
                <td class="col-count">@team.SoLuongThanhVien</td>
                <td class="col-actions table-actions">
                    <a asp-controller="ThanhVienTeam"
                       asp-action="Index"
                       asp-route-locMaTeam="@team.MaTeam"
                       class="btn btn-outline-info btn-sm">Thành viên</a>

                    @if (team.SoLuongThanhVien > 0 && !team.CoTruongNhom && CanAccess(Permissions.ThanhVienNhom.Them))
                    {
                        <a asp-controller="ThanhVienTeam"
                           asp-action="Index"
                           asp-route-locMaTeam="@team.MaTeam"
                           asp-route-cheDoGanTruongNhom="true"
                           class="btn btn-outline-primary btn-sm">Gán trưởng nhóm</a>
                    }

                    @if (CanAccess(Permissions.Nhom.Sua))
                    {
                        <a asp-action="Sua"
                           asp-route-id="@team.MaTeam"
                           asp-route-tuKhoa="@tuKhoa"
                           asp-route-locTrangThaiTeam="@locTrangThaiTeam"
                              class="btn btn-outline-warning btn-sm">Sửa</a>
                    }

                    @if (CanAccess(Permissions.Nhom.Xoa))
                    {
                        <form asp-action="XoaTeam" method="post">
                            <input type="hidden" name="maTeam" value="@team.MaTeam" />
                            <input type="hidden" name="tuKhoa" value="@tuKhoa" />
                            <input type="hidden" name="locTrangThaiTeam" value="@locTrangThaiTeam" />
                            <button type="submit" class="btn btn-outline-danger btn-sm">Xóa</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
