@model QuanLyDuAn.ViewModels.Team.TeamPageViewModel
@using QuanLyDuAn.Constants
@{
    ViewData["Title"] = "Team";
    var permissions = Model.Permissions;
    bool canShowForm = permissions.Contains(Permissions.Nhom.Them) || permissions.Contains(Permissions.Nhom.Sua);
    ViewBag.Permissions = permissions;
    ViewBag.TuKhoa = Model.TuKhoa;
    ViewBag.LocTrangThaiTeam = Model.LocTrangThaiTeam;
}

@section Styles {
    <link rel="stylesheet" href="~/css/Team/index.css" asp-append-version="true" />
}

<section class="team-page">
    <header class="team-header-card">
        <h1 class="team-title">Team</h1>
        <p class="team-subtitle">Quản lý nhóm làm việc, trạng thái hoạt động và phân công thành viên.</p>
    </header>

    <section class="team-section-card">
        <div asp-validation-summary="All" class="text-danger mb-2"></div>

        @if (canShowForm)
        {
            <partial name="_Form" for="Form" />
            <hr />
        }

        <partial name="_Filter" model="Model" />
        <partial name="_Table" model="Model.DanhSach" />
        <partial name="_Pagination" model="Model.Pagination" />
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
