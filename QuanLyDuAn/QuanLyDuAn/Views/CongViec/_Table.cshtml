@model List<QuanLyDuAn.ViewModels.CongViec.CongViecItemViewModel>
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    int? locMaDuAn = ViewBag.LocMaDuAn as int?;
    string? locTrangThai = ViewBag.LocTrangThai as string;
    string? tuKhoa = ViewBag.TuKhoa as string;
    DateTime? tuNgay = ViewBag.TuNgay as DateTime?;
    DateTime? denNgay = ViewBag.DenNgay as DateTime?;
    string? locTheoNgay = ViewBag.LocTheoNgay as string;
    string? locTinhTrangThoiHan = ViewBag.LocTinhTrangThoiHan as string;

    bool canWorkflowMutate = permissions.Contains(Permissions.TienDo.Duyet)
                             || permissions.Contains(Permissions.DuyetDeXuatCongViec.Duyet);

    string GetStatusIcon(string cssTrangThai)
    {
        return cssTrangThai switch
        {
            "workflow-success" => "bi-check2-circle",
            "workflow-pending" => "bi-hourglass-split",
            "workflow-blocked" => "bi-exclamation-octagon",
            "workflow-paused" => "bi-pause-circle",
            "workflow-cancelled" => "bi-x-octagon",
            "workflow-idle" => "bi-circle",
            _ => "bi-play-circle"
        };
    }

    string GetAssignmentText(int soNguoi)
    {
        return soNguoi <= 0
            ? "Chưa phân công"
            : $"Đã phân công · {soNguoi} người";
    }

    string GetAssignmentBadgeClass(int soNguoi)
    {
        return soNguoi > 0 ? "bg-success" : "bg-secondary";
    }

    string GetDetailCountText(int soLuong)
    {
        return soLuong <= 0
            ? "Chưa có chi tiết"
            : $"{soLuong} chi tiết";
    }

    string GetDetailCountBadgeClass(int soLuong)
    {
        return soLuong > 0 ? "bg-info text-dark" : "bg-light text-muted border";
    }
}

@if (Model.Count == 0)
{
    <div class="empty-state">
        <i class="bi bi-inboxes"></i>
        <p>Chưa có công việc phù hợp bộ lọc hiện tại.</p>
    </div>
}
else
{
    <div class="workflow-table-wrapper table-responsive-soft d-none d-lg-block">
        <table class="table app-data-table workflow-table">
            <thead>
                <tr>
                    <th class="col-project">Dự án</th>
                    <th class="col-task">Công việc</th>
                    <th class="col-meta">Mức độ / Chi phí</th>
                    <th class="col-time">Mốc thời gian</th>
                    <th class="col-status">Trạng thái</th>
                    <th class="col-assignment">Phân công</th>
                    <th class="col-detail-count">Chi tiết công việc</th>
                    <th class="col-actions">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="col-project">
                            <div class="fw-semibold">@item.TenDuAn</div>
                            <small class="text-muted task-meta-compact">@item.TenDanhMucCV</small>
                        </td>
                        <td class="col-task">
                            <div class="fw-semibold">@item.TenCongViec</div>
                            <small class="text-muted task-desc-compact">@item.MoTaCongViec</small>
                        </td>
                        <td class="col-meta">
                            <div class="meta-line">
                                <span class="meta-label">Mức độ:</span>
                                <span>@item.TenMucDo</span>
                            </div>
                            <div class="meta-line">
                                <span class="meta-label">Chi phí:</span>
                                <span>@item.ChiPhiDaChi.ToString("N0")</span>
                            </div>
                        </td>
                        <td class="col-time">
                            <div class="meta-line">
                                <span class="meta-label">Bắt đầu:</span>
                                <span>@item.NgayBatDauCongViec?.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="meta-line">
                                <span class="meta-label">Hạn:</span>
                                <span class="@(item.IsQuaHan || item.IsHoanThanhTre ? "deadline-date-late" : string.Empty)">@item.NgayKetThucCVDuKien?.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            @if (item.NgayKetThucCVThucTe.HasValue)
                            {
                                <div class="meta-line">
                                    <span class="meta-label">Hoàn tất:</span>
                                    <span>@item.NgayKetThucCVThucTe?.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                            }
                        </td>
                        <td class="col-status">
                            <div class="status-stack">
                                <span class="workflow-badge @item.CssTrangThai">
                                    <i class="bi @GetStatusIcon(item.CssTrangThai)"></i>
                                    @item.TrangThaiHienThi
                                </span>
                                <span class="deadline-badge @item.CssTinhTrangThoiHan">
                                    @item.TinhTrangThoiHan
                                </span>
                            </div>
                        </td>
                        <td class="col-assignment">
                            <span class="badge @GetAssignmentBadgeClass(item.SoNguoiDuocPhanCong)">
                                @GetAssignmentText(item.SoNguoiDuocPhanCong)
                            </span>
                        </td>
                        <td class="col-detail-count">
                            <span class="badge @GetDetailCountBadgeClass(item.SoLuongChiTietCongViec)">
                                @GetDetailCountText(item.SoLuongChiTietCongViec)
                            </span>
                        </td>
                        <td class="col-actions table-actions task-actions-cell">
                            @if (permissions.Contains(Permissions.PhanCongCongViec.Xem) && item.CoThePhanCongCongViec)
                            {
                                <a asp-controller="PhanCongCongViec" asp-action="Index" asp-route-maCongViec="@item.MaCongViec" class="btn btn-action btn-subtle">
                                    <i class="bi bi-person-plus"></i>
                                    Phân công
                                </a>
                            }
                            @if (permissions.Contains(Permissions.ChiTietCongViec.Xem))
                            {
                                <a asp-controller="ChiTietCongViec" asp-action="Index" asp-route-maCongViec="@item.MaCongViec" class="btn btn-action btn-subtle">
                                    <i class="bi bi-layout-text-sidebar-reverse"></i>
                                    Chi tiết
                                </a>
                            }
                            @if (item.CoTheXacNhanHoanThanh && canWorkflowMutate)
                            {
                                <form asp-action="XacNhanHoanThanh" method="post">
                                    <input type="hidden" name="maCongViec" value="@item.MaCongViec" />
                                    <input type="hidden" name="locMaDuAn" value="@locMaDuAn" />
                                    <input type="hidden" name="locTrangThai" value="@locTrangThai" />
                                    <input type="hidden" name="tuKhoa" value="@tuKhoa" />
                                    <input type="hidden" name="tuNgay" value="@tuNgay?.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="denNgay" value="@denNgay?.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="locTheoNgay" value="@locTheoNgay" />
                                    <input type="hidden" name="locTinhTrangThoiHan" value="@locTinhTrangThoiHan" />
                                    <button type="submit" class="btn btn-action btn-confirm">
                                        <i class="bi bi-check2-circle"></i>
                                        Xác nhận hoàn thành
                                    </button>
                                </form>
                            }
                            @if (item.CoTheMoLai && canWorkflowMutate)
                            {
                                <form asp-action="MoLai" method="post" class="reopen-form">
                                    <input type="hidden" name="maCongViec" value="@item.MaCongViec" />
                                    <input type="hidden" name="locMaDuAn" value="@locMaDuAn" />
                                    <input type="hidden" name="locTrangThai" value="@locTrangThai" />
                                    <input type="hidden" name="tuKhoa" value="@tuKhoa" />
                                    <input type="hidden" name="tuNgay" value="@tuNgay?.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="denNgay" value="@denNgay?.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="locTheoNgay" value="@locTheoNgay" />
                                    <input type="hidden" name="locTinhTrangThoiHan" value="@locTinhTrangThoiHan" />
                                    <input type="text" name="lyDo" class="form-control form-control-sm" placeholder="Lý do mở lại" required />
                                    <button type="submit" class="btn btn-action btn-reopen">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                        Mở lại
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="task-mobile-list d-lg-none">
        @foreach (var item in Model)
        {
            <article class="task-mobile-card">
                <div class="task-mobile-head">
                    <div>
                        <p class="task-mobile-id">Công việc #@item.MaCongViec</p>
                        <h3>@item.TenCongViec</h3>
                    </div>
                    <div class="task-mobile-status-stack">
                        <span class="workflow-badge @item.CssTrangThai">
                            <i class="bi @GetStatusIcon(item.CssTrangThai)"></i>
                            @item.TrangThaiHienThi
                        </span>
                        <span class="deadline-badge @item.CssTinhTrangThoiHan">
                            @item.TinhTrangThoiHan
                        </span>
                    </div>
                </div>

                <p class="task-mobile-desc">@item.MoTaCongViec</p>

                <div class="task-mobile-meta">
                    <div><span>Dự án</span><strong>@item.TenDuAn</strong></div>
                    <div><span>Danh mục</span><strong>@item.TenDanhMucCV</strong></div>
                    <div><span>Mức độ</span><strong>@item.TenMucDo</strong></div>
                    <div><span>Chi phí</span><strong>@item.ChiPhiDaChi.ToString("N0")</strong></div>
                    <div><span>Phân công</span><strong>@GetAssignmentText(item.SoNguoiDuocPhanCong)</strong></div>
                    <div><span>Chi tiết công việc</span><strong>@GetDetailCountText(item.SoLuongChiTietCongViec)</strong></div>
                    <div><span>Bắt đầu</span><strong>@item.NgayBatDauCongViec?.ToString("dd/MM/yyyy HH:mm")</strong></div>
                    <div><span>Hạn</span><strong class="@(item.IsQuaHan || item.IsHoanThanhTre ? "deadline-date-late" : string.Empty)">@item.NgayKetThucCVDuKien?.ToString("dd/MM/yyyy HH:mm")</strong></div>
                    @if (item.NgayKetThucCVThucTe.HasValue)
                    {
                        <div><span>Hoàn tất</span><strong>@item.NgayKetThucCVThucTe?.ToString("dd/MM/yyyy HH:mm")</strong></div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(item.ThongDiepWorkflow))
                {
                    <div class="workflow-note @item.CssTrangThai">@item.ThongDiepWorkflow</div>
                }

                <div class="task-mobile-actions">
                    @if (permissions.Contains(Permissions.PhanCongCongViec.Xem) && item.CoThePhanCongCongViec)
                    {
                        <a asp-controller="PhanCongCongViec" asp-action="Index" asp-route-maCongViec="@item.MaCongViec" class="btn btn-action btn-subtle">
                            <i class="bi bi-person-plus"></i>
                            Phân công
                        </a>
                    }
                    @if (permissions.Contains(Permissions.ChiTietCongViec.Xem))
                    {
                        <a asp-controller="ChiTietCongViec" asp-action="Index" asp-route-maCongViec="@item.MaCongViec" class="btn btn-action btn-subtle">
                            <i class="bi bi-layout-text-sidebar-reverse"></i>
                            Chi tiết
                        </a>
                    }
                    @if (item.CoTheXacNhanHoanThanh && canWorkflowMutate)
                    {
                        <form asp-action="XacNhanHoanThanh" method="post" class="w-100">
                            <input type="hidden" name="maCongViec" value="@item.MaCongViec" />
                            <input type="hidden" name="locMaDuAn" value="@locMaDuAn" />
                            <input type="hidden" name="locTrangThai" value="@locTrangThai" />
                            <input type="hidden" name="tuKhoa" value="@tuKhoa" />
                            <input type="hidden" name="tuNgay" value="@tuNgay?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="denNgay" value="@denNgay?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="locTheoNgay" value="@locTheoNgay" />
                            <input type="hidden" name="locTinhTrangThoiHan" value="@locTinhTrangThoiHan" />
                            <button type="submit" class="btn btn-action btn-confirm w-100">
                                <i class="bi bi-check2-circle"></i>
                                Xác nhận hoàn thành
                            </button>
                        </form>
                    }
                    @if (item.CoTheMoLai && canWorkflowMutate)
                    {
                        <form asp-action="MoLai" method="post" class="reopen-form reopen-form-mobile">
                            <input type="hidden" name="maCongViec" value="@item.MaCongViec" />
                            <input type="hidden" name="locMaDuAn" value="@locMaDuAn" />
                            <input type="hidden" name="locTrangThai" value="@locTrangThai" />
                            <input type="hidden" name="tuKhoa" value="@tuKhoa" />
                            <input type="hidden" name="tuNgay" value="@tuNgay?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="denNgay" value="@denNgay?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="locTheoNgay" value="@locTheoNgay" />
                            <input type="hidden" name="locTinhTrangThoiHan" value="@locTinhTrangThoiHan" />
                            <input type="text" name="lyDo" class="form-control form-control-sm" placeholder="Lý do mở lại" required />
                            <button type="submit" class="btn btn-action btn-reopen w-100">
                                <i class="bi bi-arrow-counterclockwise"></i>
                                Mở lại
                            </button>
                        </form>
                    }
                </div>
            </article>
        }
    </div>
}
