@model QuanLyDuAn.ViewModels.PhanQuyen.PhanQuyenPageViewModel
@using QuanLyDuAn.Constants
@{
    ViewData["Title"] = "Phân quyền";
}

@section Styles {
    <link rel="stylesheet" href="~/css/PhanQuyen/index.css" asp-append-version="true" />
}

<section class="phan-quyen-page">
    <header class="phan-quyen-header-card">
        <h1 class="phan-quyen-title">Phân quyền</h1>
        <p class="phan-quyen-subtitle">Chọn vai trò, cấu hình quyền theo màn hình và lưu cấu hình truy cập.</p>
    </header>

    <section class="phan-quyen-section-card">
        @if (!Model.Roles.Any())
        {
            <div class="empty-state">
                <i class="bi bi-shield-lock"></i>
                <p>Chưa có vai trò hệ thống để cấu hình phân quyền.</p>
            </div>
        }
        else
        {
            <form asp-action="Save" method="post" id="permission-form">
                @Html.AntiForgeryToken()
                <div class="row g-3 mb-3">
                    <div class="col-lg-5">
                        <label asp-for="SelectedRoleId" class="form-label fw-semibold">Vai trò hệ thống</label>
                        <select asp-for="SelectedRoleId"
                                class="form-select"
                                onchange="window.location='@Url.Action("Index", "PhanQuyen")?roleId=' + encodeURIComponent(this.value)">
                            <option value="">-- Chọn vai trò --</option>
                            @foreach (var role in Model.Roles)
                            {
                                <option value="@role.RoleId">@role.RoleName</option>
                            }
                        </select>
                    </div>
                    <div class="col-lg-7 d-flex align-items-end justify-content-lg-end gap-2 table-actions">
                        @if (Model.Permissions.Contains(Permissions.PhanQuyen.Luu))
                        {
                            <button type="button" class="btn-action btn-subtle" id="select-all">Chọn tất cả</button>
                            <button type="button" class="btn-action btn-subtle" id="clear-all">Bỏ chọn tất cả</button>
                            <button type="submit" class="btn-action btn-confirm">Lưu quyền</button>
                        }
                    </div>
                </div>

                @if (string.IsNullOrWhiteSpace(Model.SelectedRoleId))
                {
                    <div class="alert alert-warning mb-0">Vui lòng chọn vai trò để phân quyền.</div>
                }
                else if (!Model.PermissionGroups.Any())
                {
                    <div class="alert alert-warning mb-0">Chưa có danh mục quyền để cấu hình.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table workflow-table align-middle">
                            <thead>
                                <tr>
                                    <th style="width: 28%;">Màn hình</th>
                                    <th>Danh sách quyền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var group in Model.PermissionGroups)
                                {
                                    <tr>
                                        <td class="fw-semibold">@group.TenManHinh</td>
                                        <td>
                                            <div class="d-flex flex-wrap gap-3">
                                                @foreach (var permission in group.DanhSachQuyen)
                                                {
                                                    <div class="form-check">
                                                        <input class="form-check-input permission-checkbox"
                                                               type="checkbox"
                                                               id="perm-@permission.MaDanhMucQuyen"
                                                               name="SelectedPermissionIds"
                                                               value="@permission.MaDanhMucQuyen"
                                                               disabled="@(!Model.Permissions.Contains(Permissions.PhanQuyen.Luu))"
                                                               checked="@(permission.IsSelected ? "checked" : null)" />
                                                        <label class="form-check-label" for="perm-@permission.MaDanhMucQuyen" title="@permission.MoTaDanhMucQuyen">
                                                            @permission.TenDanhMucQuyen
                                                        </label>
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </form>
        }
    </section>
</section>

@section Scripts {
    <script>
        (function () {
            const permissionCheckboxes = document.querySelectorAll('.permission-checkbox');
            const selectAllButton = document.getElementById('select-all');
            const clearAllButton = document.getElementById('clear-all');

            if (selectAllButton) {
                selectAllButton.addEventListener('click', function () {
                    permissionCheckboxes.forEach(function (checkbox) {
                        if (!checkbox.disabled) {
                            checkbox.checked = true;
                        }
                    });
                });
            }

            if (clearAllButton) {
                clearAllButton.addEventListener('click', function () {
                    permissionCheckboxes.forEach(function (checkbox) {
                        if (!checkbox.disabled) {
                            checkbox.checked = false;
                        }
                    });
                });
            }
        })();
    </script>
}
