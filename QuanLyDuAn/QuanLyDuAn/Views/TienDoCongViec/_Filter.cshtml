@model QuanLyDuAn.ViewModels.TienDoCongViec.TienDoCongViecPageViewModel
@{
    var hienThiTuKhoa = !string.IsNullOrWhiteSpace(Model.Filter.TuKhoa)
        ? Model.Filter.TuKhoa
        : Model.Filter.LocMaChiTietCv?.ToString();
}

<form asp-action="Index" method="get" class="td-filter-form mb-3" data-tien-do-filter>
    <input type="hidden" name="locMaChiTietCv" value="@Model.Filter.LocMaChiTietCv" data-filter-ma-ctcv />

    <div class="td-filter-head">
        <h6 class="mb-1">Bộ lọc tiến độ</h6>
        <p class="mb-0">Lọc theo dự án, công việc và khoảng thời gian báo cáo.</p>
    </div>

    <div class="td-filter-grid td-filter-grid-primary">
        <div class="td-filter-field">
            <label class="form-label">Dự án</label>
            <select class="form-select" name="locMaDuAn">
                <option value="">Tất cả dự án</option>
                @foreach (var item in Model.DanhSachDuAn)
                {
                    <option value="@item.MaDuAn" selected="@(Model.Filter.LocMaDuAn == item.MaDuAn)">@item.TenDuAn</option>
                }
            </select>
        </div>

        <div class="td-filter-field">
            <label class="form-label">Công việc</label>
            <select class="form-select" name="locMaCongViec">
                <option value="">Tất cả công việc</option>
                @foreach (var item in Model.DanhSachCongViec)
                {
                    <option value="@item.MaCongViec" selected="@(Model.Filter.LocMaCongViec == item.MaCongViec)">@item.TenCongViec</option>
                }
            </select>
        </div>

        <div class="td-filter-field">
            <label class="form-label">Từ khóa</label>
            <input type="text" class="form-control" name="tuKhoa" value="@hienThiTuKhoa" placeholder="Tên dự án, công việc, chi tiết, mã CTCV..." data-filter-tu-khoa />
        </div>
    </div>

    <div class="td-filter-grid td-filter-grid-secondary">
        <div class="td-filter-field td-filter-field-date">
            <label class="form-label">Từ ngày báo cáo</label>
            <input type="date" class="form-control" name="tuNgayBaoCao" value="@Model.Filter.TuNgayBaoCao?.ToString("yyyy-MM-dd")" />
        </div>

        <div class="td-filter-field td-filter-field-date">
            <label class="form-label">Đến ngày báo cáo</label>
            <input type="date" class="form-control" name="denNgayBaoCao" value="@Model.Filter.DenNgayBaoCao?.ToString("yyyy-MM-dd")" />
        </div>

        <div class="td-filter-actions">
            <button type="submit" class="btn-filter-apply td-filter-submit">Lọc dữ liệu</button>
            <a asp-action="Index" class="btn-filter-reset td-filter-reset">Làm mới</a>
        </div>
    </div>
</form>
