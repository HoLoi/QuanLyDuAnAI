@model QuanLyDuAn.ViewModels.TienDoCongViec.TienDoCongViecPageViewModel
@using QuanLyDuAn.Constants

@{
    var canUpdate = Model.Permissions.Contains(Permissions.TienDo.CapNhat);
    var canApprove = Model.Permissions.Contains(Permissions.TienDo.Duyet);

    string GetDuyetBadgeClass(string? statusCode)
    {
        if (TrangThai.EqualsValue(statusCode, TrangThai.ChoDuyet)) return "td-badge-report-pending";
        if (TrangThai.EqualsValue(statusCode, TrangThai.DaDuyet)) return "td-badge-report-approved";
        if (TrangThai.EqualsValue(statusCode, TrangThai.YeuCauBoSung)) return "td-badge-report-requested";
        if (TrangThai.EqualsValue(statusCode, TrangThai.TuChoi)) return "td-badge-report-rejected";
        return "td-badge-report-default";
    }

    string GetCtcvBadgeClass(string? statusCode)
    {
        if (TrangThai.EqualsValue(statusCode, TrangThai.ChuaBatDau)) return "td-badge-ctcv-not-started";
        if (TrangThai.EqualsValue(statusCode, TrangThai.DangThucHien)) return "td-badge-ctcv-in-progress";
        if (TrangThai.EqualsValue(statusCode, TrangThai.BiCanCan)) return "td-badge-ctcv-blocked";
        if (TrangThai.EqualsValue(statusCode, TrangThai.ChoXacNhanHoanThanh)) return "td-badge-ctcv-waiting-confirm";
        if (TrangThai.EqualsValue(statusCode, TrangThai.HoanThanh)) return "td-badge-ctcv-done";
        return "td-badge-ctcv-default";
    }

    string RutGonGhiChu(string? note, int maxLength = 90)
    {
        if (string.IsNullOrWhiteSpace(note)) return string.Empty;
        var normalized = note.Trim();
        if (normalized.Length <= maxLength) return normalized;
        return normalized.Substring(0, maxLength).TrimEnd() + "...";
    }
}

<div class="tien-do-table-host">
    <div class="table-responsive tien-do-table-scroll">
        <table class="table workflow-table app-data-table tien-do-table mb-0">
            <thead>
                <tr>
                    <th class="col-work">Công việc / Dự án</th>
                    <th class="col-detail">Chi tiết / Người thực hiện</th>
                    <th class="col-progress-status">Tiến độ / Trạng thái</th>
                    <th class="col-report">Báo cáo mới nhất</th>
                    <th class="col-action">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.DanhSach.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">Không có dữ liệu tiến độ công việc.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.DanhSach)
                    {
                        var rowModel = new QuanLyDuAn.ViewModels.TienDoCongViec.TienDoCongViecRowPartialViewModel
                        {
                            Item = item,
                            Filter = Model.Filter,
                            CanUpdate = canUpdate,
                            CanApprove = canApprove,
                            CollapseId = $"capnhat-{item.MaChiTietCV}",
                            LichSuCollapseId = $"lichsu-{item.MaChiTietCV}"
                        };

                        var coBaoCao = item.MaTienDoMoiNhat.HasValue;
                        var ghiChuTomTat = RutGonGhiChu(item.GhiChuBaoCaoGanNhat);

                        <tr class="tien-do-main-row">
                            <td data-label="Công việc">
                                <div class="td-cell-title">@item.TenCongViec</div>
                                <div class="td-subline">Dự án: @item.TenDuAn</div>
                            </td>
                            <td data-label="Chi tiết công việc">
                                <div class="td-cell-title">@item.TenChiTietCongViec</div>
                                <div class="td-subline td-subline-wrap">Người thực hiện: @item.NguoiThucHien</div>
                            </td>
                            <td data-label="Tiến độ / Trạng thái" class="col-progress-status">
                                <div class="td-progress-wrap">
                                    <div class="progress td-progress-track">
                                        <div class="progress-bar" role="progressbar" style="width: @item.PhanTramHienTai%;"></div>
                                    </div>
                                    <span class="badge td-progress-badge">@item.PhanTramHienTai%</span>
                                    <span class="badge td-ctcv-badge @GetCtcvBadgeClass(item.TrangThaiCTCVCode)">@item.TrangThaiCTCV</span>
                                </div>
                            </td>
                            <td data-label="Báo cáo mới nhất">
                                @if (!coBaoCao)
                                {
                                    <span class="text-muted">Chưa có báo cáo</span>
                                }
                                else
                                {
                                    <div class="td-latest-report td-latest-report-card">
                                        <span class="badge td-report-badge @GetDuyetBadgeClass(item.TrangThaiDuyetBaoCaoGanNhatCode)">@item.TrangThaiDuyetBaoCaoGanNhat</span>
                                        <div class="td-meta-line"><span class="fw-semibold">Người báo cáo:</span> @item.TenNguoiBaoCaoGanNhat</div>
                                        <div class="td-meta-line"><span class="fw-semibold">Thời gian:</span> @item.ThoiGianBaoCaoGanNhat?.ToString("dd/MM/yyyy HH:mm")</div>
                                        <div class="td-meta-line"><span class="fw-semibold">Đề xuất:</span> @item.TrangThaiCTCVDeXuatGanNhat</div>
                                        @if (!string.IsNullOrWhiteSpace(ghiChuTomTat))
                                        {
                                            <div class="td-note-line" title="@item.GhiChuBaoCaoGanNhat">@ghiChuTomTat</div>
                                        }
                                    </div>
                                }
                            </td>
                            <td data-label="Thao tác" class="col-action table-actions-cell">
                                <div class="table-actions table-actions-compact">
                                    @if (item.LichSuTienDo.Any())
                                    {
                                        <button type="button" class="btn-action btn-subtle" data-bs-toggle="collapse" data-bs-target="#@rowModel.LichSuCollapseId">
                                            Lịch sử
                                        </button>
                                    }
                                    else if (canUpdate && item.CoTheCapNhatTienDo)
                                    {
                                        <button type="button" class="btn-action btn-confirm" data-bs-toggle="collapse" data-bs-target="#@rowModel.CollapseId">
                                            Báo cáo
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>

                        @if (item.LichSuTienDo.Any())
                        {
                            @await Html.PartialAsync("_History", rowModel)
                        }

                        @if (canUpdate && item.CoTheCapNhatTienDo)
                        {
                            @await Html.PartialAsync("_UpdateForm", rowModel)
                        }
                    }
                }
            </tbody>
        </table>
    </div>
</div>
