                                    <input type="text" name="GhiChuDuyet" class="form-control" maxlength="255" required placeholder="Nh?p l? do t? ch?i" />
                                    <button type="submit" class="btn-action btn-danger-soft">T? ch?i</button>
                                </form>
                            </div>
                        }
                    </article>
                }
            </div>
        </div>
    </td>
</tr>
