                            <div class="history-block">
                                <div class="history-label">Ng�?i duy?t</div>
                                <div class="history-value">@(string.IsNullOrWhiteSpace(ls.TenNguoiDuyet) ? "-" : ls.TenNguoiDuyet)</div>
