@model QuanLyDuAn.ViewModels.DeXuatCongViec.DeXuatCongViecPageViewModel
@using QuanLyDuAn.Constants

<form asp-action="Index" method="get" class="dxcv-filter-form">
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label" for="locMaDuAn">Dự án</label>
            <select id="locMaDuAn" name="locMaDuAn" class="form-select">
                @foreach (var duAn in Model.DanhSachDuAn)
                {
                    if (Model.LocMaDuAn == duAn.MaDuAn)
                    {
                        <option value="@duAn.MaDuAn" selected>@duAn.TenDuAn</option>
                    }
                    else
                    {
                        <option value="@duAn.MaDuAn">@duAn.TenDuAn</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label" for="locTrangThai">Trạng thái đề xuất</label>
            <select id="locTrangThai" name="locTrangThai" class="form-select">
                <option value="">-- Tất cả trạng thái --</option>
                <option value="@TrangThai.ChoDuyet" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.ChoDuyet))">@TrangThai.ChoDuyetHienThi</option>
                <option value="@TrangThai.DaDuyet" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.DaDuyet))">@TrangThai.DaDuyetHienThi</option>
                <option value="@TrangThai.TuChoi" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.TuChoi))">@TrangThai.TuChoiHienThi</option>
                <option value="@TrangThai.DaHuy" selected="@(TrangThai.EqualsValue(Model.LocTrangThai, TrangThai.DaHuy))">@TrangThai.DaHuyHienThi</option>
            </select>
        </div>
    </div>

    <div class="dxcv-filter-actions">
        <button class="dxcv-action-btn dxcv-action-primary" type="submit">
            <i class="bi bi-funnel"></i>
            Lọc
        </button>
        <a asp-action="Index" asp-route-locMaDuAn="@Model.LocMaDuAn" class="dxcv-action-btn dxcv-action-neutral">
            <i class="bi bi-x-circle"></i>
            Bỏ lọc
        </a>
    </div>
</form>
