@model List<QuanLyDuAn.ViewModels.DeXuatCongViec.DeXuatCongViecItemViewModel>
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    var canCreate = permissions.Contains(Permissions.DeXuatCongViec.Them);
    int? locMaDuAn = ViewBag.LocMaDuAn as int?;
    string? locTrangThai = ViewBag.LocTrangThai as string;
}

<table class="table table-bordered table-sm app-data-table">
    <thead>
        <tr>
            <th class="col-id">Mã</th>
            <th>Công việc đề xuất</th>
            <th>Người đề xuất</th>
            <th>Chi phí</th>
            <th class="col-date">Ngày đề xuất</th>
            <th class="col-status">Trạng thái</th>
            <th class="col-actions"></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="7" class="text-center text-muted">Chưa có đề xuất công việc.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td class="col-id">@item.MaDeXuatCV</td>
                    <td>
                        <div class="fw-semibold">@item.TenCongViecDeXuat</div>
                        <div class="text-muted">@item.MoTaCongViecDeXuat</div>
                    </td>
                    <td>@item.NguoiDungDeXuat</td>
                    <td>@item.ChiPhiDeXuat?.ToString("N0")</td>
                    <td class="col-date">@item.NgayDeXuatCongViec?.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="col-status">@TrangThai.ToDisplay(item.TrangThaiCongViecDeXuat)</td>
                    <td class="col-actions table-actions">
                        @if (canCreate && TrangThai.EqualsValue(item.TrangThaiCongViecDeXuat, TrangThai.ChoDuyet))
                        {
                            <form asp-action="HuyDeXuat" method="post">
                                <input type="hidden" name="maDeXuatCv" value="@item.MaDeXuatCV" />
                                <input type="hidden" name="locMaDuAn" value="@locMaDuAn" />
                                <input type="hidden" name="locTrangThai" value="@locTrangThai" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Hủy</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
