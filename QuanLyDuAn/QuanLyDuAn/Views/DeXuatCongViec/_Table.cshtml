@model List<QuanLyDuAn.ViewModels.DeXuatCongViec.DeXuatCongViecItemViewModel>
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    bool canCancel = permissions.Contains(Permissions.DeXuatCongViec.Them);
    int? locMaDuAn = ViewBag.LocMaDuAn as int?;
    string? locTrangThai = ViewBag.LocTrangThai as string;
    DateTime? tuNgay = ViewBag.TuNgay as DateTime?;
    DateTime? denNgay = ViewBag.DenNgay as DateTime?;
    string? locTheoNgay = ViewBag.LocTheoNgay as string;
}

<div class="dxcv-table-scroll table-responsive-soft app-table-scroll proposal-table-scroll">
    <table class="table dxcv-table app-data-table proposal-table">
        <thead>
            <tr>
                <th>Công việc đề xuất</th>
                <th>Người đề xuất</th>
                <th>Chi phí</th>
                <th>Ngày đề xuất</th>
                <th>Trạng thái</th>
                <th class="col-actions">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="6">
                        <div class="dxcv-empty-state">Chưa có đề xuất công việc.</div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    var statusCode = TrangThai.ToCode(item.TrangThaiCongViecDeXuat);
                    var badgeClass = "dxcv-status-neutral";
                    var statusClass = "status-neutral";
                    if (TrangThai.EqualsValue(statusCode, TrangThai.ChoDuyet)) { badgeClass = "dxcv-status-pending"; }
                    else if (TrangThai.EqualsValue(statusCode, TrangThai.DaDuyet)) { badgeClass = "dxcv-status-approved"; statusClass = "status-approved"; }
                    else if (TrangThai.EqualsValue(statusCode, TrangThai.TuChoi)) { badgeClass = "dxcv-status-rejected"; statusClass = "status-rejected"; }
                    else if (TrangThai.EqualsValue(statusCode, TrangThai.DaHuy)) { badgeClass = "dxcv-status-canceled"; statusClass = "status-neutral"; }
                    if (TrangThai.EqualsValue(statusCode, TrangThai.ChoDuyet)) { statusClass = "status-pending"; }

                    <tr>
                        <td>
                            <div class="dxcv-row-title">@item.TenCongViecDeXuat</div>
                            <div class="dxcv-row-subtitle">@item.NgayBatDauCongViecDeXuat?.ToString("dd/MM/yyyy") - @item.NgayKetThucCVDeXuatDuKien?.ToString("dd/MM/yyyy")</div>
                        </td>
                        <td>@item.NguoiDungDeXuat</td>
                        <td class="text-nowrap">@item.ChiPhiDeXuat?.ToString("N0") VNĐ</td>
                        <td class="text-nowrap">@item.NgayDeXuatCongViec?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="dxcv-status-badge status-badge @badgeClass @statusClass">@TrangThai.ToDisplay(item.TrangThaiCongViecDeXuat)</span>
                        </td>
                        <td class="col-actions dxcv-table-actions">
                            <div class="dxcv-action-group dxcv-table-action-group">
                                <button type="button" class="dxcv-action-btn dxcv-action-neutral btn-action btn-subtle proposal-action-btn" data-bs-toggle="collapse" data-bs-target="#dxcv-detail-@item.MaDeXuatCV" aria-expanded="false" aria-controls="dxcv-detail-@item.MaDeXuatCV">
                                    <i class="bi bi-eye"></i>
                                    Xem chi tiết
                                </button>
                                @if (canCancel && TrangThai.EqualsValue(item.TrangThaiCongViecDeXuat, TrangThai.ChoDuyet))
                                {
                                    <form asp-action="HuyDeXuat" method="post" class="d-inline">
                                        <input type="hidden" name="maDeXuatCv" value="@item.MaDeXuatCV" />
                                        <input type="hidden" name="locMaDuAn" value="@locMaDuAn" />
                                        <input type="hidden" name="locTrangThai" value="@locTrangThai" />
                                        <input type="hidden" name="tuNgay" value="@tuNgay?.ToString("yyyy-MM-dd")" />
                                        <input type="hidden" name="denNgay" value="@denNgay?.ToString("yyyy-MM-dd")" />
                                        <input type="hidden" name="locTheoNgay" value="@locTheoNgay" />
                                        <button type="submit" class="dxcv-action-btn dxcv-action-danger btn-action btn-danger-soft proposal-action-btn">
                                            <i class="bi bi-x-circle"></i>
                                            Hủy đề xuất
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                    <tr class="collapse" id="dxcv-detail-@item.MaDeXuatCV">
                        <td colspan="6" class="dxcv-detail-cell">
                            <div class="dxcv-detail-grid proposal-detail-grid">
                                <div>
                                    <span>Mô tả</span>
                                    <p>@item.MoTaCongViecDeXuat</p>
                                </div>
                                <div>
                                    <span>Người duyệt</span>
                                    <p>@(string.IsNullOrWhiteSpace(item.NguoiDungDuyet) ? "Chưa duyệt" : item.NguoiDungDuyet)</p>
                                </div>
                                <div>
                                    <span>Ngày duyệt</span>
                                    <p>@(item.NgayDuyetDeXuatCongViec?.ToString("dd/MM/yyyy HH:mm") ?? "-")</p>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
