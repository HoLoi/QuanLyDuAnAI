@model QuanLyDuAn.ViewModels.DeXuatCongViec.DeXuatCongViecDieuHuongViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/DeXuatCongViec/index.css" asp-append-version="true" />
}

<div class="de-xuat-cong-viec-page de-xuat-cong-viec-dieu-huong">
    <section class="dxcv-header-card">
        <div>
            <h1 class="dxcv-title">Đề xuất công việc</h1>
            <p class="dxcv-subtitle">Tạo và theo dõi các đề xuất công việc trong phạm vi dự án</p>
        </div>
        <a asp-controller="DuAn" asp-action="Index" class="dxcv-action-btn dxcv-action-neutral">
            <i class="bi bi-arrow-left"></i>
            Quay lại dự án
        </a>
    </section>

    <section class="dxcv-warning-card dxcv-warning-card-large">
        <div class="dxcv-warning-icon"><i class="bi bi-exclamation-triangle"></i></div>
        <div>
            <h2>Dự án chưa có ngân sách được duyệt</h2>
            <p>Bạn có thể tạo đề xuất ngân sách trước, hoặc tiếp tục vào màn hình đề xuất công việc để theo dõi và chuẩn bị nội dung.</p>
            <div class="dxcv-action-group mt-3">
                <a asp-action="DieuHuong"
                   asp-route-maDuAn="@Model.MaDuAn"
                   asp-route-deXuatNganSach="true"
                   class="dxcv-action-btn dxcv-action-primary">
                    <i class="bi bi-cash"></i>
                    Đề xuất ngân sách
                </a>

                <a asp-action="DieuHuong"
                   asp-route-maDuAn="@Model.MaDuAn"
                   asp-route-deXuatNganSach="false"
                   class="dxcv-action-btn dxcv-action-neutral">
                    <i class="bi bi-briefcase"></i>
                    Tiếp tục đề xuất công việc
                </a>
            </div>
        </div>
    </section>
</div>
