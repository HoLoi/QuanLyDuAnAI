@model QuanLyDuAn.ViewModels.DeXuatCongViec.DeXuatCongViecDieuHuongViewModel

<div class="card p-3">
    <h5 class="mb-2">Đề xuất công việc</h5>
    <div class="text-muted mb-3">@Model.TenDuAn</div>

    <div class="alert alert-warning mb-3">
        Dự án chưa có ngân sách được duyệt. Bạn có muốn đề xuất ngân sách không?
    </div>

    <div class="d-flex gap-2">
        <a asp-action="DieuHuong"
           asp-route-maDuAn="@Model.MaDuAn"
           asp-route-deXuatNganSach="true"
           class="btn btn-warning btn-sm">Có, đi đến đề xuất ngân sách</a>

        <a asp-action="DieuHuong"
           asp-route-maDuAn="@Model.MaDuAn"
           asp-route-deXuatNganSach="false"
           class="btn btn-outline-primary btn-sm">Không, vẫn đề xuất công việc</a>

        <a asp-controller="DuAn" asp-action="Index" class="btn btn-outline-secondary btn-sm">Quay lại danh sách dự án</a>
    </div>
</div>
