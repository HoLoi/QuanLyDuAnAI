@model QuanLyDuAn.ViewModels.DuAn.DuAnChiTietViewModel
@using QuanLyDuAn.Constants

@{
    ViewData["Title"] = "Chi tiết dự án";
    var permissions = Model.Permissions;
    var canManageFiles = Model.CoTheQuanLyFile;
    var statusCheck = Model.StatusCheck;
    var canSeeBudget = permissions.Contains(Permissions.NganSach.Xem) || permissions.Contains(Permissions.DeXuatNganSach.Xem);
    var canSeeChiPhi = permissions.Contains(Permissions.ChiPhi.Xem);
    var canSeeFinance = canSeeBudget || canSeeChiPhi;
    var canSeeMembers = permissions.Contains(Permissions.ThanhVienDuAn.Xem);
    var canSeeTeams = permissions.Contains(Permissions.TeamDuAn.Xem);
    var canSeeTasks = permissions.Contains(Permissions.CongViec.Xem);
    var canSeeWorkDetails = permissions.Contains(Permissions.ChiTietCongViec.Xem) && Model.MaCongViecDauTien.HasValue;
    var canSeeCategories = permissions.Contains(Permissions.DanhMucCongViec.Xem);
    var canSeeDeXuatCongViec = permissions.Contains(Permissions.DeXuatCongViec.Xem);
    var canSeeDeXuatNganSach = permissions.Contains(Permissions.DeXuatNganSach.Xem);
    var canSeeNganSach = permissions.Contains(Permissions.NganSach.Xem);
    var canSeeChatDuAn = permissions.Contains(Permissions.Chat.Xem)
                         && !(User?.IsInRole("Admin") == true || User?.IsInRole("ADMIN") == true);
    var canSeeActivity = permissions.Contains(Permissions.NhatKy.Xem);
    var canProposeBudget = permissions.Contains(Permissions.DeXuatNganSach.Them);
    var budgetSummary = Model.NganSachTongHop;
    var workSummary = Model.TienDoCongViec;
    var deadlineGanNhat = Model.DeadlineGanNhat;
    var hasAnyWarning = Model.SoLuongThanhVien == 0
                        || Model.SoLuongCongViec == 0
                        || Model.IsSapDenHan
                        || Model.IsQuaHan
                        || (canSeeBudget && !Model.HasApprovedBudget);
}

@section Styles
{
    <link rel="stylesheet" href="~/css/DuAn/details.css" asp-append-version="true" />
}

<div class="project-details">
    <div class="project-hero mb-4">
        <div class="hero-bg"></div>
        <div class="hero-content">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <div class="project-kicker">Mã dự án: @Model.MaDuAn</div>
                    <h2 class="project-title">@Model.TenDuAn</h2>
                    <div class="project-meta">
                        <span class="chip">Loại: @Model.TenLoaiDuAn</span>
                        <span class="chip chip-status">Trạng thái: @TrangThai.ToDisplay(Model.TrangThaiDuAn)</span>
                        <span class="chip chip-progress">Tiến độ: @Model.PhanTramHoanThanh%</span>
                    </div>
                </div>
                <div class="hero-actions d-flex gap-2 flex-wrap">
                    <a asp-action="Index"
                       asp-route-tuKhoa="@Model.TuKhoa"
                       asp-route-locMaLoaiDuAn="@Model.LocMaLoaiDuAn"
                       asp-route-locTrangThaiDuAn="@Model.LocTrangThaiDuAn"
                       class="btn btn-light btn-sm">Quay lại danh sách</a>
                    @if (permissions.Contains(Permissions.DuAn.Sua))
                    {
                        <a asp-action="Sua"
                           asp-route-id="@Model.MaDuAn"
                           asp-route-tuKhoa="@Model.TuKhoa"
                           asp-route-locMaLoaiDuAn="@Model.LocMaLoaiDuAn"
                           asp-route-locTrangThaiDuAn="@Model.LocTrangThaiDuAn"
                           class="btn btn-warning btn-sm">Sửa dự án</a>
                    }
                </div>
            </div>
            <div class="progress-rail mt-3">
                <div class="progress-fill" style="width: @Model.PhanTramHoanThanh%;"></div>
            </div>
            <div class="progress-caption">@Model.PhanTramHoanThanh% hoàn thành</div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="section-card reveal" style="--delay: 80ms;">
                <div class="section-title">Thông tin chính</div>
                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label">Ngày tạo</div>
                        <div class="info-value">@(Model.NgayTaoDuAn?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Ngày bắt đầu</div>
                        <div class="info-value">@(Model.NgayBatDauDuAn?.ToString("dd/MM/yyyy") ?? "-")</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Ngày kết thúc</div>
                        <div class="info-value">@(Model.NgayKetThucDuAn?.ToString("dd/MM/yyyy") ?? "-")</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Người quản lý</div>
                        <div class="info-value">@(string.IsNullOrWhiteSpace(Model.TenNguoiQuanLy) ? "-" : Model.TenNguoiQuanLy)</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">Ghi chú dự án</div>
                        <div class="info-value">@(string.IsNullOrWhiteSpace(Model.GhiChuDuAn) ? "-" : Model.GhiChuDuAn)</div>
                    </div>
                </div>
            </div>

            <div class="section-card reveal mt-4" style="--delay: 160ms;">
                <div class="section-title">Mô tả dự án</div>
                <div class="description-box">
                    @(string.IsNullOrWhiteSpace(Model.MoTaDuAn) ? "Chưa có mô tả dự án." : Model.MoTaDuAn)
                </div>
            </div>

            <div class="section-card reveal mt-4" style="--delay: 200ms;">
                <div class="section-title">Tổng quan hoạt động</div>
                <div class="preview-grid">
                    <div class="preview-card">
                        <div class="preview-header">
                            <i class="bi bi-list-check"></i>
                            <span>5 công việc gần đây</span>
                        </div>
                        @if (Model.CongViecGanDay.Any())
                        {
                            <ul class="preview-list">
                                @foreach (var congViec in Model.CongViecGanDay)
                                {
                                    <li>
                                        <div class="preview-item-title">@congViec.TenCongViec</div>
                                        <div class="preview-item-meta">
                                            <span class="badge status-badge">@TrangThai.ToDisplay(congViec.TrangThaiCongViec)</span>
                                            <span class="meta-text">@congViec.TenDanhMucCV</span>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="empty-state empty-state-panel">
                                <div class="empty-state-icon"><i class="bi bi-clipboard-x"></i></div>
                                <div class="empty-state-text">Chưa có công việc nào.</div>
                                @if (canSeeTasks)
                                {
                                    <a asp-controller="CongViec"
                                       asp-action="Index"
                                       asp-route-locMaDuAn="@Model.MaDuAn"
                                       class="btn btn-outline-primary btn-sm">Xem công việc</a>
                                }
                            </div>
                        }
                    </div>

                    <div class="preview-card">
                        <div class="preview-header">
                            <i class="bi bi-file-earmark-text"></i>
                            <span>5 tệp mới tải lên</span>
                        </div>
                        @if (Model.TepGanDay.Any())
                        {
                            <ul class="preview-list">
                                @foreach (var tep in Model.TepGanDay)
                                {
                                    <li>
                                        <div class="preview-item-title">@tep.TenFileDA</div>
                                        <div class="preview-item-meta">
                                            <span class="meta-text">@((tep.NgayUploadFileDA?.ToString("dd/MM/yyyy HH:mm")) ?? "-")</span>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="empty-state empty-state-panel">
                                <div class="empty-state-icon"><i class="bi bi-cloud-upload"></i></div>
                                <div class="empty-state-text">Chưa có tệp nào được tải lên.</div>
                                @if (canManageFiles)
                                {
                                    <a href="#tep-du-an" class="btn btn-outline-primary btn-sm">Tải lên tệp</a>
                                }
                            </div>
                        }
                    </div>

                    @if (canSeeMembers)
                    {
                        <div class="preview-card">
                            <div class="preview-header">
                                <i class="bi bi-people"></i>
                                <span>Thành viên tham gia nổi bật</span>
                            </div>
                            @if (Model.ThanhVienNoiBat.Any())
                            {
                                <ul class="preview-list">
                                    @foreach (var thanhVien in Model.ThanhVienNoiBat)
                                    {
                                        <li>
                                            <div class="preview-item-title">@thanhVien.HoTenNguoiDung</div>
                                            <div class="preview-item-meta">
                                                <span class="badge role-badge">@TrangThai.ToDisplayVaiTroTrongDuAn(thanhVien.VaiTroTrongDuAn)</span>
                                                <span class="meta-text">@((thanhVien.NgayThamGiaDuAn?.ToString("dd/MM/yyyy")) ?? "-")</span>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="empty-state empty-state-panel">
                                    <div class="empty-state-icon"><i class="bi bi-person-plus"></i></div>
                                    <div class="empty-state-text">Chưa có thành viên tham gia.</div>
                                    <a asp-controller="NhanVienDuAn"
                                       asp-action="Index"
                                       asp-route-maDuAn="@Model.MaDuAn"
                                       asp-route-tuKhoa="@Model.TuKhoa"
                                       asp-route-locMaLoaiDuAn="@Model.LocMaLoaiDuAn"
                                       asp-route-locTrangThaiDuAn="@Model.LocTrangThaiDuAn"
                                       class="btn btn-outline-primary btn-sm">Xem thành viên</a>
                                </div>
                            }
                        </div>
                    }

                    @if (canSeeActivity)
                    {
                        <div class="preview-card">
                            <div class="preview-header">
                                <i class="bi bi-activity"></i>
                                <span>Hoạt động gần đây</span>
                            </div>
                            @if (Model.HoatDongGanDay.Any())
                            {
                                <ul class="preview-list">
                                    @foreach (var hoatDong in Model.HoatDongGanDay)
                                    {
                                        <li>
                                            <div class="preview-item-title">@hoatDong.NoiDung</div>
                                            <div class="preview-item-meta">
                                                <span class="meta-text">@hoatDong.NguoiThucHien</span>
                                                <span class="meta-text">@((hoatDong.ThoiGian?.ToString("dd/MM/yyyy HH:mm")) ?? "-")</span>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="empty-state empty-state-panel">
                                    <div class="empty-state-icon"><i class="bi bi-clock-history"></i></div>
                                    <div class="empty-state-text">Chưa có hoạt động nào gần đây.</div>
                                </div>
                            }
                        </div>
                    }

                    @if (canSeeTasks)
                    {
                        <div class="preview-card preview-card-wide">
                            <div class="preview-header">
                                <i class="bi bi-flag"></i>
                                <span>Deadline gần nhất</span>
                            </div>
                            @if (deadlineGanNhat != null)
                            {
                                <div class="deadline-card">
                                    <div class="deadline-title">@deadlineGanNhat.TenCongViec</div>
                                    <div class="deadline-meta">
                                        Hạn: @((deadlineGanNhat.NgayKetThucDuKien?.ToString("dd/MM/yyyy")) ?? "-")
                                        <span class="badge status-badge">@TrangThai.ToDisplay(deadlineGanNhat.TrangThaiCongViec)</span>
                                    </div>
                                    <div class="deadline-state @(deadlineGanNhat.SoNgayConLai.HasValue && deadlineGanNhat.SoNgayConLai.Value < 0 ? "over" : "near")">
                                        @if (deadlineGanNhat.SoNgayConLai.HasValue)
                                        {
                                            if (deadlineGanNhat.SoNgayConLai.Value < 0)
                                            {
                                                <text>Quá @Math.Abs(deadlineGanNhat.SoNgayConLai.Value) ngày</text>
                                            }
                                            else
                                            {
                                                <text>Còn @deadlineGanNhat.SoNgayConLai.Value ngày</text>
                                            }
                                        }
                                        else
                                        {
                                            <text>Chưa có hạn cụ thể</text>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="empty-state empty-state-panel">
                                    <div class="empty-state-icon"><i class="bi bi-flag"></i></div>
                                    <div class="empty-state-text">Chưa có deadline nào sắp tới.</div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="section-card reveal mt-4" style="--delay: 240ms;" id="tep-du-an">
                <div class="section-title">Tệp dự án</div>
                @if (canManageFiles)
                {
                    <form asp-action="ThemFileDuAn" method="post" enctype="multipart/form-data" class="upload-form">
                        <input type="hidden" name="maDuAn" value="@Model.MaDuAn" />
                        <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
                        <input type="hidden" name="locMaLoaiDuAn" value="@Model.LocMaLoaiDuAn" />
                        <input type="hidden" name="locTrangThaiDuAn" value="@Model.LocTrangThaiDuAn" />
                        <div class="d-flex flex-wrap gap-2 align-items-center">
                            <input class="form-control" type="file" name="file" id="file-upload-input" required />
                            <button type="submit" class="btn btn-primary btn-sm">Tải lên tệp</button>
                        </div>
                        <div class="upload-hint">Chỉ quản lý dự án mới có thể thêm hoặc xóa tệp.</div>
                    </form>
                }
                else
                {
                    <div class="upload-hint">Bạn chỉ có thể tải tệp về để xem. Chức năng thêm/xóa chỉ dành cho quản lý.</div>
                }

                <div class="file-list mt-3">
                    @if (Model.DanhSachFile.Any())
                    {
                        foreach (var file in Model.DanhSachFile)
                        {
                            <div class="file-item">
                                <div class="file-info">
                                    <div class="file-name">@file.TenFileDA</div>
                                    <div class="file-meta">Tải lên: @(file.NgayUploadFileDA?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                                </div>
                                <div class="file-actions">
                                    <a asp-action="TaiFileDuAn"
                                       asp-route-maFileDa="@file.MaFileDA"
                                       asp-route-maDuAn="@Model.MaDuAn"
                                       asp-route-tuKhoa="@Model.TuKhoa"
                                       asp-route-locMaLoaiDuAn="@Model.LocMaLoaiDuAn"
                                       asp-route-locTrangThaiDuAn="@Model.LocTrangThaiDuAn"
                                       class="btn btn-outline-primary btn-sm">Tải về</a>
                                    @if (canManageFiles)
                                    {
                                        <form asp-action="XoaFileDuAn" method="post" class="d-inline">
                                            <input type="hidden" name="maFileDa" value="@file.MaFileDA" />
                                            <input type="hidden" name="maDuAn" value="@Model.MaDuAn" />
                                            <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
                                            <input type="hidden" name="locMaLoaiDuAn" value="@Model.LocMaLoaiDuAn" />
                                            <input type="hidden" name="locTrangThaiDuAn" value="@Model.LocTrangThaiDuAn" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm">Xóa</button>
                                        </form>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state empty-state-panel">
                            <div class="empty-state-icon"><i class="bi bi-cloud-arrow-up"></i></div>
                            <div class="empty-state-text">Chưa có tệp dự án nào được tải lên.</div>
                            @if (canManageFiles)
                            {
                                <label class="btn btn-primary btn-sm" for="file-upload-input">Tải tệp đầu tiên</label>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="sticky-sidebar">
                <div class="section-card reveal" style="--delay: 120ms;">
                    <div class="section-title">Thống kê nhanh</div>
                    <div class="stat-grid">
                        <div class="stat-card">
                            <div class="stat-icon"><i class="bi bi-diagram-3"></i></div>
                            <div>
                                <div class="stat-label">Số nhóm</div>
                                <div class="stat-value">@Model.SoLuongTeam</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon"><i class="bi bi-people"></i></div>
                            <div>
                                <div class="stat-label">Số thành viên</div>
                                <div class="stat-value">@Model.SoLuongThanhVien</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon"><i class="bi bi-list-task"></i></div>
                            <div>
                                <div class="stat-label">Số công việc</div>
                                <div class="stat-value">@Model.SoLuongCongViec</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon"><i class="bi bi-card-checklist"></i></div>
                            <div>
                                <div class="stat-label">Số chi tiết</div>
                                <div class="stat-value">@Model.SoLuongChiTietCongViec</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="section-card reveal mt-4" style="--delay: 160ms;">
                    <div class="section-title">Tiến độ công việc</div>
                    @if (workSummary.TongCongViec == 0)
                    {
                        <div class="empty-state empty-state-panel">
                            <div class="empty-state-icon"><i class="bi bi-clipboard-x"></i></div>
                            <div class="empty-state-text">Chưa có công việc nào.</div>
                            @if (canSeeTasks)
                            {
                                <a asp-controller="CongViec"
                                   asp-action="Index"
                                   asp-route-locMaDuAn="@Model.MaDuAn"
                                   class="btn btn-outline-primary btn-sm">Xem danh sách công việc</a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="work-progress">
                            <div class="progress">
                                <div class="progress-bar bg-success" style="width: @workSummary.TiLeHoanThanhCap%;"></div>
                            </div>
                            <div class="progress-caption">@((workSummary.TiLeHoanThanh ?? 0).ToString("0"))% công việc đã hoàn thành</div>
                        </div>
                        <div class="work-grid">
                            <div class="work-item done">
                                <span class="work-label"><i class="bi bi-check-circle-fill"></i> Hoàn thành</span>
                                <span class="work-value">@workSummary.CongViecHoanThanh</span>
                            </div>
                            <div class="work-item active">
                                <span class="work-label"><i class="bi bi-play-circle-fill"></i> Đang thực hiện</span>
                                <span class="work-value">@workSummary.CongViecDangThucHien</span>
                            </div>
                            <div class="work-item warn">
                                <span class="work-label"><i class="bi bi-exclamation-triangle-fill"></i> Trễ hạn</span>
                                <span class="work-value">@workSummary.CongViecTreHan</span>
                            </div>
                            <div class="work-item paused">
                                <span class="work-label"><i class="bi bi-pause-circle-fill"></i> Tạm dừng</span>
                                <span class="work-value">@workSummary.CongViecTamDung</span>
                            </div>
                            <div class="work-item idle">
                                <span class="work-label"><i class="bi bi-hourglass-split"></i> Chưa bắt đầu</span>
                                <span class="work-value">@workSummary.CongViecChuaBatDau</span>
                            </div>
                        </div>
                    }
                </div>

                @if (canSeeFinance)
                {
                    <div class="section-card reveal mt-4" style="--delay: 200ms;">
                        <div class="section-title">Tài chính dự án</div>
                        @if (budgetSummary == null || !budgetSummary.CoNganSachDaDuyet)
                        {
                            <div class="empty-state empty-state-panel">
                                <div class="empty-state-icon"><i class="bi bi-wallet2"></i></div>
                                <div class="empty-state-text">Chưa có ngân sách được duyệt.</div>
                                @if (canProposeBudget)
                                {
                                    <a asp-controller="DeXuatNganSach"
                                       asp-action="Index"
                                       asp-route-locMaDuAn="@Model.MaDuAn"
                                       class="btn btn-outline-primary btn-sm">Đề xuất ngân sách</a>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="budget-summary">
                                <div class="budget-row">
                                    <span>Ngân sách đã duyệt</span>
                                    <strong>@(budgetSummary.TongNganSachDaDuyet?.ToString("N0") ?? "0") VNĐ</strong>
                                </div>
                                <div class="budget-row">
                                    <span>Đã sử dụng</span>
                                    <strong>@budgetSummary.TongChiPhiDaDung.ToString("N0") VNĐ</strong>
                                </div>
                                <div class="budget-row">
                                    <span>Còn lại</span>
                                    <strong>@(budgetSummary.SoTienConLai?.ToString("N0") ?? "-") VNĐ</strong>
                                </div>
                                <div class="budget-progress">
                                    <div class="progress">
                                        <div class="progress-bar @budgetSummary.TrangThaiCss" style="width: @budgetSummary.PhanTramSuDungCap%;"></div>
                                    </div>
                                    <div class="budget-caption">@((budgetSummary.PhanTramSuDung ?? 0).ToString("0"))% ngân sách đã sử dụng</div>
                                </div>
                                <div class="budget-status-row">
                                    <span class="budget-badge @budgetSummary.TrangThaiCss">
                                        <i class="bi @(budgetSummary.VuotNganSach ? "bi-x-circle-fill" : budgetSummary.SapVuotNganSach ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill")"></i>
                                        @budgetSummary.TrangThaiHienThi
                                    </span>
                                    @if (budgetSummary.VuotNganSach)
                                    {
                                        <span class="budget-alert">Cảnh báo vượt ngân sách</span>
                                    }
                                </div>
                                @if (!budgetSummary.CoChiPhi)
                                {
                                    <div class="budget-note"><i class="bi bi-info-circle"></i> Chưa có dữ liệu chi phí.</div>
                                }
                            </div>
                        }
                    </div>
                }

                <div class="section-card reveal mt-4" style="--delay: 220ms;">
                    <div class="section-title">Cảnh báo dự án</div>
                    @if (!hasAnyWarning)
                    {
                        <div class="empty-state empty-state-panel">
                            <div class="empty-state-icon"><i class="bi bi-shield-check"></i></div>
                            <div class="empty-state-text">Không có cảnh báo nào cần lưu ý.</div>
                        </div>
                    }
                    else
                    {
                        <ul class="warning-list">
                            @if (Model.SoLuongThanhVien == 0)
                            {
                                <li><i class="bi bi-person-x"></i> Chưa có thành viên tham gia.</li>
                            }
                            @if (Model.SoLuongCongViec == 0)
                            {
                                <li><i class="bi bi-clipboard-x"></i> Chưa có công việc nào được tạo.</li>
                            }
                            @if (Model.IsSapDenHan)
                            {
                                <li><i class="bi bi-clock-history"></i> Sắp đến hạn @if (Model.SoNgayConLai.HasValue) {<text>(còn @Model.SoNgayConLai.Value ngày)</text>}.</li>
                            }
                            @if (Model.IsQuaHan)
                            {
                                <li><i class="bi bi-exclamation-diamond"></i> Đã trễ hạn @if (Model.SoNgayConLai.HasValue) {<text>(quá @Math.Abs(Model.SoNgayConLai.Value) ngày)</text>}.</li>
                            }
                            @if (canSeeBudget && !Model.HasApprovedBudget)
                            {
                                <li><i class="bi bi-wallet2"></i> Chưa có ngân sách được duyệt.</li>
                            }
                        </ul>
                    }
                </div>

                @if (statusCheck != null)
                {
                    <div class="section-card reveal mt-4" style="--delay: 230ms;">
                        <div class="section-title">Trạng thái luồng công việc</div>
                        <div class="workflow-meta">Hiện tại: <strong>@TrangThai.ToDisplay(statusCheck.TrangThaiDuAn)</strong></div>
                        <div class="workflow-grid">
                            <div class="workflow-item">
                                <span>Có thành viên</span>
                                <span class="workflow-status @(statusCheck.HasMembers ? "ok" : "bad")">
                                    <i class="bi @(statusCheck.HasMembers ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
                                    @(statusCheck.HasMembers ? "Đã có" : "Chưa có")
                                </span>
                            </div>
                            <div class="workflow-item">
                                <span>Có danh mục công việc</span>
                                <span class="workflow-status @(statusCheck.HasCategories ? "ok" : "bad")">
                                    <i class="bi @(statusCheck.HasCategories ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
                                    @(statusCheck.HasCategories ? "Đã có" : "Chưa có")
                                </span>
                            </div>
                            <div class="workflow-item">
                                <span>Có công việc</span>
                                <span class="workflow-status @(statusCheck.HasWorkItems ? "ok" : "bad")">
                                    <i class="bi @(statusCheck.HasWorkItems ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
                                    @(statusCheck.HasWorkItems ? "Đã có" : "Chưa có")
                                </span>
                            </div>
                            <div class="workflow-item">
                                <span>Tất cả công việc hoàn thành</span>
                                <span class="workflow-status @(statusCheck.AllTasksDone ? "ok" : "warn")">
                                    <i class="bi @(statusCheck.AllTasksDone ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                                    @(statusCheck.AllTasksDone ? "Hoàn tất" : "Chưa hoàn tất")
                                </span>
                            </div>
                            <div class="workflow-item">
                                <span>Không có công việc đang thực hiện</span>
                                <span class="workflow-status @(!statusCheck.HasOngoingTasks ? "ok" : "warn")">
                                    <i class="bi @(!statusCheck.HasOngoingTasks ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                                    @(!statusCheck.HasOngoingTasks ? "Ổn định" : "Còn đang thực hiện")
                                </span>
                            </div>
                            <div class="workflow-item">
                                <span>Không có công việc bị cản trở</span>
                                <span class="workflow-status @(!statusCheck.HasBlockedTasks ? "ok" : "warn")">
                                    <i class="bi @(!statusCheck.HasBlockedTasks ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                                    @(!statusCheck.HasBlockedTasks ? "Ổn định" : "Có việc bị cản trở")
                                </span>
                            </div>
                        </div>
                    </div>
                }

                <div class="section-card reveal mt-4" style="--delay: 240ms;">
                    <div class="section-title">Điều hướng nhanh</div>
                    <div class="nav-grid">
                        @if (canSeeTasks)
                        {
                            <a asp-controller="CongViec"
                               asp-action="Index"
                               asp-route-locMaDuAn="@Model.MaDuAn"
                               class="quick-action-card">
                                <span class="quick-icon"><i class="bi bi-list-task"></i></span>
                                <span class="quick-title">Công việc</span>
                                <span class="quick-desc">Theo dõi danh sách</span>
                            </a>
                        }
                        @if (canSeeWorkDetails)
                        {
                            <a asp-controller="ChiTietCongViec"
                               asp-action="Index"
                               asp-route-maCongViec="@Model.MaCongViecDauTien"
                               class="quick-action-card">
                                <span class="quick-icon"><i class="bi bi-card-checklist"></i></span>
                                <span class="quick-title">Chi tiết công việc</span>
                                <span class="quick-desc">Theo dõi đầu mục</span>
                            </a>
                        }
                        @if (canSeeTeams)
                        {
                            <a asp-controller="TeamDuAn"
                               asp-action="Index"
                               asp-route-maDuAn="@Model.MaDuAn"
                               asp-route-tuKhoa="@Model.TuKhoa"
                               asp-route-locMaLoaiDuAn="@Model.LocMaLoaiDuAn"
                               asp-route-locTrangThaiDuAn="@Model.LocTrangThaiDuAn"
                               class="quick-action-card">
                                <span class="quick-icon"><i class="bi bi-diagram-3"></i></span>
                                <span class="quick-title">Nhóm phụ trách</span>
                                <span class="quick-desc">Xem các nhóm</span>
                            </a>
                        }
                        @if (canSeeMembers)
                        {
                            <a asp-controller="NhanVienDuAn"
                               asp-action="Index"
                               asp-route-maDuAn="@Model.MaDuAn"
                               asp-route-tuKhoa="@Model.TuKhoa"
                               asp-route-locMaLoaiDuAn="@Model.LocMaLoaiDuAn"
                               asp-route-locTrangThaiDuAn="@Model.LocTrangThaiDuAn"
                               class="quick-action-card">
                                <span class="quick-icon"><i class="bi bi-people"></i></span>
                                <span class="quick-title">Thành viên dự án</span>
                                <span class="quick-desc">Danh sách tham gia</span>
                            </a>
                        }
                        @if (canSeeCategories)
                        {
                            <a asp-controller="DanhMucCongViec"
                               asp-action="Index"
                               asp-route-locMaDuAn="@Model.MaDuAn"
                               class="quick-action-card">
                                <span class="quick-icon"><i class="bi bi-folder2-open"></i></span>
                                <span class="quick-title">Danh mục công việc</span>
                                <span class="quick-desc">Quản lý danh mục</span>
                            </a>
                        }
                        @if (canSeeDeXuatCongViec)
                        {
                            <a asp-controller="DeXuatCongViec"
                               asp-action="Index"
                               asp-route-locMaDuAn="@Model.MaDuAn"
                               class="quick-action-card">
                                <span class="quick-icon"><i class="bi bi-lightbulb"></i></span>
                                <span class="quick-title">Đề xuất công việc</span>
                                <span class="quick-desc">Dòng đề xuất</span>
                            </a>
                        }
                        @if (canSeeDeXuatNganSach)
                        {
                            <a asp-controller="DeXuatNganSach"
                               asp-action="Index"
                               asp-route-locMaDuAn="@Model.MaDuAn"
                               class="quick-action-card">
                                <span class="quick-icon"><i class="bi bi-cash-coin"></i></span>
                                <span class="quick-title">Đề xuất ngân sách</span>
                                <span class="quick-desc">Gửi yêu cầu</span>
                            </a>
                        }
                        @if (canSeeNganSach)
                        {
                            <a asp-controller="NganSach"
                               asp-action="Index"
                               asp-route-locMaDuAn="@Model.MaDuAn"
                               class="quick-action-card">
                                <span class="quick-icon"><i class="bi bi-wallet2"></i></span>
                                <span class="quick-title">Ngân sách</span>
                                <span class="quick-desc">Theo dõi cấp phát</span>
                            </a>
                        }
                        @if (canSeeChatDuAn)
                        {
                            <a asp-controller="ChatDuAn"
                               asp-action="Index"
                               asp-route-maDuAn="@Model.MaDuAn"
                               class="quick-action-card">
                                <span class="quick-icon"><i class="bi bi-chat-dots"></i></span>
                                <span class="quick-title">Chat dự án</span>
                                <span class="quick-desc">Trao đổi nội bộ</span>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
