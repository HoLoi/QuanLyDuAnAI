@model QuanLyDuAn.ViewModels.DuAn.DuAnChiTietViewModel
@using QuanLyDuAn.Constants

@{
    ViewData["Title"] = "Chi tiết dự án";
    var permissions = Model.Permissions;
}

<div class="row g-3">
    <div class="col-12">
        <div class="card card-soft p-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                    <div class="text-muted small">Mã dự án: @Model.MaDuAn</div>
                    <h5 class="mb-1">@Model.TenDuAn</h5>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge bg-light text-dark border">Loại: @Model.TenLoaiDuAn</span>
                        <span class="badge bg-light text-dark border">Trạng thái: @TrangThai.ToDisplay(Model.TrangThaiDuAn)</span>
                        <span class="badge bg-light text-dark border">Tiến độ: @Model.PhanTramHoanThanh%</span>
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a asp-action="Index"
                       asp-route-tuKhoa="@Model.TuKhoa"
                       asp-route-locMaLoaiDuAn="@Model.LocMaLoaiDuAn"
                       asp-route-locTrangThaiDuAn="@Model.LocTrangThaiDuAn"
                       class="btn btn-outline-secondary btn-sm">Quay lại danh sách</a>
                    @if (permissions.Contains(Permissions.DuAn.Sua))
                    {
                        <a asp-action="Sua"
                           asp-route-id="@Model.MaDuAn"
                           asp-route-tuKhoa="@Model.TuKhoa"
                           asp-route-locMaLoaiDuAn="@Model.LocMaLoaiDuAn"
                           asp-route-locTrangThaiDuAn="@Model.LocTrangThaiDuAn"
                           class="btn btn-outline-warning btn-sm">Sửa dự án</a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card card-soft p-3 h-100">
            <h6 class="mb-3">Thông tin tổng quan</h6>
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="text-muted small">Ngày tạo</div>
                    <div class="fw-semibold">@(Model.NgayTaoDuAn?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Ngày bắt đầu</div>
                    <div class="fw-semibold">@(Model.NgayBatDauDuAn?.ToString("dd/MM/yyyy") ?? "-")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Ngày kết thúc</div>
                    <div class="fw-semibold">@(Model.NgayKetThucDuAn?.ToString("dd/MM/yyyy") ?? "-")</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Người quản lý</div>
                    <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.TenNguoiQuanLy) ? "-" : Model.TenNguoiQuanLy)</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Ghi chú dự án</div>
                    <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.GhiChuDuAn) ? "-" : Model.GhiChuDuAn)</div>
                </div>
                <div class="col-12">
                    <div class="text-muted small">Mô tả dự án</div>
                    <div>@(string.IsNullOrWhiteSpace(Model.MoTaDuAn) ? "-" : Model.MoTaDuAn)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card card-soft p-3 h-100">
            <h6 class="mb-3">Thống kê nhanh</h6>
            <div class="row g-2">
                <div class="col-6">
                    <div class="border rounded p-2">
                        <div class="text-muted small">Team</div>
                        <div class="fw-bold">@Model.SoLuongTeam</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="border rounded p-2">
                        <div class="text-muted small">Thành viên</div>
                        <div class="fw-bold">@Model.SoLuongThanhVien</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="border rounded p-2">
                        <div class="text-muted small">Công việc</div>
                        <div class="fw-bold">@Model.SoLuongCongViec</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="border rounded p-2">
                        <div class="text-muted small">Chi tiết việc</div>
                        <div class="fw-bold">@Model.SoLuongChiTietCongViec</div>
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <div class="d-flex justify-content-between small mb-1">
                    <span class="text-muted">Tiến độ tổng quan</span>
                    <span class="fw-semibold">@Model.PhanTramHoanThanh%</span>
                </div>
                <div class="progress">
                    <div class="progress-bar" role="progressbar" style="width: @Model.PhanTramHoanThanh%;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card card-soft p-3">
            <h6 class="mb-3">Điều hướng chức năng</h6>
            <div class="d-flex gap-2 flex-wrap">
                @if (permissions.Contains(Permissions.CongViec.Xem))
                {
                    <a asp-controller="CongViec"
                       asp-action="Index"
                       asp-route-locMaDuAn="@Model.MaDuAn"
                       class="btn btn-outline-primary btn-sm">Xem công việc</a>
                }
                @if (permissions.Contains(Permissions.ChiTietCongViec.Xem) && Model.MaCongViecDauTien.HasValue)
                {
                    <a asp-controller="ChiTietCongViec"
                       asp-action="Index"
                       asp-route-maCongViec="@Model.MaCongViecDauTien"
                       class="btn btn-outline-primary btn-sm">Xem chi tiết công việc</a>
                }
                @if (permissions.Contains(Permissions.TeamDuAn.Xem))
                {
                    <a asp-controller="TeamDuAn"
                       asp-action="Index"
                       asp-route-maDuAn="@Model.MaDuAn"
                       asp-route-tuKhoa="@Model.TuKhoa"
                       asp-route-locMaLoaiDuAn="@Model.LocMaLoaiDuAn"
                       asp-route-locTrangThaiDuAn="@Model.LocTrangThaiDuAn"
                       class="btn btn-outline-info btn-sm">Xem team phụ trách</a>
                }
                @if (permissions.Contains(Permissions.ThanhVienDuAn.Xem))
                {
                    <a asp-controller="NhanVienDuAn"
                       asp-action="Index"
                       asp-route-maDuAn="@Model.MaDuAn"
                       asp-route-tuKhoa="@Model.TuKhoa"
                       asp-route-locMaLoaiDuAn="@Model.LocMaLoaiDuAn"
                       asp-route-locTrangThaiDuAn="@Model.LocTrangThaiDuAn"
                       class="btn btn-outline-info btn-sm">Xem thành viên dự án</a>
                }
                @if (permissions.Contains(Permissions.DanhMucCongViec.Xem))
                {
                    <a asp-controller="DanhMucCongViec"
                       asp-action="Index"
                       asp-route-locMaDuAn="@Model.MaDuAn"
                       class="btn btn-outline-primary btn-sm">Xem danh mục công việc</a>
                }
                @if (permissions.Contains(Permissions.DeXuatCongViec.Xem))
                {
                    <a asp-controller="DeXuatCongViec"
                       asp-action="Index"
                       asp-route-locMaDuAn="@Model.MaDuAn"
                       class="btn btn-outline-primary btn-sm">Xem đề xuất công việc</a>
                }
                @if (permissions.Contains(Permissions.DeXuatNganSach.Xem))
                {
                    <a asp-controller="DeXuatNganSach"
                       asp-action="Index"
                       asp-route-locMaDuAn="@Model.MaDuAn"
                       class="btn btn-outline-primary btn-sm">Xem đề xuất ngân sách</a>
                }
                @if (permissions.Contains(Permissions.NganSach.Xem))
                {
                    <a asp-controller="NganSach"
                       asp-action="Index"
                       asp-route-locMaDuAn="@Model.MaDuAn"
                       class="btn btn-outline-primary btn-sm">Xem ngân sách</a>
                }
            </div>
        </div>
    </div>
</div>
