@model QuanLyDuAn.ViewModels.DuAn.DuAnPageViewModel
@using QuanLyDuAn.Constants
@using QuanLyDuAn.ViewModels.DuAn

@{
    var danhSachLoaiDuAn = ViewBag.DanhSachLoaiDuAn as List<QuanLyDuAn.ViewModels.DuAn.LoaiDuAnOptionViewModel>
                          ?? new List<QuanLyDuAn.ViewModels.DuAn.LoaiDuAnOptionViewModel>();

    var locTrangThai = Model.LocTrangThaiDuAn;
    var locTinhTrangThoiHan = DuAnDeadlineStatusHelper.NormalizeFilter(Model.LocTinhTrangThoiHan);
}

<form asp-action="Index" method="get" class="du-an-filter-form">
    <div class="du-an-filter-grid du-an-filter-grid-main">
        <div class="du-an-filter-field du-an-filter-field-wide">
            <label class="form-label">Từ khóa</label>
            <input type="text" name="tuKhoa" value="@Model.TuKhoa" class="form-control"
                   placeholder="Tìm theo tên dự án, loại dự án, mô tả..." />
        </div>

        <div class="du-an-filter-field">
            <label class="form-label">Loại dự án</label>
            <select name="locMaLoaiDuAn" class="form-select">
                <option value="">Tất cả loại dự án</option>
                @foreach (var loai in danhSachLoaiDuAn)
                {
                    <option value="@loai.MaLoaiDuAn" selected="@(Model.LocMaLoaiDuAn == loai.MaLoaiDuAn ? "selected" : null)">@loai.TenLoai</option>
                }
            </select>
        </div>

        <div class="du-an-filter-field">
            <label class="form-label">Trạng thái</label>
            <select name="locTrangThaiDuAn" class="form-select">
                <option value="">Tất cả trạng thái</option>
                <option value="@TrangThai.KhoiTao" selected="@(TrangThai.EqualsValue(locTrangThai, TrangThai.KhoiTao) ? "selected" : null)">@TrangThai.KhoiTaoHienThi</option>
                <option value="@TrangThai.DangThucHien" selected="@(TrangThai.EqualsValue(locTrangThai, TrangThai.DangThucHien) ? "selected" : null)">@TrangThai.DangThucHienHienThi</option>
                <option value="@TrangThai.ChoXacNhanHoanThanh" selected="@(TrangThai.EqualsValue(locTrangThai, TrangThai.ChoXacNhanHoanThanh) ? "selected" : null)">@TrangThai.ChoXacNhanHoanThanhHienThi</option>
                <option value="@TrangThai.HoanThanh" selected="@(TrangThai.EqualsValue(locTrangThai, TrangThai.HoanThanh) ? "selected" : null)">@TrangThai.HoanThanhHienThi</option>
                <option value="@TrangThai.TamDung" selected="@(TrangThai.EqualsValue(locTrangThai, TrangThai.TamDung) ? "selected" : null)">@TrangThai.TamDungHienThi</option>
                <option value="@TrangThai.LuuTru" selected="@(TrangThai.EqualsValue(locTrangThai, TrangThai.LuuTru) ? "selected" : null)">@TrangThai.LuuTruHienThi</option>
            </select>
        </div>

        <div class="du-an-filter-field">
            <label class="form-label">Tình trạng thời hạn</label>
            <select name="locTinhTrangThoiHan" class="form-select">
                <option value="">Tất cả tình trạng</option>
                <option value="@DuAnDeadlineStatusHelper.FilterDangQuaHan" selected="@(locTinhTrangThoiHan == DuAnDeadlineStatusHelper.FilterDangQuaHan ? "selected" : null)">Đang quá hạn</option>
                <option value="@DuAnDeadlineStatusHelper.FilterCoCongViecTre" selected="@(locTinhTrangThoiHan == DuAnDeadlineStatusHelper.FilterCoCongViecTre ? "selected" : null)">Có công việc trễ</option>
                <option value="@DuAnDeadlineStatusHelper.FilterHoanThanhTre" selected="@(locTinhTrangThoiHan == DuAnDeadlineStatusHelper.FilterHoanThanhTre ? "selected" : null)">Hoàn thành trễ</option>
                <option value="@DuAnDeadlineStatusHelper.FilterHoanThanhDungHan" selected="@(locTinhTrangThoiHan == DuAnDeadlineStatusHelper.FilterHoanThanhDungHan ? "selected" : null)">Hoàn thành đúng hạn</option>
                <option value="@DuAnDeadlineStatusHelper.FilterConHan" selected="@(locTinhTrangThoiHan == DuAnDeadlineStatusHelper.FilterConHan ? "selected" : null)">Còn hạn</option>
            </select>
        </div>
    </div>

    <div class="du-an-filter-grid du-an-filter-grid-time">
        <div class="du-an-filter-field">
            <label class="form-label">Lọc theo ngày</label>
            <select name="locTheoNgay" class="form-select">
                <option value="NgayTao" selected="@((Model.LocTheoNgay ?? "NgayTao") == "NgayTao")">Ngày tạo</option>
                <option value="NgayBatDau" selected="@(Model.LocTheoNgay == "NgayBatDau")">Ngày bắt đầu</option>
                <option value="NgayKetThuc" selected="@(Model.LocTheoNgay == "NgayKetThuc")">Ngày kết thúc</option>
            </select>
        </div>

        <div class="du-an-filter-field du-an-filter-field-date">
            <label class="form-label">Từ ngày</label>
            <input type="date" name="tuNgay" value="@Model.TuNgay?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>

        <div class="du-an-filter-field du-an-filter-field-date">
            <label class="form-label">Đến ngày</label>
            <input type="date" name="denNgay" value="@Model.DenNgay?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>

        <div class="du-an-filter-actions">
            <button type="submit" class="du-an-filter-btn-primary">Lọc dữ liệu</button>
            <a asp-action="Index" class="du-an-filter-btn-secondary">Làm mới</a>
        </div>
    </div>
</form>
