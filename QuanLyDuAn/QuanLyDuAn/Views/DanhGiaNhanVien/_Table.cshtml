@model QuanLyDuAn.ViewModels.DanhGiaNhanVien.DanhGiaNhanVienPageViewModel

<div class="table-responsive dgnv-table-wrap">
    <table class="table table-hover align-middle dgnv-table">
        <thead>
            <tr>
                <th>Nhân viên</th>
                <th>Dự án</th>
                <th>Vai trò</th>
                <th>Trạng thái</th>
                <th>Điểm</th>
                <th>Thống kê</th>
                <th class="text-end">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.DanhSach)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.TenNhanVien</div>
                        <div class="text-muted small">ID: @item.MaNhanVien</div>
                    </td>
                    <td>@item.TenDuAn</td>
                    <td>@item.VaiTroTrongDuAn</td>
                    <td>@await Html.PartialAsync("_TrangThaiDanhGiaBadge", item.TrangThaiDanhGia)</td>
                    <td>@await Html.PartialAsync("_ScoreBadge", item)</td>
                    <td>
                        <span class="small text-muted">@item.ChiTietHoanThanh/@item.TongChiTietDuocGiao HT | Trễ: @item.ChiTietTreHan</span>
                    </td>
                    <td class="text-end">
                        <div class="d-flex gap-1 justify-content-end flex-wrap">
                            <a asp-action="ChiTiet" asp-route-maDanhGiaNhanVien="@item.MaDanhGiaNhanVien" class="btn btn-sm btn-outline-secondary">Chi tiết</a>
                            @if (item.CoTheSua)
                            {
                                <a asp-action="Form" asp-route-maDuAn="@item.MaDuAn" asp-route-maNhanVien="@item.MaNhanVien" class="btn btn-sm btn-warning">Sửa</a>
                            }
                            @if (item.CoTheGuiDuyet)
                            {
                                <form asp-action="GuiDuyet" method="post">
                                    <input type="hidden" name="maDanhGiaNhanVien" value="@item.MaDanhGiaNhanVien" />
                                    <input type="hidden" name="maDuAn" value="@Model.MaDuAn" />
                                    <input type="hidden" name="maNhanVien" value="@Model.MaNhanVien" />
                                    <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
                                    <button type="submit" class="btn btn-sm btn-primary">Gửi duyệt</button>
                                </form>
                            }
                            @if (item.CoTheDuyet)
                            {
                                <form asp-action="Duyet" method="post">
                                    <input type="hidden" name="maDanhGiaNhanVien" value="@item.MaDanhGiaNhanVien" />
                                    <input type="hidden" name="maDuAn" value="@Model.MaDuAn" />
                                    <input type="hidden" name="maNhanVien" value="@Model.MaNhanVien" />
                                    <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
                                    <button type="submit" class="btn btn-sm btn-success">Duyệt</button>
                                </form>
                            }
                            @if (item.CoTheTuChoi)
                            {
                                <form asp-action="TuChoi" method="post" class="d-flex gap-1">
                                    <input type="hidden" name="maDanhGiaNhanVien" value="@item.MaDanhGiaNhanVien" />
                                    <input type="hidden" name="maDuAn" value="@Model.MaDuAn" />
                                    <input type="hidden" name="maNhanVien" value="@Model.MaNhanVien" />
                                    <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
                                    <input type="text" name="lyDoTuChoi" class="form-control form-control-sm" placeholder="Lý do" required />
                                    <button type="submit" class="btn btn-sm btn-danger">Từ chối</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
