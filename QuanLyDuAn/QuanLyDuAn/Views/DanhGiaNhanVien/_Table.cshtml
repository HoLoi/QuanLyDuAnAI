@model QuanLyDuAn.ViewModels.DanhGiaNhanVien.DanhGiaNhanVienPageViewModel
@{
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var upstreamReturnUrl = Context.Request.Query["returnUrl"].ToString();
    var tuModuleDuAn = string.Equals(Model.Nguon, "du-an", StringComparison.OrdinalIgnoreCase);
    var effectiveReturnUrl = tuModuleDuAn && Url.IsLocalUrl(upstreamReturnUrl)
        ? upstreamReturnUrl
        : currentUrl;
}

<div class="table-responsive dgnv-table-wrap app-table-scroll evaluation-table-wrap">
    <table class="table workflow-table align-middle dgnv-table app-data-table evaluation-table">
        <thead>
            <tr>
                <th class="dgnv-col-project">Dự án</th>
                <th class="dgnv-col-employee">Nhân viên</th>
                <th>Vai trò</th>
                <th>Tiến độ</th>
                <th>Trạng thái đánh giá</th>
                <th class="text-end">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.DanhSach)
            {
                <tr>
                    <td class="dgnv-col-project">@item.TenDuAn</td>
                    <td class="dgnv-col-employee">
                        <div class="fw-semibold">@item.TenNhanVien</div>
                    </td>
                    <td>@item.VaiTroTrongDuAn</td>
                    <td>
                        <span class="small text-muted">@item.ChiTietHoanThanh/@item.TongChiTietDuocGiao | Trễ: @item.ChiTietTreHan</span>
                    </td>
                    <td>@await Html.PartialAsync("_TrangThaiDanhGiaBadge", item.TrangThaiDanhGia)</td>
                    <td class="text-end dgnv-col-actions">
                        <div class="table-actions dgnv-table-actions evaluation-table-actions">
                            @if (!item.CoDanhGia && item.CoTheDanhGia)
                            {
                                <a asp-action="Form"
                                   asp-route-maDuAn="@item.MaDuAn"
                                   asp-route-maNhanVien="@item.MaNhanVien"
                                   asp-route-tuKhoa="@Model.TuKhoa"
                                   asp-route-trangThai="@Model.TrangThai"
                                   asp-route-nguon="@Model.Nguon"
                                   asp-route-returnUrl="@effectiveReturnUrl"
                                   asp-route-tuNgayDanhGia="@Model.TuNgayDanhGia?.ToString("yyyy-MM-dd")"
                                   asp-route-denNgayDanhGia="@Model.DenNgayDanhGia?.ToString("yyyy-MM-dd")"
                                   class="btn-action btn-confirm">
                                    Đánh giá
                                </a>
                            }
                            else if (item.CoDanhGia && item.CoTheSua)
                            {
                                <a asp-action="Form"
                                   asp-route-maDuAn="@item.MaDuAn"
                                   asp-route-maNhanVien="@item.MaNhanVien"
                                   asp-route-tuKhoa="@Model.TuKhoa"
                                   asp-route-trangThai="@Model.TrangThai"
                                   asp-route-nguon="@Model.Nguon"
                                   asp-route-returnUrl="@effectiveReturnUrl"
                                   asp-route-tuNgayDanhGia="@Model.TuNgayDanhGia?.ToString("yyyy-MM-dd")"
                                   asp-route-denNgayDanhGia="@Model.DenNgayDanhGia?.ToString("yyyy-MM-dd")"
                                   class="btn-action btn-confirm">
                                    Sửa đánh giá
                                </a>
                            }
                            else if (item.CoDanhGia)
                            {
                                <a asp-action="ChiTiet" asp-route-maDanhGiaNhanVien="@item.MaDanhGiaNhanVien" asp-route-returnUrl="@effectiveReturnUrl" class="btn-action btn-subtle">Xem đánh giá</a>
                            }

                            @if (item.CoDanhGia && item.CoTheGuiDuyet)
                            {
                                <form asp-action="GuiDuyet" method="post">
                                    <input type="hidden" name="maDanhGiaNhanVien" value="@item.MaDanhGiaNhanVien" />
                                    <input type="hidden" name="maDuAn" value="@item.MaDuAn" />
                                    <input type="hidden" name="maNhanVien" value="@item.MaNhanVien" />
                                    <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
                                    <input type="hidden" name="trangThai" value="@Model.TrangThai" />
                                    <input type="hidden" name="nguon" value="@Model.Nguon" />
                                    <input type="hidden" name="returnUrl" value="@effectiveReturnUrl" />
                                    <input type="hidden" name="tuNgayDanhGia" value="@Model.TuNgayDanhGia?.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="denNgayDanhGia" value="@Model.DenNgayDanhGia?.ToString("yyyy-MM-dd")" />
                                    <button type="submit" class="btn-action btn-confirm">Gửi duyệt</button>
                                </form>
                            }
                            @if (item.CoDanhGia && item.CoTheDuyet)
                            {
                                <form asp-action="Duyet" method="post">
                                    <input type="hidden" name="maDanhGiaNhanVien" value="@item.MaDanhGiaNhanVien" />
                                    <input type="hidden" name="maDuAn" value="@item.MaDuAn" />
                                    <input type="hidden" name="maNhanVien" value="@item.MaNhanVien" />
                                    <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
                                    <input type="hidden" name="trangThai" value="@Model.TrangThai" />
                                    <input type="hidden" name="nguon" value="@Model.Nguon" />
                                    <input type="hidden" name="returnUrl" value="@effectiveReturnUrl" />
                                    <input type="hidden" name="tuNgayDanhGia" value="@Model.TuNgayDanhGia?.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="denNgayDanhGia" value="@Model.DenNgayDanhGia?.ToString("yyyy-MM-dd")" />
                                    <button type="submit" class="btn-action btn-confirm">Duyệt</button>
                                </form>
                            }
                            @if (item.CoDanhGia && item.CoTheTuChoi)
                            {
                                <form asp-action="TuChoi" method="post" class="d-flex gap-1 dgnv-reject-form">
                                    <input type="hidden" name="maDanhGiaNhanVien" value="@item.MaDanhGiaNhanVien" />
                                    <input type="hidden" name="maDuAn" value="@item.MaDuAn" />
                                    <input type="hidden" name="maNhanVien" value="@item.MaNhanVien" />
                                    <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />
                                    <input type="hidden" name="trangThai" value="@Model.TrangThai" />
                                    <input type="hidden" name="nguon" value="@Model.Nguon" />
                                    <input type="hidden" name="returnUrl" value="@effectiveReturnUrl" />
                                    <input type="hidden" name="tuNgayDanhGia" value="@Model.TuNgayDanhGia?.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="denNgayDanhGia" value="@Model.DenNgayDanhGia?.ToString("yyyy-MM-dd")" />
                                    <input type="text" name="lyDoTuChoi" class="form-control" placeholder="Lý do" required />
                                    <button type="submit" class="btn-action btn-danger-soft">Từ chối</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

