@model QuanLyDuAn.ViewModels.DanhGiaNhanVien.DanhGiaNhanVienPageViewModel

<form asp-action="Index" method="get" class="dgnv-filter">
    <div class="row g-2 align-items-end">
        <div class="col-lg-4 col-md-6">
            <label class="form-label">Từ khóa</label>
            <input type="text" name="tuKhoa" value="@Model.TuKhoa" class="form-control" placeholder="Tên dự án, tên nhân viên..." />
        </div>
        <div class="col-lg-3 col-md-6">
            <label class="form-label">Dự án</label>
            <select name="maDuAn" class="form-select">
                <option value="">Tất cả</option>
                @foreach (var duAn in Model.DanhSachDuAn)
                {
                    <option value="@duAn.MaDuAn" selected="@(Model.MaDuAn == duAn.MaDuAn)">@duAn.TenDuAn</option>
                }
            </select>
        </div>
        <div class="col-lg-3 col-md-6">
            <label class="form-label">Nhân viên</label>
            <select name="maNhanVien" class="form-select">
                <option value="">Tất cả</option>
                @foreach (var nv in Model.DanhSachNhanVien)
                {
                    <option value="@nv.MaNhanVien" selected="@(Model.MaNhanVien == nv.MaNhanVien)">@nv.TenNhanVien</option>
                }
            </select>
        </div>
        <div class="col-lg-2 col-md-6 d-grid">
            <button type="submit" class="btn btn-primary">Lọc</button>
        </div>
    </div>
</form>
