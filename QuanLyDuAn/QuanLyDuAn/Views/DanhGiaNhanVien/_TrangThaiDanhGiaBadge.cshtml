@model string

@{
    var css = "status-badge status-neutral evaluation-status-badge";
    if (string.Equals(Model, "DaDuyet", StringComparison.OrdinalIgnoreCase)) { css = "status-badge status-approved evaluation-status-badge"; }
    else if (string.Equals(Model, "ChoDuyet", StringComparison.OrdinalIgnoreCase)) { css = "status-badge status-pending evaluation-status-badge"; }
    else if (string.Equals(Model, "TuChoi", StringComparison.OrdinalIgnoreCase)) { css = "status-badge status-rejected evaluation-status-badge"; }
    else if (string.Equals(Model, "Nhap", StringComparison.OrdinalIgnoreCase)) { css = "status-badge status-draft evaluation-status-badge"; }
    else if (string.Equals(Model, "ChuaDanhGia", StringComparison.OrdinalIgnoreCase)) { css = "status-badge status-neutral evaluation-status-badge"; }

    var text = Model;
    if (string.Equals(Model, "ChuaDanhGia", StringComparison.OrdinalIgnoreCase)) { text = "Chưa đánh giá"; }
    if (string.Equals(Model, "Nhap", StringComparison.OrdinalIgnoreCase)) { text = "Nháp"; }
    else if (string.Equals(Model, "ChoDuyet", StringComparison.OrdinalIgnoreCase)) { text = "Chờ duyệt"; }
    else if (string.Equals(Model, "DaDuyet", StringComparison.OrdinalIgnoreCase)) { text = "Đã duyệt"; }
    else if (string.Equals(Model, "TuChoi", StringComparison.OrdinalIgnoreCase)) { text = "Từ chối"; }
}
<span class="@css">@text</span>
