@model QuanLyDuAn.ViewModels.Account.ForgotPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu - QuảnLýDựÁn AI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&display=swap&subset=vietnamese" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Account/login.css" asp-append-version="true" />
</head>
<body class="auth-page-body">
    <main class="auth-shell">
        <section class="auth-card card-soft">
            <div class="auth-header-block">
                <div class="auth-brand-mark">
                    <i class="bi bi-rocket-takeoff-fill"></i>
                </div>
                <h1 class="auth-system-name">Hệ Thống Quản Lý Dự Án Tích Hợp AI</h1>
            </div>

            <div class="auth-form-block">
                <h2 class="auth-card-title">Khôi phục mật khẩu</h2>
                <p class="auth-card-description">Nhập tài khoản để nhận mã xác thực.</p>

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }

                <form asp-action="ForgotPassword" method="post" class="auth-form">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger auth-validation-summary"></div>

                    <div class="mb-3">
                        <label asp-for="EmailHoacTenDangNhap" class="form-label"></label>
                        <input asp-for="EmailHoacTenDangNhap" class="form-control auth-input" autocomplete="username" placeholder="Nhập email hoặc tên đăng nhập" />
                        <span asp-validation-for="EmailHoacTenDangNhap" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary auth-submit-btn">Gửi mã OTP</button>
                    <a asp-action="Login" class="auth-secondary-link">Quay lại đăng nhập</a>
                </form>
            </div>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
