@model QuanLyDuAn.ViewModels.Account.ActivateAccountViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kích hoạt tài khoản - QuảnLýDựÁn AI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&display=swap&subset=vietnamese" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Account/login.css" asp-append-version="true" />
</head>
<body class="auth-page-body">
    <main class="auth-shell">
        <section class="auth-card card-soft">
            <div class="auth-header-block">
                <div class="auth-brand-mark">
                    <i class="bi bi-rocket-takeoff-fill"></i>
                </div>
                <h1 class="auth-system-name">Hệ Thống Quản Lý Dự Án Tích Hợp AI</h1>
            </div>

            <div class="auth-form-block">
                <h2 class="auth-card-title">Kích hoạt tài khoản</h2>
                <p class="auth-card-description">Thiết lập mật khẩu để hoàn tất kích hoạt tài khoản.</p>

                <form asp-action="Activate" method="post" class="auth-form">
                    @Html.AntiForgeryToken()
                    <input asp-for="UserId" type="hidden" />
                    <input asp-for="Token" type="hidden" />
                    <input asp-for="TenDangNhapHienThi" type="hidden" />
                    <input asp-for="EmailHienThi" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger auth-validation-summary"></div>

                    @if (!string.IsNullOrWhiteSpace(Model.TenDangNhapHienThi) || !string.IsNullOrWhiteSpace(Model.EmailHienThi))
                    {
                        <div class="mb-3 auth-card-description">
                            @if (!string.IsNullOrWhiteSpace(Model.TenDangNhapHienThi))
                            {
                                <div>Tên đăng nhập: @Model.TenDangNhapHienThi</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.EmailHienThi))
                            {
                                <div>Email: @Model.EmailHienThi</div>
                            }
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" type="password" class="form-control auth-input" autocomplete="new-password" placeholder="Nhập mật khẩu mới" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control auth-input" autocomplete="new-password" placeholder="Nhập lại mật khẩu mới" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <p class="auth-card-description">Mật khẩu cần tối thiểu 8 ký tự, gồm chữ hoa, chữ thường, số và ký tự đặc biệt.</p>

                    <button type="submit" class="btn btn-primary auth-submit-btn">Kích hoạt tài khoản</button>
                    <a asp-action="Login" class="auth-secondary-link">Quay lại đăng nhập</a>
                </form>
            </div>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
