@model QuanLyDuAn.ViewModels.Auth.DangNhapViewModel
@{
    Layout = null;
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập hệ thống - QuảnLýDựÁn AI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&display=swap&subset=vietnamese" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Account/login.css" asp-append-version="true" />
</head>
<body class="auth-page-body">
    <main class="auth-shell">
        <section class="auth-card card-soft">
            <div class="auth-header-block">
                <div class="auth-brand-mark">
                    <i class="bi bi-rocket-takeoff-fill"></i>
                </div>
                <h1 class="auth-system-name">Hệ Thống Quản Lý Dự Án Tích Hợp AI</h1>
                <p class="auth-system-note">Đăng nhập để truy cập hệ thống quản trị dự án.</p>
            </div>

            <div class="auth-form-block">
                <h2 class="auth-card-title">Đăng nhập</h2>
                <p class="auth-card-description">Vui lòng nhập thông tin tài khoản.</p>

                <form asp-action="Login" method="post" class="auth-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    <div asp-validation-summary="ModelOnly" class="text-danger auth-validation-summary"></div>

                    <div class="mb-3">
                        <label asp-for="TenDangNhap" class="form-label"></label>
                        <input asp-for="TenDangNhap" class="form-control auth-input" autocomplete="username" placeholder="Ví dụ: quantri" />
                        <span asp-validation-for="TenDangNhap" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MatKhau" class="form-label"></label>
                        <input asp-for="MatKhau" class="form-control auth-input" autocomplete="current-password" placeholder="Nhập mật khẩu" />
                        <span asp-validation-for="MatKhau" class="text-danger"></span>
                    </div>

                    <div class="auth-form-options">
                        <div class="form-check">
                            <input asp-for="GhiNhoDangNhap" class="form-check-input" />
                            <label asp-for="GhiNhoDangNhap" class="form-check-label"></label>
                        </div>
                        <a asp-action="ForgotPassword" class="auth-link">Quên mật khẩu?</a>
                    </div>

                    <button type="submit" class="btn btn-primary auth-submit-btn">Đăng nhập</button>
                </form>
            </div>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
