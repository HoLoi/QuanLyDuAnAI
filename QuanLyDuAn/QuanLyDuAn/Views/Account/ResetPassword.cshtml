@model QuanLyDuAn.ViewModels.Account.ResetPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đặt lại mật khẩu - QuảnLýDựÁn AI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&display=swap&subset=vietnamese" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Account/login.css" asp-append-version="true" />
</head>
<body class="auth-page-body">
    <main class="auth-shell">
        <section class="auth-card card-soft">
            <div class="auth-header-block">
                <div class="auth-brand-mark">
                    <i class="bi bi-rocket-takeoff-fill"></i>
                </div>
                <h1 class="auth-system-name">Hệ Thống Quản Lý Dự Án Tích Hợp AI</h1>
            </div>

            <div class="auth-form-block">
                <h2 class="auth-card-title">Đặt lại mật khẩu</h2>
                <p class="auth-card-description">Nhập mật khẩu mới cho tài khoản.</p>

                <form asp-action="ResetPassword" method="post" class="auth-form">
                    @Html.AntiForgeryToken()
                    <input asp-for="MaPhien" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger auth-validation-summary"></div>

                    <div class="mb-3">
                        <label asp-for="MatKhauMoi" class="form-label"></label>
                        <input asp-for="MatKhauMoi" class="form-control auth-input" autocomplete="new-password" placeholder="Nhập mật khẩu mới" />
                        <span asp-validation-for="MatKhauMoi" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="XacNhanMatKhau" class="form-label"></label>
                        <input asp-for="XacNhanMatKhau" class="form-control auth-input" autocomplete="new-password" placeholder="Nhập lại mật khẩu mới" />
                        <span asp-validation-for="XacNhanMatKhau" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary auth-submit-btn">Cập nhật mật khẩu</button>
                    <a asp-action="Login" class="auth-secondary-link">Quay lại đăng nhập</a>
                </form>
            </div>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
