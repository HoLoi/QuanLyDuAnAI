@inject QuanLyDuAn.Services.Interfaces.IPhanQuyenService PhanQuyenService
@using QuanLyDuAn.Constants
@using QuanLyDuAn.ViewModels.Dashboard
@using QuanLyDuAn.ViewModels.Ai
@model DashboardViewModel
@{
    ViewData["Title"] = "Thống kê tổng quan";
    var ai = ViewBag.AiDashboard as AiDashboardViewModel;
    var updatedAt = DateTime.Now.ToString("dd/MM/yyyy HH:mm");

    var grantedPermissions = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    if (User?.Identity?.IsAuthenticated == true)
    {
        grantedPermissions = await PhanQuyenService.GetGrantedPermissionNamesAsync(User!);
    }

    var canXuLyCongViecTreHan = grantedPermissions.Contains(Permissions.CongViec.Xem)
        || grantedPermissions.Contains(Permissions.TienDo.Xem);
    var canXuLyVuotNganSach = grantedPermissions.Contains(Permissions.ChiPhi.Xem)
        || grantedPermissions.Contains(Permissions.NganSach.Xem);
    var canXuLyThieuDuLieuAi = grantedPermissions.Contains(Permissions.AI.Dataset)
        || grantedPermissions.Contains(Permissions.AI.Dashboard);

    var canDuyetDeXuatCongViec = grantedPermissions.Contains(Permissions.DuyetDeXuatCongViec.Xem);
    var canDuyetDeXuatNganSach = grantedPermissions.Contains(Permissions.DuyetNganSach.Xem);
    var canDuyetDoiQuanLy = grantedPermissions.Contains(Permissions.DuyetYeuCauDoiQuanLy.Xem);

    var tongDuAn = Math.Max(Model.TongDuAn, 0);
    var hasProgressChartData = Model.TenDuAn.Any() && Model.PhanTramTienDo.Any();
    var hasCostChartData = Model.TenDuAn.Any() && Model.ChiPhiTheoDuAn.Any();

    string BuildRate(int value)
    {
        if (tongDuAn <= 0)
        {
            return "0";
        }

        var rate = (decimal)value * 100m / tongDuAn;
        return Math.Round(rate, 1, MidpointRounding.AwayFromZero).ToString("0.#");
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/Dashboard/index.css" asp-append-version="true" />
}

<div class="dashboard-overview-page">
    <section class="dashboard-header">
        <div class="dashboard-header-content">
            <h1 class="dashboard-title">Thống kê tổng quan</h1>
            <p class="dashboard-subtitle">Theo dõi tình hình dự án, công việc, nhân sự, ngân sách và cảnh báo AI</p>
        </div>
        <div class="dashboard-updated">
            <i class="bi bi-clock-history"></i>
            <span>Cập nhật mới nhất: @updatedAt</span>
        </div>
    </section>

    <section class="overview-grid">
        <article class="overview-card">
            <div class="overview-card-icon"><i class="bi bi-kanban-fill"></i></div>
            <div class="overview-card-label">Tổng dự án</div>
            <div class="overview-card-value">@Model.TongDuAn</div>
            <div class="overview-card-note">Số dự án đang quản lý trong hệ thống.</div>
        </article>

        <article class="overview-card">
            <div class="overview-card-icon"><i class="bi bi-list-task"></i></div>
            <div class="overview-card-label">Tổng công việc</div>
            <div class="overview-card-value">@Model.TongCongViec</div>
            <div class="overview-card-note">Tổng đầu việc của tất cả dự án.</div>
        </article>

        <article class="overview-card">
            <div class="overview-card-icon"><i class="bi bi-people-fill"></i></div>
            <div class="overview-card-label">Tổng nhân sự</div>
            <div class="overview-card-value">@Model.TongNhanVien</div>
            <div class="overview-card-note">Nhân sự tham gia hệ thống hiện tại.</div>
        </article>

        <article class="overview-card">
            <div class="overview-card-icon"><i class="bi bi-wallet2"></i></div>
            <div class="overview-card-label">Tổng ngân sách</div>
            <div class="overview-card-value">@Model.TongNganSach.ToString("N0")</div>
            <div class="overview-card-note">Ngân sách đã được duyệt và kích hoạt.</div>
        </article>

        <article class="overview-card">
            <div class="overview-card-icon"><i class="bi bi-cash-stack"></i></div>
            <div class="overview-card-label">Tổng chi phí đã chi</div>
            <div class="overview-card-value">@Model.TongChiPhi.ToString("N0")</div>
            <div class="overview-card-note">Tổng chi phí thực tế đã ghi nhận.</div>
        </article>

        <article class="overview-card">
            <div class="overview-card-icon"><i class="bi bi-piggy-bank-fill"></i></div>
            <div class="overview-card-label">Ngân sách còn lại</div>
            <div class="overview-card-value">@Model.NganSachConLai.ToString("N0")</div>
            <div class="overview-card-note">Phần ngân sách còn lại sau khi trừ chi phí.</div>
        </article>

        <article class="overview-card">
            <div class="overview-card-icon"><i class="bi bi-speedometer2"></i></div>
            <div class="overview-card-label">Tỷ lệ sử dụng ngân sách</div>
            <div class="overview-card-value">@Model.TyLeSuDungNganSach.ToString("0.##")%</div>
            <div class="overview-card-note">Tỷ lệ tổng chi phí so với tổng ngân sách.</div>
        </article>
    </section>

    <section class="status-section">
        <div class="section-heading">
            <h2>Trạng thái dự án</h2>
            <p>Phân bố trạng thái hiện tại của các dự án đang theo dõi.</p>
        </div>

        <div class="status-grid">
            <article class="status-pill-card">
                <div class="status-header">
                    <span>Khởi tạo</span>
                    <strong>@Model.DuAnKhoiTao</strong>
                </div>
                <div class="progress">
                    <div class="progress-bar" role="progressbar" style="width: @BuildRate(Model.DuAnKhoiTao)%"></div>
                </div>
                <small>@BuildRate(Model.DuAnKhoiTao)% tổng dự án</small>
            </article>

            <article class="status-pill-card">
                <div class="status-header">
                    <span>Đang thực hiện</span>
                    <strong>@Model.DuAnDangThucHien</strong>
                </div>
                <div class="progress">
                    <div class="progress-bar" role="progressbar" style="width: @BuildRate(Model.DuAnDangThucHien)%"></div>
                </div>
                <small>@BuildRate(Model.DuAnDangThucHien)% tổng dự án</small>
            </article>

            <article class="status-pill-card">
                <div class="status-header">
                    <span>Tạm dừng</span>
                    <strong>@Model.DuAnTamDung</strong>
                </div>
                <div class="progress">
                    <div class="progress-bar" role="progressbar" style="width: @BuildRate(Model.DuAnTamDung)%"></div>
                </div>
                <small>@BuildRate(Model.DuAnTamDung)% tổng dự án</small>
            </article>

            <article class="status-pill-card">
                <div class="status-header">
                    <span>Chờ xác nhận hoàn thành</span>
                    <strong>@Model.DuAnChoXacNhanHoanThanh</strong>
                </div>
                <div class="progress">
                    <div class="progress-bar" role="progressbar" style="width: @BuildRate(Model.DuAnChoXacNhanHoanThanh)%"></div>
                </div>
                <small>@BuildRate(Model.DuAnChoXacNhanHoanThanh)% tổng dự án</small>
            </article>

            <article class="status-pill-card">
                <div class="status-header">
                    <span>Hoàn thành</span>
                    <strong>@Model.DuAnHoanThanh</strong>
                </div>
                <div class="progress">
                    <div class="progress-bar" role="progressbar" style="width: @BuildRate(Model.DuAnHoanThanh)%"></div>
                </div>
                <small>@BuildRate(Model.DuAnHoanThanh)% tổng dự án</small>
            </article>
        </div>
    </section>

    <section class="warning-section">
        <div class="section-heading">
            <h2>Cảnh báo cần xử lý</h2>
            <p>Các điểm nóng cần theo dõi ngay trong vận hành.</p>
        </div>

        <div class="warning-grid">
            <article class="warning-card @(Model.CongViecTreHan > 0 ? "warning-card-danger" : "warning-card-ok")">
                <div class="warning-title-wrap">
                    <h3>Công việc trễ hạn</h3>
                    <span class="warning-value">@Model.CongViecTreHan</span>
                </div>
                <p class="overview-card-note">
                    @(Model.CongViecTreHan > 0 ? "Có công việc cần xử lý ngay để tránh trễ tiến độ dây chuyền." : "Ổn định. Không có công việc trễ hạn.")
                </p>
                @if (Model.CongViecTreHan > 0 && canXuLyCongViecTreHan)
                {
                    <a class="dashboard-action-btn" href="@Url.Action("Index", "CongViec", new { treHan = true })">Xem công việc trễ hạn</a>
                }
            </article>

            <article class="warning-card @(Model.NhanSuQuaTai > 0 ? "warning-card-danger" : "warning-card-ok")">
                <div class="warning-title-wrap">
                    <h3>Nhân sự quá tải</h3>
                    <span class="warning-value">@Model.NhanSuQuaTai</span>
                </div>
                <p class="overview-card-note">
                    @(Model.NhanSuQuaTai > 0 ? "Có nhân sự đang vượt ngưỡng phân công an toàn." : "Ổn định. Chưa ghi nhận tình trạng quá tải.")
                </p>
            </article>

            <article class="warning-card @(Model.DuAnVuotNganSach > 0 ? "warning-card-danger" : "warning-card-ok")">
                <div class="warning-title-wrap">
                    <h3>Dự án vượt ngân sách</h3>
                    <span class="warning-value">@Model.DuAnVuotNganSach</span>
                </div>
                <p class="overview-card-note">
                    @(Model.DuAnVuotNganSach > 0 ? "Một số dự án đã vượt hạn mức ngân sách được duyệt." : "Ổn định. Chưa có dự án vượt ngân sách.")
                </p>
                @if (Model.DuAnVuotNganSach > 0 && canXuLyVuotNganSach)
                {
                    <a class="dashboard-action-btn" href="@Url.Action("Index", "ChiPhi", new { vuotNganSach = true })">Xem chi phí liên quan</a>
                }
            </article>

            <article class="warning-card @(Model.DuAnThieuDatasetAi > 0 ? "warning-card-danger" : "warning-card-ok")">
                <div class="warning-title-wrap">
                    <h3>Thiếu dữ liệu AI</h3>
                    <span class="warning-value">@Model.DuAnThieuDatasetAi</span>
                </div>
                <p class="overview-card-note">
                    @(Model.DuAnThieuDatasetAi > 0 ? "Cần bổ sung dữ liệu để tăng chất lượng phân tích AI." : "Ổn định. Dữ liệu AI đang đầy đủ.")
                </p>
                @if (Model.DuAnThieuDatasetAi > 0 && canXuLyThieuDuLieuAi)
                {
                    <a class="dashboard-action-btn" href="@Url.Action("Index", "AiDataset", new { thieuDataset = true })">Mở dữ liệu AI</a>
                }
            </article>
        </div>
    </section>

    <section class="pending-section">
        <div class="section-heading">
            <h2>Đề xuất và yêu cầu chờ duyệt</h2>
            <p>Tổng hợp nhanh các hồ sơ đang chờ phê duyệt.</p>
        </div>

        <div class="pending-grid">
            <article class="overview-card">
                <div class="overview-card-icon"><i class="bi bi-clipboard-check"></i></div>
                <div class="overview-card-label">Đề xuất công việc chờ duyệt</div>
                <div class="overview-card-value">@Model.DeXuatCongViecChoDuyet</div>
                <div class="overview-card-note">Theo dõi các đề xuất công việc mới cần duyệt.</div>
                @if (canDuyetDeXuatCongViec)
                {
                    <a class="dashboard-action-btn" href="@Url.Action("Index", "DuyetDeXuatCongViec")">Xem duyệt</a>
                }
            </article>

            <article class="overview-card">
                <div class="overview-card-icon"><i class="bi bi-cash-coin"></i></div>
                <div class="overview-card-label">Đề xuất ngân sách chờ duyệt</div>
                <div class="overview-card-value">@Model.DeXuatNganSachChoDuyet</div>
                <div class="overview-card-note">Theo dõi các đề xuất điều chỉnh ngân sách.</div>
                @if (canDuyetDeXuatNganSach)
                {
                    <a class="dashboard-action-btn" href="@Url.Action("Index", "DuyetDeXuatNganSach")">Xem duyệt</a>
                }
            </article>

            <article class="overview-card">
                <div class="overview-card-icon"><i class="bi bi-person-check-fill"></i></div>
                <div class="overview-card-label">Yêu cầu đổi quản lý chờ duyệt</div>
                <div class="overview-card-value">@Model.YeuCauDoiQuanLyChoDuyet</div>
                <div class="overview-card-note">Yêu cầu đổi quản lý dự án đang chờ xử lý.</div>
                @if (canDuyetDoiQuanLy)
                {
                    <div class="empty-dashboard-state mt-2">Chưa có màn hình duyệt phù hợp để mở trực tiếp.</div>
                }
            </article>
        </div>
    </section>

    <section class="chart-grid">
        <article class="chart-card">
            <div class="section-heading mb-2">
                <h2>Tiến độ các dự án</h2>
            </div>
            @if (hasProgressChartData)
            {
                <div class="chart-wrapper">
                    <canvas id="progressChart"></canvas>
                </div>
            }
            else
            {
                <div class="empty-dashboard-state">Chưa có dữ liệu biểu đồ.</div>
            }
        </article>

        <article class="chart-card">
            <div class="section-heading mb-2">
                <h2>Chi phí theo dự án</h2>
            </div>
            @if (hasCostChartData)
            {
                <div class="chart-wrapper">
                    <canvas id="costChart"></canvas>
                </div>
            }
            else
            {
                <div class="empty-dashboard-state">Chưa có dữ liệu biểu đồ.</div>
            }
        </article>
    </section>

    <section class="ai-section">
        <article class="chart-card">
            <div class="section-heading mb-2">
                <h2>Cảnh báo AI mức cao</h2>
            </div>
            @if (ai == null)
            {
                <div class="empty-dashboard-state">Chưa có dữ liệu phân tích AI.</div>
            }
            else
            {
                <div class="overview-card-value">@ai.SoCanhBaoDo</div>
                <div class="overview-card-note">Số cảnh báo rủi ro cao do AI ghi nhận.</div>
            }
        </article>

        <article class="chart-card">
            <div class="section-heading mb-2">
                <h2>Nguyên nhân trễ nhiều nhất</h2>
            </div>
            @if (ai?.NguyenNhanThongKe.Any() != true)
            {
                <div class="empty-dashboard-state">Chưa có dữ liệu phân tích AI.</div>
            }
            else
            {
                <div class="d-flex flex-column gap-2">
                    @foreach (var item in ai!.NguyenNhanThongKe.Take(5))
                    {
                        <div class="suggestion-card">
                            <div class="d-flex justify-content-between align-items-center gap-2">
                                <strong>@item.NguyenNhan</strong>
                                <span class="badge text-bg-light">@item.TyLePhanTram%</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </article>
    </section>

    <section class="suggestion-section">
        <div class="section-heading">
            <h2>Gợi ý ưu tiên</h2>
            <p>Các gợi ý giúp ưu tiên hành động trong giai đoạn hiện tại.</p>
        </div>

        @if (!Model.Suggestions.Any())
        {
            <div class="empty-dashboard-state">Hiện chưa có gợi ý ưu tiên. Hệ thống đang hoạt động ổn định.</div>
        }
        else
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var s in Model.Suggestions.Take(6))
                {
                    <article class="suggestion-card">
                        <div class="d-flex justify-content-between align-items-center gap-2">
                            <strong>@s.Title</strong>
                            <span class="badge @(s.Priority == "Cao" ? "text-bg-danger" : s.Priority == "Trung bình" ? "text-bg-warning" : "text-bg-secondary")">@s.Priority</span>
                        </div>
                        <p class="mb-0 mt-2 text-muted">@s.Description</p>
                        @if (!string.IsNullOrWhiteSpace(s.ActionText) && !string.IsNullOrWhiteSpace(s.ActionUrl))
                        {
                            <a href="@s.ActionUrl" class="dashboard-action-btn mt-2">@s.ActionText</a>
                        }
                    </article>
                }
            </div>
        }
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TenDuAn ?? new List<string>()));
        const progressData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PhanTramTienDo ?? new List<int>()));
        const costData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChiPhiTheoDuAn ?? new List<decimal>()));

        const progressCanvas = document.getElementById("progressChart");
        if (progressCanvas && labels.length > 0 && progressData.length > 0) {
            new Chart(progressCanvas, {
                type: "bar",
                data: {
                    labels,
                    datasets: [{
                        label: "% hoàn thành",
                        data: progressData,
                        backgroundColor: "#6f8bff",
                        borderRadius: 8,
                        maxBarThickness: 32
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: true }
                    },
                    scales: {
                        y: { beginAtZero: true, max: 100 }
                    }
                }
            });
        }

        const costCanvas = document.getElementById("costChart");
        if (costCanvas && labels.length > 0 && costData.length > 0) {
            new Chart(costCanvas, {
                type: "line",
                data: {
                    labels,
                    datasets: [{
                        label: "Chi phí",
                        data: costData,
                        borderColor: "#03a9d9",
                        backgroundColor: "rgba(3, 169, 217, 0.16)",
                        fill: true,
                        tension: 0.3,
                        pointRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: true }
                    }
                }
            });
        }
    </script>
}
