@model QuanLyDuAn.ViewModels.ChatDuAn.ChatDuAnPageViewModel
@using System.Security.Claims

@{
    ViewData["Title"] = "Chat dự án";
}

@section Styles
{
    <link rel="stylesheet" href="~/css/ChatDuAn/index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ChatDuAn/room-list.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ChatDuAn/chat-header.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ChatDuAn/message-list.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ChatDuAn/message-item.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ChatDuAn/message-form.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ChatDuAn/empty-state.css" asp-append-version="true" />
}

<div class="chat-du-an-page app-page"
     id="chat-du-an-app"
     data-room-url="@Url.Action("Phong", "ChatDuAn")"
     data-room-batch-url="@Url.Action("PhongBatch", "ChatDuAn")"
     data-older-messages-url="@Url.Action("TinNhanCu", "ChatDuAn")"
     data-new-messages-url="@Url.Action("TinNhanMoi", "ChatDuAn")"
     data-chat-hub-url="@Url.Content("~/hubs/chat-du-an")"
     data-current-user-id="@User.FindFirstValue("MaNguoiDung")"
     data-room-empty-text="Không có phòng phù hợp."
     data-send-url="@Url.Action("GuiTinNhan", "ChatDuAn")">
    <div class="chat-realtime-status" id="chat-realtime-status" aria-live="polite">Đang kết nối...</div>
    <div class="chat-layout">
        <aside class="chat-sidebar app-section-card">
            @await Html.PartialAsync("_RoomList", Model)
        </aside>

        <section class="chat-main app-section-card" id="chat-main">
            @await Html.PartialAsync("_ChatContent", Model)
        </section>
    </div>
</div>

@section Scripts
{
    <script src="~/lib/microsoft/signalr/signalr.min.js" asp-append-version="true"></script>
    <script src="~/js/ChatDuAn/chat.js" asp-append-version="true"></script>
}

