@model QuanLyDuAn.ViewModels.ChatDuAn.ChatDuAnPageViewModel

<div class="chat-room-list">
    <form asp-action="Index" method="get" class="chat-room-search" id="chat-room-search-form">
        <input type="text"
               name="tuKhoa"
               value="@Model.TuKhoa"
               placeholder="Tìm theo dự án hoặc phòng chat..." class="form-control" />
        @if (Model.MaDuAnDangChon.HasValue)
        {
            <input type="hidden" name="maDuAn" value="@Model.MaDuAnDangChon" />
        }
        <button type="submit" class="btn btn-sm btn-outline-primary btn-action btn-filter-apply">Lọc</button>
    </form>

    <div class="chat-room-items" id="chat-room-items">
        @await Html.PartialAsync("_RoomBatch", Model.PhongBatch)
        @if (!Model.PhongBatch.DanhSachPhong.Any())
        {
            <div class="chat-room-empty app-empty-state" id="chat-room-empty">
                Không có phòng phù hợp.
            </div>
        }
        <div class="chat-room-load">
            <button type="button"
                    class="btn btn-sm btn-outline-primary"
                    id="chat-load-more-rooms"
                    @if (!Model.PhongBatch.HasMore)
                    {
                        <text>hidden</text>
                    }>
                Tải thêm phòng
            </button>
            <span class="chat-request-status" id="chat-room-status" aria-live="polite"></span>
        </div>
    </div>
</div>
