@model QuanLyDuAn.ViewModels.ChatDuAn.ChatDuAnPageViewModel

<div class="chat-room-list">
    <form asp-action="Index" method="get" class="chat-room-search">
        <input type="text"
               name="tuKhoa"
               value="@Model.TuKhoa"
               placeholder="Tìm theo dự án hoặc phòng chat..." />
        @if (Model.MaDuAnDangChon.HasValue)
        {
            <input type="hidden" name="maDuAn" value="@Model.MaDuAnDangChon" />
        }
        <button type="submit" class="btn btn-sm btn-outline-primary">Lọc</button>
    </form>

    @if (!Model.DanhSachPhong.Any())
    {
        <div class="chat-room-empty">Bạn chưa tham gia dự án nào có phòng chat.</div>
    }
    else
    {
        <div class="chat-room-items">
            @foreach (var item in Model.DanhSachPhong)
            {
                var activeClass = item.DangChon ? "active" : string.Empty;

                <a class="chat-room-item @activeClass"
                   asp-controller="ChatDuAn"
                   asp-action="Index"
                   asp-route-maDuAn="@item.MaDuAn"
                   asp-route-tuKhoa="@Model.TuKhoa">
                    <div class="room-card-header">
                        <div class="room-title">@item.TenDuAn</div>
                        @if (!string.IsNullOrWhiteSpace(item.TrangThaiDuAn))
                        {
                            <span class="room-status">@item.TrangThaiDuAn</span>
                        }
                    </div>

                    <div class="room-subtitle">@item.TenPhong</div>

                    <div class="room-latest">
                        @(string.IsNullOrWhiteSpace(item.TinNhanMoiNhat) ? "Chưa có tin nhắn" : item.TinNhanMoiNhat)
                    </div>

                    <div class="room-meta">
                        <span class="meta-pill">
                            <i class="bi bi-people"></i>
                            @item.SoThanhVien thành viên
                        </span>

                        <span class="meta-pill">
                            <i class="bi bi-chat-dots"></i>
                            @item.SoTinNhan tin
                        </span>

                        @if (item.ThoiGianTinNhanMoiNhat.HasValue)
                        {
                            <span class="meta-pill">
                                <i class="bi bi-clock"></i>
                                @item.ThoiGianTinNhanMoiNhat.Value.ToString("dd/MM/yyyy HH:mm")
                            </span>
                        }
                    </div>
                </a>
            }
        </div>
    }
</div>
