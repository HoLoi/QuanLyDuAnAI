@model QuanLyDuAn.ViewModels.ChatDuAn.ChatDuAnPageViewModel
@using QuanLyDuAn.Constants

@{
    var canShowForm = Model.CoTheGuiTinNhan
                      && Model.PhongDangChon != null
                      && Model.Permissions.Contains(Permissions.Chat.Gui);
}

<div class="chat-message-form">
    @if (canShowForm)
    {
        <form asp-action="GuiTinNhan" method="post" class="chat-message-form-inner" id="chat-message-form">
            <input type="hidden" name="MaPhongChat" value="@Model.PhongDangChon!.MaPhongChat" />
            <input type="hidden" name="MaDuAn" value="@Model.PhongDangChon!.MaDuAn" />
            <input type="hidden" name="maDuAn" value="@Model.PhongDangChon!.MaDuAn" />
            <input type="hidden" name="tuKhoa" value="@Model.TuKhoa" />

            <div class="message-form-row">
                <textarea name="NoiDungTinNhan"
                          rows="2"
                          maxlength="2000"
                          placeholder="Nhập nội dung trao đổi..."
                          class="message-input form-control"></textarea>
                <button type="submit" class="btn btn-primary message-submit btn-action btn-confirm">Gửi</button>
            </div>
            <div class="chat-request-status" id="chat-send-status" aria-live="polite"></div>
        </form>
    }
    else
    {
        <div class="chat-send-disabled app-empty-state">
            Bạn không có quyền gửi tin nhắn trong phòng chat này.
        </div>
    }
</div>
