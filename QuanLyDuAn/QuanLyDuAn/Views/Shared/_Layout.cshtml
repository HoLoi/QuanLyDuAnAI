@inject QuanLyDuAn.Services.Interfaces.IPhanQuyenService PhanQuyenService
@using QuanLyDuAn.Constants
@{
    var isAuthenticated = User?.Identity?.IsAuthenticated == true;
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var pageTitle = ViewData["Title"]?.ToString();
    var resolvedPageTitle = string.IsNullOrWhiteSpace(pageTitle) ? "Hệ thống quản lý dự án" : pageTitle.Trim();
    var userName = User?.Identity?.Name ?? "Người dùng";
    var userInitial = !string.IsNullOrWhiteSpace(userName) ? userName.Trim()[0].ToString().ToUpperInvariant() : "U";
    var isAdmin = User?.IsInRole("Admin") == true || User?.IsInRole("ADMIN") == true;
    var grantedPermissions = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

    if (isAuthenticated)
    {
        grantedPermissions = await PhanQuyenService.GetGrantedPermissionNamesAsync(User!);
    }

    

    // ===== HỆ THỐNG =====
    var canDashboard = grantedPermissions.Contains(Permissions.ThongKe.Xem);
    var canChucDanh = grantedPermissions.Contains(Permissions.ChucDanh.Xem);
    var canNhanSu = grantedPermissions.Contains(Permissions.NhanSu.Xem);
    var canNhom = grantedPermissions.Contains(Permissions.Nhom.Xem);
    var canPhanQuyen = grantedPermissions.Contains(Permissions.PhanQuyen.Xem);
    var canDuyetDoiQuanLy = grantedPermissions.Contains(Permissions.DuyetYeuCauDoiQuanLy.Xem);

    // ===== DỰ ÁN =====
    var canDuAn = grantedPermissions.Contains(Permissions.DuAn.Xem);

    // ===== CÔNG VIỆC =====
    var canDanhMuc = grantedPermissions.Contains(Permissions.DanhMucCongViec.Xem);
    var canCongViec = grantedPermissions.Contains(Permissions.CongViec.Xem);
    var canTienDo = grantedPermissions.Contains(Permissions.TienDo.Xem);
    var canDeXuat = grantedPermissions.Contains(Permissions.DeXuatCongViec.Xem);
    var canDuyetDeXuat = grantedPermissions.Contains(Permissions.DuyetDeXuatCongViec.Xem);

    // ===== TÀI CHÍNH =====
    var canNganSach = grantedPermissions.Contains(Permissions.NganSach.Xem);
    var canDeXuatNganSach = grantedPermissions.Contains(Permissions.DeXuatNganSach.Xem);
    var canDuyetNganSach = grantedPermissions.Contains(Permissions.DuyetNganSach.Xem);
    var canChiPhi = grantedPermissions.Contains(Permissions.ChiPhi.Xem);

    // ===== AI =====
    var canAiDataset = grantedPermissions.Contains(Permissions.AI.Dataset);
    var canAiTrain = grantedPermissions.Contains(Permissions.AI.Train);
    var canAiAnalyzeReason = grantedPermissions.Contains(Permissions.AI.PhanTichNguyenNhan);
    var canAiDashboard = grantedPermissions.Contains(Permissions.AI.Dashboard);

    // ===== KHÁC =====
    var canDanhGiaDuAn = grantedPermissions.Contains(Permissions.DanhGiaDuAn.Xem);
    var canDanhGiaNhanVien = grantedPermissions.Contains(Permissions.DanhGiaNhanVien.Xem);
    var canDanhGiaNhanVienDocLap = canDanhGiaNhanVien && !canDanhGiaDuAn;
    var canChat = grantedPermissions.Contains(Permissions.Chat.Xem);
    var canChatDuAn = canChat && !isAdmin;
    var canNhatKy = grantedPermissions.Contains(Permissions.NhatKy.Xem);

    bool IsActiveController(string controllerName) =>
        string.Equals(currentController, controllerName, StringComparison.OrdinalIgnoreCase);

    bool IsActiveRoute(string controllerName, string actionName) =>
        IsActiveController(controllerName) &&
        string.Equals(currentAction, actionName, StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@resolvedPageTitle - QuanLyDuAnAI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&display=swap&subset=vietnamese" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QuanLyDuAn.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout/sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/TaiKhoanCaNhan/index.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(isAuthenticated ? "layout-authenticated" : "layout-guest")">
    <div class="app-shell">
        @if (isAuthenticated)
        {
            <aside class="app-sidebar" id="appSidebar">
                <a asp-controller="Dashboard" asp-action="Index" class="brand-wrap text-decoration-none">
                    <span class="brand-logo"><i class="bi bi-rocket-takeoff-fill"></i></span>
                    <div>
                        <h1 class="brand-title">QuanLyDuAn AI</h1>
                        <p class="brand-subtitle">Project Intelligence</p>
                    </div>
                </a>

                <nav class="side-nav sidebar-menu">
                    @if (canDashboard || canNhanSu || canChucDanh || canNhom || canPhanQuyen)
                    {
                        <div class="sidebar-section">
                            <div class="sidebar-section-title">HỆ THỐNG</div>

                            @if (canDashboard)
                            {
                                <a asp-controller="Dashboard" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("Dashboard") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-grid"></i></span>
                                    <span class="sidebar-menu-text">Dashboard</span>
                                </a>
                            }

                            @if (canNhanSu)
                            {
                                <a asp-controller="NhanSu" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("NhanSu") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-people"></i></span>
                                    <span class="sidebar-menu-text">Nhân sự</span>
                                </a>
                            }

                            @if (canChucDanh)
                            {
                                <a asp-controller="ChucDanh" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("ChucDanh") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-person-badge"></i></span>
                                    <span class="sidebar-menu-text">Chức danh</span>
                                </a>
                            }

                            @if (canNhom)
                            {
                                <a asp-controller="Team" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("Team") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-people-fill"></i></span>
                                    <span class="sidebar-menu-text">Team</span>
                                </a>
                            }

                            @if (canPhanQuyen)
                            {
                                <a asp-controller="PhanQuyen" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("PhanQuyen") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-shield-lock"></i></span>
                                    <span class="sidebar-menu-text">Phân quyền</span>
                                </a>
                            }
                        </div>
                    }

                    @if (canDuAn || canDuyetDoiQuanLy)
                    {
                        <div class="sidebar-section">
                            <div class="sidebar-section-title">DỰ ÁN</div>

                            @if (canDuAn)
                            {
                                <a asp-controller="DuAn" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("DuAn") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-kanban"></i></span>
                                    <span class="sidebar-menu-text">Dự án</span>
                                </a>
                            }
                            @if (canDuyetDoiQuanLy)
                            {
                                <a asp-controller="DuyetYeuCauDoiQuanLy" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("DuyetYeuCauDoiQuanLy") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-person-check"></i></span>
                                    <span class="sidebar-menu-text">Duyệt yêu cầu đổi quản lý</span>
                                </a>
                            }
                        </div>
                    }

                    @if (canCongViec || canDeXuat || canDuyetDeXuat || canTienDo)
                    {
                        <div class="sidebar-section">
                            <div class="sidebar-section-title">CÔNG VIỆC</div>

                            @if (canDuyetDeXuat)
                            {
                                <a asp-controller="DuyetDeXuatCongViec" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("DuyetDeXuatCongViec") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-check-circle"></i></span>
                                    <span class="sidebar-menu-text">Duyệt công việc</span>
                                </a>
                            }

                            @if (canCongViec)
                            {
                                <a asp-controller="CongViec" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("CongViec") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-list-task"></i></span>
                                    <span class="sidebar-menu-text">Công việc</span>
                                </a>
                            }

                            @if (canTienDo)
                            {
                                <a asp-controller="TienDoCongViec" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("TienDoCongViec") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-graph-up-arrow"></i></span>
                                    <span class="sidebar-menu-text">Tiến độ</span>
                                </a>
                            }
                        </div>
                    }

                    @if (canDeXuatNganSach || canDuyetNganSach || canNganSach || canChiPhi)
                    {
                        <div class="sidebar-section">
                            <div class="sidebar-section-title">TÀI CHÍNH</div>

                            @if (canDuyetNganSach)
                            {
                                <a asp-controller="DuyetDeXuatNganSach" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("DuyetDeXuatNganSach") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-check2-square"></i></span>
                                    <span class="sidebar-menu-text">Duyệt ngân sách</span>
                                </a>
                            }

                            @if (canNganSach)
                            {
                                <a asp-controller="NganSach" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("NganSach") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-wallet2"></i></span>
                                    <span class="sidebar-menu-text">Ngân sách</span>
                                </a>
                            }

                            @if (canChiPhi)
                            {
                                <a asp-controller="ChiPhi" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("ChiPhi") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-cash-stack"></i></span>
                                    <span class="sidebar-menu-text">Chi phí</span>
                                </a>
                            }
                        </div>
                    }

                    @if (canDanhGiaDuAn || canDanhGiaNhanVienDocLap)
                    {
                        <div class="sidebar-section">
                            <div class="sidebar-section-title">ĐÁNH GIÁ</div>

                            @if (canDanhGiaDuAn)
                            {
                                <a asp-controller="DanhGiaDuAn" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("DanhGiaDuAn") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-clipboard2-check"></i></span>
                                    <span class="sidebar-menu-text">Đánh giá dự án</span>
                                </a>
                            }

                            @if (canDanhGiaNhanVienDocLap)
                            {
                                <a asp-controller="DanhGiaNhanVien" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("DanhGiaNhanVien") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-person-check"></i></span>
                                    <span class="sidebar-menu-text">Đánh giá nhân viên</span>
                                </a>
                            }
                        </div>
                    }

                    @if (canChatDuAn)
                    {
                        <div class="sidebar-section">
                            <div class="sidebar-section-title">TRAO ĐỔI</div>
                            <a asp-controller="ChatDuAn" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("ChatDuAn") ? "active sidebar-active" : string.Empty)">
                                <span class="sidebar-menu-icon"><i class="bi bi-chat-dots"></i></span>
                                <span class="sidebar-menu-text">Chat dự án</span>
                            </a>
                        </div>
                    }

                    @if (canAiDataset || canAiTrain || canAiAnalyzeReason || canAiDashboard)
                    {
                        <div class="sidebar-section">
                            <div class="sidebar-section-title">AI</div>

                            @if (canAiDataset)
                            {
                                <a asp-controller="AiDataset" asp-action="Index" class="side-link sidebar-menu-link @(IsActiveController("AiDataset") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-database"></i></span>
                                    <span class="sidebar-menu-text">Dữ liệu AI</span>
                                </a>
                            }
                            @if (canAiTrain)
                            {
                                <a asp-controller="Ai" asp-action="Train" class="side-link sidebar-menu-link @(IsActiveRoute("Ai", "Train") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-cpu"></i></span>
                                    <span class="sidebar-menu-text">Huấn luyện nguyên nhân trễ</span>
                                </a>
                                <a asp-controller="Ai" asp-action="Models" class="side-link sidebar-menu-link @(IsActiveRoute("Ai", "Models") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-diagram-3"></i></span>
                                    <span class="sidebar-menu-text">Model nguyên nhân</span>
                                </a>
                            }
                            @if (canAiAnalyzeReason)
                            {
                                <a asp-controller="Ai" asp-action="Predict" class="side-link sidebar-menu-link @(IsActiveRoute("Ai", "Predict") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-graph-up"></i></span>
                                    <span class="sidebar-menu-text">Phân tích nguyên nhân trễ</span>
                                </a>
                            }
                            @if (canAiDashboard)
                            {
                                <a asp-controller="Ai" asp-action="Dashboard" class="side-link sidebar-menu-link @(IsActiveRoute("Ai", "Dashboard") ? "active sidebar-active" : string.Empty)">
                                    <span class="sidebar-menu-icon"><i class="bi bi-speedometer2"></i></span>
                                    <span class="sidebar-menu-text">Tổng quan AI</span>
                                </a>
                            }
                        </div>
                    }
                </nav>
            </aside>
            <button type="button" class="sidebar-backdrop" data-sidebar-dismiss aria-label="Đóng menu"></button>
        }

        <div class="app-main">
            <header class="app-topbar @(isAuthenticated ? string.Empty : "app-topbar-guest")">
                <div>
                    <h2 class="page-title mb-0">@resolvedPageTitle</h2>
                    @if (!isAuthenticated)
                    {
                        <p class="text-muted mb-0 small">Đăng nhập để truy cập hệ thống quản lý dự án.</p>
                    }
                </div>
                <div class="d-flex align-items-center gap-3">
                    @if (isAuthenticated)
                    {
                        <button type="button" class="sidebar-toggle d-lg-none" data-sidebar-toggle aria-label="Mở menu">
                            <i class="bi bi-list"></i>
                        </button>
                        <div class="tai-khoan-dropdown" data-account-dropdown>
                            <button type="button" class="tai-khoan-toggle" data-account-toggle aria-label="Mở menu tài khoản" aria-expanded="false">
                                <span class="tai-khoan-avatar">@userInitial</span>
                                <span class="tai-khoan-name">@userName</span>
                                <i class="bi bi-chevron-down"></i>
                            </button>

                            <div class="tai-khoan-menu" data-account-menu>
                                <a asp-controller="TaiKhoanCaNhan" asp-action="Index" class="tai-khoan-menu-item">
                                    <i class="bi bi-person-badge"></i>
                                    Hồ sơ cá nhân
                                </a>
                                <a asp-controller="TaiKhoanCaNhan" asp-action="DoiMatKhau" class="tai-khoan-menu-item">
                                    <i class="bi bi-key"></i>
                                    Đổi mật khẩu
                                </a>
                                <div class="tai-khoan-menu-divider"></div>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="tai-khoan-menu-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="tai-khoan-menu-item danger">
                                        <i class="bi bi-box-arrow-right"></i>
                                        Đăng xuất
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-primary" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                    }
                </div>
            </header>

            <main class="app-content @(isAuthenticated ? string.Empty : "app-content-guest")">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }
                @if (TempData["Warning"] != null)
                {
                    <div class="alert alert-warning">
                        <div>@TempData["Warning"]</div>
                        @if (TempData["NextActionText"] != null && TempData["NextActionUrl"] != null)
                        {
                            <a class="alert-link" href="@TempData["NextActionUrl"]">@TempData["NextActionText"]</a>
                        }
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <script>
        (function () {
            var toggleButtons = document.querySelectorAll("[data-sidebar-toggle]");
            var dismissButtons = document.querySelectorAll("[data-sidebar-dismiss]");
            var accountDropdown = document.querySelector("[data-account-dropdown]");
            var accountToggle = document.querySelector("[data-account-toggle]");

            function setSidebarState(isOpen) {
                document.body.classList.toggle("sidebar-open", isOpen);
            }

            function setAccountMenuState(isOpen) {
                if (!accountDropdown || !accountToggle) {
                    return;
                }

                accountDropdown.classList.toggle("open", isOpen);
                accountToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
            }

            toggleButtons.forEach(function (button) {
                button.addEventListener("click", function () {
                    setSidebarState(!document.body.classList.contains("sidebar-open"));
                });
            });

            dismissButtons.forEach(function (button) {
                button.addEventListener("click", function () {
                    setSidebarState(false);
                });
            });

            if (accountDropdown && accountToggle) {
                accountToggle.addEventListener("click", function (event) {
                    event.preventDefault();
                    event.stopPropagation();
                    setAccountMenuState(!accountDropdown.classList.contains("open"));
                });

                document.addEventListener("click", function (event) {
                    if (!accountDropdown.contains(event.target)) {
                        setAccountMenuState(false);
                    }
                });
            }

            document.addEventListener("keydown", function (event) {
                if (event.key === "Escape") {
                    setSidebarState(false);
                    setAccountMenuState(false);
                }
            });

            window.addEventListener("resize", function () {
                if (window.innerWidth >= 992) {
                    setSidebarState(false);
                }
            });
        })();
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
