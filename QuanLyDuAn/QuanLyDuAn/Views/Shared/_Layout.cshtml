@inject QuanLyDuAn.Services.Interfaces.IPhanQuyenService PhanQuyenService
@using QuanLyDuAn.Constants
@{
    var isAuthenticated = User?.Identity?.IsAuthenticated == true;
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    var pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";
    var userName = User?.Identity?.Name ?? "Người dùng";
    var grantedPermissions = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

    if (isAuthenticated)
    {
        grantedPermissions = await PhanQuyenService.GetGrantedPermissionNamesAsync(User!);
    }

    bool CanAccess(params string[] keys) => keys.Any(x => grantedPermissions.Contains(x));

    // ===== HỆ THỐNG =====
    var canDashboard = CanAccess(Permissions.ThongKe.Xem);
    var canChucDanh = CanAccess(Permissions.ChucDanh.Xem);
    var canNhanSu = CanAccess(Permissions.NhanSu.Xem);
    var canNhom = CanAccess(Permissions.Nhom.Xem);
    var canPhanQuyen = CanAccess(Permissions.PhanQuyen.Xem);
    var canDuyetDoiQuanLy = CanAccess(Permissions.DuyetYeuCauDoiQuanLy.Xem);

    // ===== DỰ ÁN =====
    var canDuAn = CanAccess(Permissions.DuAn.Xem);

    // ===== CÔNG VIỆC =====
    var canDanhMuc = CanAccess(Permissions.DanhMucCongViec.Xem);
    var canCongViec = CanAccess(Permissions.CongViec.Xem);
    var canPhanCong = CanAccess(Permissions.PhanCong.Xem);
    var canTienDo = CanAccess(Permissions.TienDo.Xem);
    var canDeXuat = CanAccess(Permissions.DeXuatCongViec.Xem);
    var canDuyetDeXuat = CanAccess(Permissions.DuyetDeXuatCongViec.Xem);

    // ===== TÀI CHÍNH =====
    var canNganSach = CanAccess(Permissions.NganSach.Xem);
    var canDeXuatNganSach = CanAccess(Permissions.DeXuatNganSach.Xem);
    var canDuyetNganSach = CanAccess(Permissions.DuyetNganSach.Xem);
    var canChiPhi = CanAccess(Permissions.ChiPhi.Xem);

    // ===== AI =====
    var canAiDataset = CanAccess(Permissions.AI.Dataset);
    var canAiTrain = CanAccess(Permissions.AI.Train);
    var canAiPredict = CanAccess(Permissions.AI.DuDoan);
    var canAiDashboard = CanAccess(Permissions.AI.Dashboard);

    // ===== KHÁC =====
    var canDanhGiaDuAn = CanAccess(Permissions.DanhGiaDuAn.Xem);
    var canDanhGiaNhanVien = CanAccess(Permissions.DanhGiaNhanVien.Xem);
    var canChat = CanAccess(Permissions.Chat.Xem);
    var canNhatKy = CanAccess(Permissions.NhatKy.Xem);
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - QuanLyDuAnAI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&display=swap&subset=vietnamese" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QuanLyDuAn.styles.css" asp-append-version="true" />
</head>
<body class="@(isAuthenticated ? "layout-authenticated" : "layout-guest")">
    <div class="app-shell">
        @if (isAuthenticated)
        {
            <aside class="app-sidebar">
                <a asp-controller="Dashboard" asp-action="Index" class="brand-wrap text-decoration-none">
                    <span class="brand-logo"><i class="bi bi-rocket-takeoff-fill"></i></span>
                    <div>
                        <h1 class="brand-title">QuanLyDuAn AI</h1>
                        <p class="brand-subtitle">Project Intelligence</p>
                    </div>
                </a>

                <nav class="side-nav">
                    @if (canDashboard || canNhanSu || canChucDanh || canNhom || canPhanQuyen || canDuyetDoiQuanLy)
                    {
                        <div class="text-uppercase text-muted small fw-bold mt-1 mb-1">Hệ thống</div>

                        @if (canDashboard)
                        {
                            <a asp-controller="Dashboard" asp-action="Index" class="side-link"><i class="bi bi-grid"></i> Dashboard</a>
                        }

                        @if (canNhanSu)
                        {
                            <a asp-controller="NhanSu" asp-action="Index" class="side-link"><i class="bi bi-people"></i> Nhân sự</a>
                        }

                        @if (canChucDanh)
                        {
                            <a asp-controller="ChucDanh" asp-action="Index" class="side-link"><i class="bi bi-person-badge"></i> Chức danh</a>
                        }

                        @if (canNhom)
                        {
                            <a asp-controller="Team" asp-action="Index" class="side-link"><i class="bi bi-people-fill"></i> Team</a>
                        }

                        @if (canPhanQuyen)
                        {
                            <a asp-controller="PhanQuyen" asp-action="Index" class="side-link"><i class="bi bi-shield-lock"></i> Phân quyền</a>
                        }

                        @if (canDuyetDoiQuanLy)
                        {
                            <a asp-controller="DoiQuanLy" asp-action="Index" class="side-link"><i class="bi bi-person-check"></i> Duyệt đổi quản lý</a>
                        }
                    }

                    @if (canDuAn)
                    {
                        <div class="text-uppercase text-muted small fw-bold mt-3 mb-1">Dự án</div>

                        @if (canDuAn)
                        {
                            <a asp-controller="DuAn" asp-action="Index" class="side-link">
                                <i class="bi bi-kanban"></i> Dự án
                            </a>
                        }
                    }

                    @if (canCongViec || canDeXuat || canDuyetDeXuat || canPhanCong || canTienDo)
                    {
                        <div class="text-uppercase text-muted small fw-bold mt-3 mb-1">Công việc</div>

                        @if (canDuyetDeXuat)
                        {
                            <a asp-controller="DuyetDeXuatCongViec" asp-action="Index" class="side-link">
                                <i class="bi bi-check-circle"></i> Duyệt công việc
                            </a>
                        }

                        @if (canCongViec)
                        {
                            <a asp-controller="CongViec" asp-action="Index" class="side-link">
                                <i class="bi bi-list-task"></i> Công việc
                            </a>
                        }

                        @if (canPhanCong)
                        {
                            <a asp-controller="PhanCong" asp-action="Index" class="side-link">
                                <i class="bi bi-person-check"></i> Phân công
                            </a>
                        }

                        @if (canTienDo)
                        {
                            <a asp-controller="TienDo" asp-action="Index" class="side-link">
                                <i class="bi bi-graph-up-arrow"></i> Tiến độ
                            </a>
                        }
                    }

                    @if (canDeXuatNganSach || canDuyetNganSach || canNganSach || canChiPhi)
                    {
                        <div class="text-uppercase text-muted small fw-bold mt-3 mb-1">Tài chính</div>

                        @if (canDuyetNganSach)
                        {
                            <a asp-controller="DuyetDeXuatNganSach" asp-action="Index" class="side-link">
                                <i class="bi bi-check2-square"></i> Duyệt ngân sách
                            </a>
                        }

                        @if (canNganSach)
                        {
                            <a asp-controller="NganSach" asp-action="Index" class="side-link">
                                <i class="bi bi-wallet2"></i> Ngân sách
                            </a>
                        }

                        @if (canChiPhi)
                        {
                            <a asp-controller="ChiPhi" asp-action="Index" class="side-link">
                                <i class="bi bi-cash-stack"></i> Chi phí
                            </a>
                        }
                    }

                    @if (canAiDataset || canAiTrain || canAiPredict || canAiDashboard)
                    {
                        <div class="text-uppercase text-muted small fw-bold mt-3 mb-1">AI</div>

                        @if (canAiDataset)
                        {
                            <a asp-controller="AiDataset" asp-action="Index" class="side-link">Dataset</a>
                        }
                        @if (canAiTrain)
                        {
                            <a asp-controller="Ai" asp-action="Train" class="side-link">Train</a>
                        }
                        @if (canAiPredict)
                        {
                            <a asp-controller="Ai" asp-action="Predict" class="side-link">Predict</a>
                        }
                        @if (canAiDashboard)
                        {
                            <a asp-controller="Ai" asp-action="Dashboard" class="side-link">Dashboard</a>
                        }
                    }
                </nav>
            </aside>
        }

        <div class="app-main">
            <header class="app-topbar @(isAuthenticated ? string.Empty : "app-topbar-guest")">
                <div>
                    <h2 class="page-title mb-0">@pageTitle</h2>
                    @if (!isAuthenticated)
                    {
                        <p class="text-muted mb-0 small">Đăng nhập để truy cập hệ thống quản lý dự án.</p>
                    }
                </div>
                <div class="d-flex align-items-center gap-3">
                    @if (isAuthenticated)
                    {
                        <span class="user-chip">
                            <i class="bi bi-person-circle"></i>
                            @userName
                        </span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Đăng xuất</button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-primary" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                    }
                </div>
            </header>

            <main class="app-content @(isAuthenticated ? string.Empty : "app-content-guest")">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }
                @if (TempData["Warning"] != null)
                {
                    <div class="alert alert-warning">
                        <div>@TempData["Warning"]</div>
                        @if (TempData["NextActionText"] != null && TempData["NextActionUrl"] != null)
                        {
                            <a class="alert-link" href="@TempData["NextActionUrl"]">@TempData["NextActionText"]</a>
                        }
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
