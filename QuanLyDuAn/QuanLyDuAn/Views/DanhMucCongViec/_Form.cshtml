@model QuanLyDuAn.ViewModels.DanhMucCongViec.DanhMucCongViecCreateUpdateViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = ViewBag.Permissions as HashSet<string> ?? new();
    var tenDuAn = ViewBag.TenDuAn as string ?? string.Empty;
}

<form asp-action="LuuDanhMucCongViec" method="post" class="danh-muc-entry-form">
    <input asp-for="MaDanhMucCV" type="hidden" />
    <input type="hidden" name="TuKhoa" value="@ViewBag.TuKhoa" />
    <input type="hidden" name="LocMaDuAn" value="@ViewBag.LocMaDuAn" />

    <div class="row g-3">
        <div class="col-md-6">
            <label>Dự án</label>
            <input class="form-control" value="@tenDuAn" readonly />
            <input asp-for="MaDuAn" type="hidden" />
            <span asp-validation-for="MaDuAn" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label>Tên danh mục công việc</label>
            <input asp-for="TenDanhMucCV" class="form-control" required />
            <span asp-validation-for="TenDanhMucCV" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label>Mô tả</label>
            <textarea asp-for="MoTaDanhMucCV" class="form-control" rows="3" required></textarea>
            <span asp-validation-for="MoTaDanhMucCV" class="text-danger"></span>
        </div>
    </div>

    <div class="danh-muc-form-actions">
        @if (permissions.Contains(Permissions.DanhMucCongViec.Them) || permissions.Contains(Permissions.DanhMucCongViec.Sua))
        {
            <button type="submit" class="btn danh-muc-btn-primary">Lưu</button>
        }

        <a asp-action="Index" class="btn danh-muc-btn-secondary">Làm mới</a>
    </div>
</form>
