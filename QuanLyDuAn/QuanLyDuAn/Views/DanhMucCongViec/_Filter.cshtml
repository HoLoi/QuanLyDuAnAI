@model QuanLyDuAn.ViewModels.DanhMucCongViec.DanhMucCongViecPageViewModel

<form asp-action="Index" method="get" class="danh-muc-filter-form">
    <input type="hidden" name="locMaDuAn" value="@Model.LocMaDuAn" />

    <div class="row g-3 align-items-end">
        <div class="col-lg-7 col-md-6">
            <label class="form-label">Từ khóa</label>
            <input type="text"
                   name="tuKhoa"
                   value="@Model.TuKhoa"
                   class="form-control"
                   placeholder="Tìm theo tên danh mục, mô tả..." />
        </div>

        <div class="col-lg-5 col-md-6">
            <div class="danh-muc-filter-actions">
                <button type="submit" class="btn danh-muc-btn-primary">Lọc</button>
                <a asp-action="Index" asp-route-locMaDuAn="@Model.LocMaDuAn" class="btn danh-muc-btn-secondary">Làm mới</a>
            </div>
        </div>
    </div>
</form>
