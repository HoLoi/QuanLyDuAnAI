@model QuanLyDuAn.ViewModels.DanhMucCongViec.DanhMucCongViecPageViewModel
@using QuanLyDuAn.Constants

@{
    var permissions = Model.Permissions;
    bool canShowForm = Model.CoTheThemDanhMuc || Model.CoTheSuaDanhMuc;
    var hasValidationErrors = ViewData.ModelState.Values.Any(v => v.Errors.Count > 0);

    ViewBag.Permissions = permissions;
    ViewBag.DanhSachDuAn = Model.DanhSachDuAn;
    ViewBag.TenDuAn = Model.TenDuAn;
    ViewBag.TuKhoa = Model.TuKhoa;
    ViewBag.LocMaDuAn = Model.LocMaDuAn;
    ViewBag.CoTheThemDanhMuc = Model.CoTheThemDanhMuc;
    ViewBag.CoTheSuaDanhMuc = Model.CoTheSuaDanhMuc;
    ViewBag.CoTheXoaDanhMuc = Model.CoTheXoaDanhMuc;
}

@section Styles {
    <link rel="stylesheet" href="~/css/DanhMucCongViec/index.css" asp-append-version="true" />
}

<div class="danh-muc-page">
    <section class="danh-muc-header-card">
        <div>
            <h2 class="danh-muc-title">Quản lý danh mục công việc</h2>
            <p class="danh-muc-subtitle">Theo dõi và quản lý các danh mục công việc theo từng dự án.</p>
        </div>
        <a asp-controller="DuAn" asp-action="Index" class="btn danh-muc-back-btn">Quay lại dự án</a>
    </section>

    @if (hasValidationErrors)
    {
        <div asp-validation-summary="All" class="text-danger danh-muc-validation-summary"></div>
    }

    @if (canShowForm)
    {
        <section class="danh-muc-section-card danh-muc-form-card">
            <div class="danh-muc-section-head">
                <h3 class="danh-muc-section-title">Thông tin danh mục</h3>
                <p class="danh-muc-section-note">Thêm mới hoặc cập nhật danh mục công việc cho dự án.</p>
            </div>
            <partial name="_Form" for="Form" />
        </section>
    }

    <section class="danh-muc-section-card danh-muc-filter-card">
        <div class="danh-muc-section-head">
            <h3 class="danh-muc-section-title">Bộ lọc</h3>
            <p class="danh-muc-section-note">Lọc nhanh danh mục theo từ khóa.</p>
        </div>
        <partial name="_Filter" model="Model" />
    </section>

    <section class="danh-muc-section-card danh-muc-table-card">
        <div class="danh-muc-section-head">
            <h3 class="danh-muc-section-title">Danh sách danh mục</h3>
            <p class="danh-muc-section-note">Danh sách các danh mục công việc hiện có trong dự án.</p>
        </div>
        <partial name="_Table" model="Model.DanhSach" />
        <partial name="_Pagination" model="Model.Pagination" />
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
