@startuml
' title Đánh giá dự án

start
partition "Quản lý dự án" {
  :Mở màn hình đánh giá dự án;
  :Chọn dự án đủ điều kiện;
  :Nhập điểm và nhận xét theo tiêu chí;
  :Lưu nháp hoặc gửi duyệt;
}

partition "Hệ thống MVC" {
  :Kiểm tra đăng nhập;
  :Kiểm tra Permissions.DanhGiaDuAn.Xem/DanhGia/Sua;
  :Kiểm tra phạm vi dự án quản lý;
  :Chỉ cho gửi duyệt khi dự án Hoàn thành, Chờ xác nhận hoàn thành hoặc Lưu trữ;
  :Validate điểm, nhận xét và trạng thái đánh giá;
  if (Hợp lệ?) then (Có)
    :Tính tổng điểm và trạng thái đánh giá;
  else (Không)
    :Trả lỗi validation về form;
    stop
  endif
}

partition "Cơ sở dữ liệu" {
  :Thêm hoặc cập nhật DANH_GIA_DU_AN;
  :Xóa và ghi lại CT_DANH_GIA_DU_AN theo tiêu chí;
  if (Gửi duyệt?) then (Có)
    :Cập nhật TrangThaiDanhGiaDA = Chờ duyệt;
  else (Lưu nháp)
    :Giữ trạng thái Nhập hoặc Từ chối để chỉnh sửa;
  endif
}

partition "Quản trị viên" {
  :Mở danh sách đánh giá dự án chờ duyệt;
  :Duyệt hoặc từ chối;
}

partition "Hệ thống MVC" {
  :Kiểm tra Permissions.DanhGiaDuAn.Duyet;
  :Chỉ duyệt/từ chối đánh giá đang Chờ duyệt;
  if (Từ chối mà thiếu lý do?) then (Có)
    :Trả lỗi bắt buộc lý do;
    stop
  endif
}

partition "Cơ sở dữ liệu" {
  if (Duyệt?) then (Có)
    :Cập nhật DANH_GIA_DU_AN = Đã duyệt;
    :Lưu người duyệt, ngày duyệt;
  else (Từ chối)
    :Cập nhật DANH_GIA_DU_AN = Từ chối;
    :Lưu người duyệt, ngày duyệt và lý do;
  endif
}

partition "Hệ thống MVC" {
  :Trả kết quả về danh sách/chi tiết đánh giá;
}

stop
@enduml
